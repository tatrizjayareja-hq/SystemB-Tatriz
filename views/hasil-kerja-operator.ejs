<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Rekap Hasil Saya - Tatriz</title>
    <style>
        body { font-family: 'Segoe UI', sans-serif; background: #e2e7e2; padding: 15px; margin: 0; }
        .header-box { background: white; padding: 15px; border-radius: 12px; box-shadow: 0 2px 5px rgba(0,0,0,0.05); margin-bottom: 15px; }
        .filter-input { width: 100%; padding: 12px; border: 1px solid #ddd; border-radius: 8px; box-sizing: border-box; font-size: 16px; margin-top: 10px; }
        .rekap-container { background: white; border-radius: 12px; overflow: hidden; box-shadow: 0 2px 8px rgba(0,0,0,0.1); }
        table { width: 100%; border-collapse: collapse; }
        th { background: #2d3436; color: white; padding: 12px; text-align: left; font-size: 14px; }
        .row-tanggal { background: #fff; border-bottom: 1px solid #eee; cursor: pointer; transition: 0.2s; }
        .row-tanggal:hover { background: #f9f9f9; }
        .row-tanggal td { padding: 15px 12px; font-weight: bold; }
        .row-detail { display: none; background: #fdfdfd; }
        .detail-box { padding: 10px; border-left: 4px solid #0984e3; margin: 5px 10px; background: white; border: 1px solid #eee; border-radius: 4px; }
        .inner-table { width: 100%; font-size: 13px; margin-top: 5px; }
        .inner-table th { background: #f1f2f6; color: #666; padding: 5px; }
        .inner-table td { border-bottom: 1px solid #f1f1f1; padding: 8px 5px; font-weight: normal; }
        .arrow { float: right; transition: 0.3s; color: #0984e3; }
        .rotate { transform: rotate(180deg); }
    </style>
</head>
<body>
    <% 
        const isInternal = access.isInternal; 
        const grouped = {};

        rows.forEach(r => {
            if (!grouped[r.tanggal]) grouped[r.tanggal] = { items: [], totalOmzet: 0, totalQty: 0 };
            const qty = Number(r.jumlah_setor) || 0;
            const harga = Number(r.harga_operator) || 0;
            
            grouped[r.tanggal].items.push(r);
            grouped[r.tanggal].totalOmzet += (qty * harga);
            grouped[r.tanggal].totalQty += qty;
        });

        const sortedDates = Object.keys(grouped).sort((a, b) => new Date(b) - new Date(a));
    %>

    <div class="header-box">    
        <h2 style="margin: 10px 0 5px 0;text-align:center;">Halo, <%= userName %>! 👋</h2>
        <p style="margin: 0; color: #888; font-size: 13px;text-align:center">Rekapitulasi hasil setoran produksi Anda.</p>       
        <input type="text" id="filterInput" class="filter-input" placeholder="Cari Tanggal atau Nama PO..." onkeyup="liveFilter()">
    </div>

    <div class="header-box" style="display: flex; gap: 10px; justify-content: center;">
        <a href="/operator" style="background: #0984e3; color: white; padding: 8px 15px; border-radius: 8px; text-decoration: none; font-weight: bold; font-size: 14px;">+ Input Hasil</a>
        <a href="/logout" style="background: #e30909; color: white; padding: 8px 15px; border-radius: 8px; text-decoration: none; font-weight: bold; font-size: 14px;">🚪 Keluar</a>
    </div>

    <div class="rekap-container">
        <table>
            <thead>
                <tr>
                    <th>Tanggal Produksi</th>
                    <th style="text-align: right;"><%= isInternal ? 'Pencapaian (Rp)' : 'Total Setor' %></th>
                </tr>
            </thead>
            <tbody id="rekapTable">
                <% sortedDates.forEach((tgl, index) => { 
                    let dHarian = grouped[tgl];
                %>
                <tr class="row-tanggal" onclick="toggleLaci('<%= index %>')">
                    <td>
                        <span class="tgl-text">
                            <%= new Date(tgl).toLocaleDateString('id-ID', { day: '2-digit', month: 'long', year: 'numeric' }) %>
                        </span>
                        <span class="arrow" id="arrow-<%= index %>">▼</span>
                    </td>
                    <td style="text-align: right;">
                        <% if (isInternal) { %>
                            Rp <%= dHarian.totalOmzet.toLocaleString() %>
                        <% } else { %>
                            <%= dHarian.totalQty %> Pcs
                        <% } %>
                    </td>
                </tr>

                <tr class="row-detail" id="laci-<%= index %>">
                    <td colspan="2">
                        <div class="detail-box">
                            <table class="inner-table">
                                <thead>
                                    <tr>
                                        <th>Nama PO / Desain</th>
                                        <th style="text-align: center;">Shift</th>
                                        <th style="text-align: center;">Qty</th>
                                        <% if (isInternal) { %>
                                            <th style="text-align: right;">Subtotal</th>
                                        <% } %>
                                    </tr>
                                </thead>
                                <tbody>
                                    <% dHarian.items.forEach(item => { %>
                                        <tr>
                                            <td>
                                                <b><%= item.nama_po %></b><br>
                                                <small><%= item.nama_desain %></small>
                                            </td>
                                            <td style="text-align: center;"><%= item.shift %></td>
                                            <td style="text-align: center;"><b><%= item.jumlah_setor %></b></td>
                                            <% if (isInternal) { %>
                                                <td style="text-align: right;">Rp <%= (item.jumlah_setor * item.harga_operator).toLocaleString() %></td>
                                            <% } %>
                                        </tr>
                                    <% }) %>
                                </tbody>
                            </table>
                        </div>
                    </td>
                </tr>
                <% }) %>
            </tbody>
        </table>
    </div>

    <script>
        function toggleLaci(idx) {
            const laci = document.getElementById('laci-' + idx);
            const arrow = document.getElementById('arrow-' + idx);
            if (laci.style.display === 'table-row') {
                laci.style.display = 'none';
                arrow.classList.remove('rotate');
            } else {
                laci.style.display = 'table-row';
                arrow.classList.add('rotate');
            }
        }

        function liveFilter() {
            let input = document.getElementById("filterInput").value.toLowerCase();
            let table = document.getElementById("rekapTable");
            let rows = table.getElementsByClassName("row-tanggal");
            let details = table.getElementsByClassName("row-detail");

            for (let i = 0; i < rows.length; i++) {
                let tglText = rows[i].querySelector(".tgl-text").innerText.toLowerCase();
                let poTexts = details[i].innerText.toLowerCase();

                if (tglText.includes(input) || poTexts.includes(input)) {
                    rows[i].style.display = "";
                } else {
                    rows[i].style.display = "none";
                    details[i].style.display = "none";
                }
            }
        }
    </script>
</body>
</html>