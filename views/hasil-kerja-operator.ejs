<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Rekap Hasil Saya - Tatriz</title>
    <style>
        body { font-family: 'Segoe UI', sans-serif; background: #e2e7e2; padding: 15px; margin: 0; }
        .header-box { background: white; padding: 15px; border-radius: 12px; box-shadow: 0 2px 5px rgba(0,0,0,0.05); margin-bottom: 15px; }
        .filter-input { width: 100%; padding: 12px; border: 1px solid #ddd; border-radius: 8px; box-sizing: border-box; font-size: 16px; margin-top: 10px; }
        .rekap-container { background: white; border-radius: 12px; overflow: hidden; box-shadow: 0 2px 8px rgba(0,0,0,0.1); }
        table { width: 100%; border-collapse: collapse; }
        th { background: #2d3436; color: white; padding: 12px; text-align: left; font-size: 14px; }
        .row-tanggal { background: #fff; border-bottom: 1px solid #eee; cursor: pointer; transition: 0.2s; }
        .row-tanggal:hover { background: #f9f9f9; }
        .row-tanggal td { padding: 15px 12px; font-weight: bold; }
        .row-detail { display: none; background: #fdfdfd; }
        .detail-box { padding: 10px; border-left: 4px solid #0984e3; margin: 5px 10px; background: white; border: 1px solid #eee; border-radius: 4px; }
        .inner-table { width: 100%; font-size: 13px; margin-top: 5px; }
        .inner-table th { background: #f1f2f6; color: #666; padding: 5px; }
        .inner-table td { border-bottom: 1px solid #f1f1f1; padding: 8px 5px; font-weight: normal; }
        .bonus-tag { background: #27ae60; color: white; padding: 2px 6px; border-radius: 4px; font-size: 11px; margin-left: 5px; }
        .arrow { float: right; transition: 0.3s; color: #0984e3; }
        .rotate { transform: rotate(180deg); }
        .filter-periode-box { display: flex; gap: 8px; align-items: center; margin-top: 12px; padding-top: 12px; border-top: 1px dashed #eee; }
        .select-periode { padding: 10px; border-radius: 8px; border: 1px solid #ddd; font-size: 14px; background: #fff; flex-grow: 1; }
        .btn-cari { background: #27ae60; color: white; border: none; padding: 10px 15px; border-radius: 8px; font-weight: bold; cursor: pointer; }
    </style>
</head>
<body>
    <div id="loaderSistem" style="position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: #195e0b; z-index: 99999; display: flex; flex-direction: column; justify-content: center; align-items: center; transition: opacity 0.3s ease, visibility 0.3s ease;">
        <div style="width: 50px; height: 50px; border: 5px solid rgba(255,255,255,0.2); border-top: 5px solid #59cf77; border-radius: 50%; animation: putar 1s linear infinite;"></div>
        <p style="color: white; margin-top: 18px; font-weight: bold; font-size: 14px;">MEMUAT SISTEM...</p>
        <style>@keyframes putar { 0% { transform: rotate(0deg); } 100% { transform: rotate(360deg); } }</style>
    </div>

    <script>
        document.addEventListener('DOMContentLoaded', function() {
            setTimeout(() => {
                const l = document.getElementById('loaderSistem');
                if(l) { l.style.opacity = '0'; l.style.visibility = 'hidden'; }
            }, 300);
        });
    </script>

    <% 
        // ==========================================
        // BLOK KEAMANAN (Mencegah EJS Crash)
        // ==========================================
        const dataRows = Array.isArray(rows) ? rows : (rows && rows.rows ? rows.rows : []);
        const activeConfig = config || {};
        const isInternal = access && access.isInternal ? true : false;
        
        // Memastikan angka config valid agar tidak error hitungan
        const tBonus = Number(activeConfig.target_bonus) || 0;
        const bDasar = Number(activeConfig.nominal_bonus_dasar) || 0;
        const bLipat = Number(activeConfig.nominal_bonus_lipat) || 0;
        const kBonus = Number(activeConfig.kelipatan_bonus) || 1; // Jangan sampai 0 (dibagi 0 = error)

        let totalGajiMingguIni = 0;
        const tanggalUnik = new Set();
        
        const bulanDipilih = filterBulan || new Date().toISOString().slice(0, 7);
        const sekarang = new Date();
        const day = sekarang.getDay(); 
        const diff = sekarang.getDate() - day + (day === 0 ? -6 : 1);
        const awalMinggu = new Date(sekarang.setDate(diff));
        awalMinggu.setHours(0,0,0,0);

        const grouped = {};
        dataRows.forEach(r => {
            if (!grouped[r.tanggal]) grouped[r.tanggal] = { items: [], totalOmzet: 0, totalQty: 0 };
            
            const qty = Number(r.jumlah_setor) || 0;
            const harga = Number(r.harga_operator) || 0;
            
            grouped[r.tanggal].items.push(r);
            grouped[r.tanggal].totalOmzet += (qty * harga);
            grouped[r.tanggal].totalQty += qty;

            if(new Date(r.tanggal) >= awalMinggu) tanggalUnik.add(r.tanggal);
        });

        if (isInternal) {
            let akumulasiBonus = 0;
            Object.keys(grouped).forEach(tgl => {
                const dHarian = grouped[tgl];
                if (new Date(tgl) >= awalMinggu && dHarian.totalOmzet >= tBonus) {
                    akumulasiBonus += bDasar + (Math.floor((dHarian.totalOmzet - tBonus) / kBonus) * bLipat);
                }
            });
            const gp = (user && user.gaji_pokok) ? Number(user.gaji_pokok) : 0;
            totalGajiMingguIni = (gp * tanggalUnik.size) + akumulasiBonus;
        }

        const sortedDates = Object.keys(grouped).sort((a, b) => new Date(b) - new Date(a));
    %>

    <div class="header-box">    
        <h2 style="margin: 10px 0 5px 0;text-align:center;">Halo, <%= userName || 'Karyawan' %>! 👋</h2>
        <p style="margin: 0; color: #888; font-size: 13px;text-align:center">Laporan hasil kerja Anda di sistem Tatriz.</p>       
        
        <input type="text" id="filterInput" class="filter-input" placeholder="Cari Tanggal atau Nama PO..." onkeyup="liveFilter()">
        
        <form action="/hasil-saya" method="GET" class="filter-periode-box">
            <label style="font-size: 13px; font-weight: bold; color: #555;">Periode:</label>
            <input type="month" name="bulan" class="select-periode" value="<%= bulanDipilih %>" required>
            <button type="submit" class="btn-cari">Buka</button>
        </form>
    </div>

    <% if (isInternal) { %>
        <div class="header-box" style="background: #27ae60; color: white; text-align: center;">
            <small style="opacity: 0.9;">Estimasi Bonus Minggu Ini :</small>
            <h2 style="margin: 5px 0 0 0;">Rp <%= (totalGajiMingguIni || 0).toLocaleString('id-ID') %></h2>
        </div>
    <% } %>

    <div class="header-box" style="display: flex; gap: 10px; justify-content: center;">
        <a href="/operator" style="background: #0984e3; color: white; padding: 8px 15px; border-radius: 8px; text-decoration: none; font-weight: bold; font-size: 14px;">+ Input Hasil</a>
        <a href="/logout" style="background: #e30909; color: white; padding: 8px 15px; border-radius: 8px; text-decoration: none; font-weight: bold; font-size: 14px;">🚪 Keluar</a>
    </div>

    <div class="rekap-container">
        <table>
            <thead>
                <tr>
                    <th>Rekap Per Tanggal</th>
                    <th style="text-align: right;"><%= isInternal ? 'Pencapaian Omzet' : 'Total Setor' %></th>
                </tr>
            </thead>
            <tbody id="rekapTable">
                <% if (sortedDates.length === 0) { %>
                    <tr>
                        <td colspan="2" style="text-align: center; padding: 30px; color: #999;">Belum ada data di bulan ini.</td>
                    </tr>
                <% } %>
                
                <% sortedDates.forEach((tgl, index) => { 
                    let dHarian = grouped[tgl];
                    let bonusHarian = 0;
                    if (isInternal && dHarian.totalOmzet >= tBonus) {
                        bonusHarian = bDasar + (Math.floor((dHarian.totalOmzet - tBonus) / kBonus) * bLipat);
                    }
                %>
                <tr class="row-tanggal" onclick="toggleLaci('<%= index %>')">
                    <td>
                        <span class="tgl-text"><%= new Date(tgl).toLocaleDateString('id-ID', { day: '2-digit', month: 'long' }) %></span>
                        <% if(isInternal && bonusHarian > 0) { %><span class="bonus-tag">🎁 Rp <%= bonusHarian.toLocaleString() %></span><% } %>
                        <span class="arrow" id="arrow-<%= index %>">▼</span>
                    </td>
                    <td style="text-align: right;"><%= isInternal ? 'Rp ' + dHarian.totalOmzet.toLocaleString() : dHarian.totalQty + ' Pcs' %></td>
                </tr>

                <tr class="row-detail" id="laci-<%= index %>">
                    <td colspan="2">
                        <div class="detail-box">
                            <table class="inner-table">
                                <thead>
                                    <tr>
                                        <th>PO / Desain</th>
                                        <th style="text-align: center;">Shift</th>
                                        <th style="text-align: center;">Qty</th>
                                        <% if (isInternal) { %><th style="text-align: right;">Subtotal</th><% } %>
                                    </tr>
                                </thead>
                                <tbody>
                                    <% dHarian.items.forEach(item => { %>
                                        <tr>
                                            <td><b><%= item.nama_po %></b><br><small><%= item.nama_desain %></small></td>
                                            <td style="text-align: center;"><%= item.shift %></td>
                                            <td style="text-align: center;"><b><%= item.jumlah_setor %></b></td>
                                            <% if (isInternal) { %><td style="text-align: right;">Rp <%= (item.jumlah_setor * item.harga_operator).toLocaleString() %></td><% } %>
                                        </tr>
                                    <% }) %>
                                </tbody>
                            </table>
                        </div>
                    </td>
                </tr>
                <% }) %>
            </tbody>
        </table>
    </div>

    <script>
        function toggleLaci(idx) {
            const laci = document.getElementById('laci-' + idx);
            const arrow = document.getElementById('arrow-' + idx);
            if (laci.style.display === 'table-row') {
                laci.style.display = 'none'; arrow.classList.remove('rotate');
            } else {
                laci.style.display = 'table-row'; arrow.classList.add('rotate');
            }
        }
        function liveFilter() {
            let input = document.getElementById("filterInput").value.toLowerCase();
            let table = document.getElementById("rekapTable");
            let rows = table.getElementsByClassName("row-tanggal");
            let details = table.getElementsByClassName("row-detail");
            for (let i = 0; i < rows.length; i++) {
                let tglText = rows[i].querySelector(".tgl-text").innerText.toLowerCase();
                let poTexts = details[i].innerText.toLowerCase();
                if (tglText.includes(input) || poTexts.includes(input)) {
                    rows[i].style.display = "";
                } else {
                    rows[i].style.display = "none"; details[i].style.display = "none";
                }
            }
        }
    </script>
</body>
</html>