<%- include('../partials/header.ejs') %>
<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-5">
            <div class="card shadow">
                <div class="card-header bg-success text-white">
                    <h5 class="mb-0">Pilih Periode Gaji</h5>
                </div>
                <div class="card-body">
                    <form action="/input-gaji" method="GET">
                        <div class="mb-3">
                            <label>Tanggal Mulai (Senin)</label>
                            <input type="date" name="tgl_awal" class="form-control" required>
                        </div>
                        <div class="mb-3">
                            <label>Tanggal Selesai (Minggu)</label>
                            <input type="date" name="tgl_akhir" class="form-control" required>
                        </div>
                        <button type="submit" class="btn btn-success w-100">Proses Hitung Gaji</button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
<script>
    const tglAwalInput = document.querySelector('input[name="tgl_awal"]');
    const tglAkhirInput = document.querySelector('input[name="tgl_akhir"]');

    // 1. Set Default Tanggal Awal ke hari Senin pada minggu berjalan
    const today = new Date();
    const day = today.getDay();
    // Logika mencari hari Senin terdekat (day 1)
    const diff = today.getDate() - day + (day === 0 ? -6 : 1); 
    const monday = new Date(today.setDate(diff));
    tglAwalInput.value = monday.toISOString().split('T')[0];

    // 2. Fungsi hitung otomatis 6 hari ke depan (Default satu minggu)
    function setOtomatisAkhir() {
        if (tglAwalInput.value) {
            let startDate = new Date(tglAwalInput.value);
            // Tambah 6 hari agar berakhir di hari Minggu
            startDate.setDate(startDate.getDate() + 6); 
            tglAkhirInput.value = startDate.toISOString().split('T')[0];
        }
    }

    // Jalankan saat halaman pertama kali dibuka
    setOtomatisAkhir();

    // Jalankan jika Admin mengubah tanggal mulai
    tglAwalInput.addEventListener('change', setOtomatisAkhir);
</script>
<%- include('../partials/footer') %>