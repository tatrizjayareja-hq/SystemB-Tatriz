<%- include('../partials/header') %>
<div class="container-fluid mt-4">
    <div class="card shadow-sm border-0 p-3">
        <h5 class="fw-bold"><i class="bi bi-shield-check"></i> Input Hasil QC</h5>
        <p class="text-muted small">Input jumlah barang yang sudah selesai diperiksa.</p>

        <form action="/simpan-qc" method="POST">
            <div class="mb-3">
                <label class="form-label small fw-bold">Pilih PO</label>
                <select name="po_id" class="form-select" onchange="muatDetail(this.value)" required>
                    <option value="">-- Pilih PO --</option>
                    <% active_pos.forEach(po => { %>
                        <option value="<%= po.id %>"><%= po.nama_po %></option>
                    <% }) %>
                </select>
            </div>

            <div class="mb-3">
                <label class="form-label small fw-bold">Pilih Desain</label>
                <select name="detail_id" id="select_detail" class="form-select" required disabled>
                    <option value="">-- Pilih Desain --</option>
                </select>
            </div>

            <div class="mb-3">
                <label class="form-label small fw-bold">Jumlah Lulus QC (Pcs)</label>
                <input type="number" name="jumlah_qc" class="form-control form-control-lg" placeholder="0" required>
            </div>

            <button type="submit" class="btn btn-primary w-100 py-3 fw-bold">SIMPAN HASIL QC</button>
        </form>
    </div>
</div>

<script>
async function muatDetail(poId) {
    const sel = document.getElementById('select_detail');
    if(!poId) { sel.disabled = true; return; }
    
    const res = await fetch(`/api/po-details/${poId}`);
    const data = await res.json();
    
    let html = '<option value="">-- Pilih Desain --</option>';
    data.forEach(d => {
        html += `<option value="${d.id}">${d.nama_desain} (${d.jenis_bordir})</option>`;
    });
    sel.innerHTML = html;
    sel.disabled = false;
}
</script>
<%- include('../partials/footer') %>