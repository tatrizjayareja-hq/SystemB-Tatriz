<%- include('../partials/header') %>
<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

<div class="container-fluid mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h4><i class="bi bi-person-badge"></i> Analisis Performa Operator</h4>
        <form action="/performa-operator" method="GET" class="d-flex gap-2">
            <input type="month" name="bulan" value="<%= bulanIni %>" class="form-control form-control-sm" onchange="this.form.submit()">
        </form>
    </div>

    <div class="row mb-4">
        <div class="col-12">
            <div class="card shadow-sm border-0">
                <div class="card-body">
                    <h6 class="card-title text-muted mb-4"><i class="bi bi-trophy"></i> Peringkat Produktivitas Bulan Ini</h6>
                    <div style="height: 300px;">
                        <canvas id="chartPerformaOps"></canvas>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="card shadow-sm border-0">
        <div class="card-header bg-white py-3 d-flex justify-content-between align-items-center">
            <h6 class="mb-0 fw-bold">Matriks Produksi Harian</h6>
            <div class="small">
                <% if (isInternal) { %>
                    <span class="badge bg-success">≥ Rp <%= targetDinamis.toLocaleString('id-ID') %> (Target)</span>
                <% } %>
                <span class="badge bg-danger"> < Rp 100.000 (Rendah)</span>
            </div>
        </div> <div class="table-responsive">
            <table class="table table-bordered table-hover align-middle mb-0" style="font-size: 12px;">
                <thead class="table-dark text-center">
                    <tr>
                        <th style="width: 80px;">Tgl</th>
                        <% operators.forEach(op => { %>
                            <th><%= op.nama_lengkap %></th>
                        <% }) %>
                        
                        <% if (isInternal) { %>
                            <th class="bg-warning text-dark">Total Upah (Op)</th>
                        <% } %>
                        <th class="bg-primary">Total Produksi</th> 
                    </tr>
                </thead>

                <tbody>
                    <% for(let d = 1; d <= jumlahHari; d++) { 
                        let tglKey = bulanIni + "-" + String(d).padStart(2, '0');
                        let dataTgl = matriks[tglKey] || null;
                    %>
                    <tr>
                        <td class="text-center fw-bold"><%= String(d).padStart(2, '0') %>/<%= bulanIni.split('-')[1] %></td>
                        <% operators.forEach(op => { 
                            let upah = dataTgl ? (dataTgl[op.id] || 0) : 0;
                            let cellClass = "";
                            
                            if (upah === 0) {
                                cellClass = "bg-light text-danger"; 
                            } else if (upah >= targetDinamis) {
                                cellClass = "bg-success text-white fw-bold"; 
                            } else if (upah < 100000) {
                                cellClass = "bg-danger text-white"; 
                            }
                        %>
                            <td class="text-end <%= cellClass %>">
                                <%= upah > 0 ? 'Rp ' + upah.toLocaleString('id-ID') : '-' %>
                            </td>
                        <% }) %>

                        <% if (isInternal) { %>
                            <td class="text-end fw-bold bg-warning bg-opacity-10">
                                Rp <%= dataTgl ? dataTgl.total_upah_op.toLocaleString('id-ID') : 0 %>
                            </td>
                        <% } %>

                        <td class="text-end fw-bold bg-primary bg-opacity-10 text-primary">
                            Rp <%= dataTgl ? dataTgl.total_omzet_cust.toLocaleString('id-ID') : 0 %>
                        </td>
                    </tr>
                    <% } %>
                </tbody>
            </table>
        </div>
    </div>
</div>

<script>
    // Script Chart.js tetap sama, pastikan data performaOps terkirim dari server
    const rawData = JSON.parse('<%- JSON.stringify(performaOps) %>');
    const sortedData = Object.values(rawData).sort((a, b) => b.totalUpah - a.totalUpah);
    
    const labels = sortedData.map(item => item.nama);
    const datasetUpah = sortedData.map(item => item.totalUpah);

    const ctx = document.getElementById('chartPerformaOps');
    if (ctx) {
        new Chart(ctx.getContext('2d'), {
            type: 'bar',
            data: {
                labels: labels,
                datasets: [{
                    label: 'Total Produksi (Rp)',
                    data: datasetUpah,
                    backgroundColor: 'rgba(46, 204, 113, 0.7)',
                    borderColor: 'rgba(46, 204, 113, 1)',
                    borderWidth: 1,
                    borderRadius: 8,
                    barThickness: 25,
                }]
            },
            options: {
                indexAxis: 'y',
                responsive: true,
                maintainAspectRatio: false,
                plugins: {
                    legend: { display: false },
                    tooltip: {
                        callbacks: {
                            footer: (tooltipItems) => {
                                const index = tooltipItems[0].dataIndex;
                                const capai = sortedData[index].kaliCapaiTarget;
                                return `Target Tercapai: ${capai} kali`;
                            }
                        }
                    }
                },
                scales: {
                    x: {
                        beginAtZero: true,
                        ticks: {
                            callback: (value) => 'Rp ' + value.toLocaleString('id-ID')
                        }
                    }
                }
            }
        });
    }
</script>
<%- include('../partials/footer') %>