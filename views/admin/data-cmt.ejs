<%- include('../partials/header') %>
<style>
    .badge-sisa { font-size: 10px; padding: 3px 8px; border-radius: 20px; }
    .card-sj { border-left: 5px solid #e67e22; transition: 0.3s; }
    .card-sj:hover { transform: translateY(-3px); box-shadow: 0 4px 15px rgba(0,0,0,0.1); }
    .input-qty-sj { width: 80px !important; text-align: center; border-color: #e67e22; }
    .bg-vendor { background-color: #fff9f4; }
    .area-detail-laci { background: #f8f9fa; border: 1px dashed #ddd; border-radius: 8px; margin-top: 10px; padding: 10px; font-size: 11px; }
</style>

<div class="container-fluid mt-3" style="max-width: 1100px;">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h4 class="fw-bold mb-0">🚜 Kelola CMT & Vendor</h4>
        <a href="/dashboard" class="btn btn-outline-secondary btn-sm">Kembali</a>
    </div>

    <div class="row">
        <div class="col-md-8">
            <div class="card shadow-sm mb-4">
                <div class="card-header bg-dark text-white py-3">
                    <h6 class="mb-0 fw-bold"><i class="bi bi-box-seam me-2"></i> Stok Antrean Bordir CMT</h6>
                </div>
                <div class="card-body p-0">
                    <form action="/admin/simpan-sj-cmt" method="POST" id="formSJ">
                        <div class="p-3 bg-vendor border-bottom">
                            <div class="row g-2">
                                <div class="col-md-6">
                                    <label class="small fw-bold">NAMA VENDOR / PENGERJA:</label>
                                    <input type="text" name="nama_vendor" class="form-control form-control-sm" placeholder="Contoh: Pak Haji / Workshop B" required>
                                </div>
                                <div class="col-md-6">
                                    <label class="small fw-bold">TANGGAL KIRIM:</label>
                                    <input type="date" name="tanggal_kirim" class="form-control form-control-sm" id="tglSJ" required>
                                </div>
                            </div>
                        </div>

                        <div class="table-responsive">
                            <table class="table table-hover align-middle mb-0" style="font-size: 12px;">
                                <thead class="table-light">
                                    <tr>
                                        <th width="40">Pilih</th>
                                        <th>PO / Desain</th>
                                        <th class="text-center">Sisa Saldo</th>
                                        <th width="120" class="text-center">Kirim Qty</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <% orders.forEach(po => { 
                                        let sub = details.filter(d => d.po_id == po.id);
                                        sub.forEach(dsn => {
                                            if(dsn.sisa_siap_kirim > 0) {
                                    %>
                                    <tr>
                                        <td class="text-center">
                                            <input type="checkbox" name="detail_ids" value="<%= dsn.id %>" class="form-check-input check-dsn" onchange="toggleInput(this)">
                                            <input type="hidden" name="harga_cmt" value="<%= dsn.harga_cmt %>" disabled class="input-harga">
                                        </td>
                                        <td>
                                            <strong><%= po.nama_po %></strong><br>
                                            <span class="text-muted text-uppercase" style="font-size: 10px;"><%= dsn.nama_desain %> (<%= dsn.jenis_bordir %>)</span>
                                        </td>
                                        <td class="text-center">
                                            <span class="badge bg-info badge-sisa"><%= dsn.sisa_siap_kirim %> / <%= dsn.jumlah %> Pcs</span>
                                        </td>
                                        <td class="text-center">
                                            <input type="number" name="qty_kirim" class="form-control form-control-sm input-qty-sj d-none" 
                                                   max="<%= dsn.sisa_siap_kirim %>" min="1" placeholder="Qty">
                                        </td>
                                    </tr>
                                    <% } }) }) %>
                                    <% if (details.filter(d => d.sisa_siap_kirim > 0).length === 0) { %>
                                        <tr><td colspan="4" class="text-center py-4 text-muted">Semua stok CMT sudah terbagi ke vendor.</td></tr>
                                    <% } %>
                                </tbody>
                            </table>
                        </div>
                        
                        <div class="p-3 text-end bg-light">
                            <button type="submit" class="btn btn-warning btn-sm fw-bold">
                                <i class="bi bi-send-plus"></i> BUAT SURAT JALAN KE VENDOR
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <h6 class="fw-bold mb-3"><i class="bi bi-clock-history"></i> Surat Jalan Terbaru</h6>
            
            <% if(historySJ.length > 0) { %>
                <% historySJ.forEach(sj => { %>
                <div class="card card-sj shadow-sm mb-2 border-0">
                    <div class="card-body p-2">
                        <div class="d-flex justify-content-between align-items-start">
                            <div>
                                <small class="text-muted" style="font-size: 10px;">
                                    <%= new Date(sj.tanggal_kirim).toLocaleDateString('id-ID') %> | ID: #<%= sj.id %>
                                </small>
                                <h6 class="mb-0 fw-bold text-uppercase"><%= sj.nama_vendor %></h6>
                                <small class="fw-bold text-danger">Estimasi: Rp <%= Number(sj.total_biaya_vendor).toLocaleString('id-ID') %></small>
                            </div>
                            <span class="badge <%= sj.status === 'PROSES' ? 'bg-warning text-dark' : 'bg-success' %>" style="font-size: 9px;">
                                <%= sj.status %>
                            </span>
                        </div>

                        <div id="laci-<%= sj.id %>" class="area-detail-laci d-none mt-2" style="background: #f8f9fa; border: 1px dashed #ddd; padding: 8px; border-radius: 5px;">
                            <div style="font-size: 9px; font-weight: bold; color: #666; margin-bottom: 5px; text-transform: uppercase; border-bottom: 1px solid #eee;">Rincian Barang:</div>
                            <table class="table table-sm table-borderless mb-0" style="font-size: 10px;">
                                <% 
                                // Gunakan Number() untuk memastikan ID dibandingkan secara akurat antar row database
                                let items = allSjDetails.filter(i => Number(i.sj_id) === Number(sj.id));
                                if(items.length > 0) {
                                    items.forEach(item => { 
                                %>
                                <tr class="border-bottom border-white">
                                    <td>
                                        <strong><%= item.nama_po %></strong><br>
                                        <small class="text-muted"><%= item.nama_desain %></small>
                                    </td>
                                    <td class="text-end fw-bold align-middle"><%= item.qty_dikirim %> Pcs</td>
                                </tr>
                                <%     }); 
                                } else { %>
                                <tr>
                                    <td colspan="2" class="text-center text-muted small">Rincian data tidak tersedia</td>
                                </tr>
                                <% } %>
                            </table>
                        </div>

                        <div class="mt-2 pt-2 border-top d-flex gap-1">
                            <button onclick="toggleLaci('<%= sj.id %>')" class="btn btn-primary btn-sm px-3" style="font-size: 10px;">
                                <i class="bi bi-list-ul"></i> DETAIL
                            </button>
                            <% if(sj.status === 'PROSES') { %>
                                <button onclick="tandaiSelesai('<%= sj.id %>')" class="btn btn-success btn-sm px-3" style="font-size: 10px;">
                                    <i class="bi bi-check-circle"></i> SELESAI
                                </button>
                            <% } %>
                        </div>
                    </div>
                </div>
                <% }) %>
            <% } else { %>
                <div class="text-center p-4 bg-white rounded border shadow-sm">
                    <i class="bi bi-truck text-muted fs-2"></i><br>
                    <small class="text-muted d-block mt-2">Belum ada pengiriman ke vendor.</small>
                </div>
            <% } %>
        </div>

<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
<script>
    document.getElementById('tglSJ').valueAsDate = new Date();

    function toggleInput(checkbox) {
        const row = checkbox.closest('tr');
        const qtyInput = row.querySelector('.input-qty-sj');
        const hargaInput = row.querySelector('.input-harga');
        
        if (checkbox.checked) {
            qtyInput.classList.remove('d-none');
            qtyInput.required = true;
            hargaInput.disabled = false;
        } else {
            qtyInput.classList.add('d-none');
            qtyInput.required = false;
            qtyInput.value = '';
            hargaInput.disabled = true;
        }
    }

    // Fungsi Laci Detail
    function toggleLaci(id) {
        const target = document.getElementById('laci-' + id);
        if (target.classList.contains('d-none')) {
            target.classList.remove('d-none');
        } else {
            target.classList.add('d-none');
        }
    }

    function tandaiSelesai(id) {
        Swal.fire({
            title: 'Konfirmasi Selesai?',
            text: "Barang sudah kembali dan akan dimasukkan ke stok produksi?",
            icon: 'question',
            showCancelButton: true,
            confirmButtonColor: '#27ae60',
            confirmButtonText: 'Ya, Selesai!'
        }).then((result) => {
            if (result.isConfirmed) {
                window.location.href = `/admin/selesai-sj-cmt/${id}`;
            }
        })
    }
</script>
<%- include('../partials/footer') %>