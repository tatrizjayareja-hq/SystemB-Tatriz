<%- include('../partials/header') %>

<div class="container-fluid mt-3" style="max-width: 1100px;">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h4 class="fw-bold mb-0">🚜 Monitor Produksi & Hutang CMT</h4>
        <a href="/dashboard" class="btn btn-outline-secondary btn-sm">Kembali</a>
    </div>

    <div class="card shadow-sm border-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0" style="font-size: 13px;">
                <thead class="table-dark">
                    <tr>
                        <th width="30%">PO / Desain</th>
                        <th width="10%" class="text-center">Gudang</th>
                        <th width="45%">Monitor Vendor & Status</th>
                        <th width="15%" class="text-end">Aksi</th>
                    </tr>
                </thead>
                <tbody>
                    <% if (dataCMT.length === 0) { %>
                        <tr>
                            <td colspan="4" class="text-center py-5 text-muted">
                                <i class="bi bi-check-all fs-2"></i><br>
                                Semua pekerjaan CMT selesai & lunas.
                            </td>
                        </tr>
                    <% } %>

                    <% dataCMT.forEach(item => { %>
                        <tr>
                            <td>
                                <strong><%= item.nama_po %></strong><br>
                                <small class="text-muted"><%= item.nama_desain %> (<%= item.jenis_bordir %>)</small>
                            </td>
                            <td class="text-center">
                                <span class="badge rounded-pill bg-light text-dark border"><%= item.sisa_gudang %> Pcs</span>
                            </td>
                            <td>
                                <% if (item.list_vendor && item.list_vendor.length > 0 && item.list_vendor[0].sj_id !== null) { %>
                                    <% item.list_vendor.forEach(v => { %>
                                        <div class="d-flex justify-content-between align-items-center mb-1 p-2 bg-light rounded border-start border-4 <%= v.status_sj === 'PROSES' ? 'border-warning' : 'border-success' %>">
                                            <div>
                                                <strong class="text-uppercase"><%= v.nama_vendor %></strong> 
                                                <small class="ms-1 badge bg-white text-dark border"><%= v.qty %> Pcs</small>
                                                
                                                <% if(v.status_sj === 'PROSES') { %>
                                                    <span class="badge bg-warning text-dark ms-1" style="font-size: 9px;">DI VENDOR</span>
                                                <% } else { %>
                                                    <span class="badge <%= v.status_bayar === 'LUNAS' ? 'bg-success' : 'bg-danger' %> ms-1" style="font-size: 9px;">
                                                        <%= v.status_bayar %>
                                                    </span>
                                                <% } %>
                                            </div>
                                            
                                            <div class="btn-group">
                                                <% if(v.status_sj === 'PROSES') { %>
                                                    <button onclick="konfirmasiTerima('<%= v.sj_detail_id %>')" class="btn btn-xs btn-success py-0 px-2" style="font-size: 10px;">TERIMA</button>
                                                <% } else if(v.status_bayar !== 'LUNAS') { %>
                                                    <button onclick="konfirmasiBayar('<%= v.sj_id %>')" class="btn btn-xs btn-primary py-0 px-2" style="font-size: 10px;">LUNASI</button>
                                                <% } %>
                                            </div>
                                        </div>
                                    <% }) %>
                                <% } else { %>
                                    <small class="text-muted fst-italic">Belum ada pengiriman ke vendor</small>
                                <% } %>
                            </td>
                            <td class="text-end">
                                <% if(item.sisa_gudang > 0) { %>
                                    <button onclick="bukaModalKirim('<%= item.detail_id %>', '<%= item.sisa_gudang %>', '<%= item.harga_cmt %>')" class="btn btn-sm btn-outline-primary fw-bold">
                                        + KIRIM
                                    </button>
                                <% } %>
                            </td>
                        </tr>
                    <% }) %>
                </tbody>
            </table>
        </div>
    </div>
</div>

<div class="modal fade" id="modalKirim" tabindex="-1">
    <div class="modal-dialog modal-sm">
        <form action="/admin/kirim-ke-vendor" method="POST" class="modal-content shadow-lg">
            <div class="modal-header bg-dark text-white py-2">
                <h6 class="modal-title fw-bold">Kirim ke Luar</h6>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <input type="hidden" name="detail_id" id="modal_detail_id">
                <input type="hidden" name="harga_cmt" id="modal_harga_cmt">
                
                <div class="mb-2">
                    <label class="small fw-bold">Nama Vendor:</label>
                    <input type="text" name="nama_vendor" class="form-control form-control-sm" placeholder="Contoh: Pak Haji" required list="vendorList">
                    <datalist id="vendorList">
                        </datalist>
                </div>
                <div class="mb-2">
                    <label class="small fw-bold">Qty Kirim:</label>
                    <input type="number" name="qty_kirim" id="modal_qty_input" class="form-control form-control-sm" min="1" required>
                    <div class="d-flex justify-content-between mt-1">
                        <small class="text-danger fw-bold" id="label_maks" style="font-size: 10px;">Maks: 0</small>
                        <small class="text-muted" style="font-size: 10px;">Saldo Gudang</small>
                    </div>
                </div>
            </div>
            <div class="modal-footer p-2">
                <button type="submit" class="btn btn-primary btn-sm w-100">SIMPAN & KIRIM</button>
            </div>
        </form>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
<script>
    const modalKirim = new bootstrap.Modal(document.getElementById('modalKirim'));

    function bukaModalKirim(id, sisa, harga) {
        document.getElementById('modal_detail_id').value = id;
        document.getElementById('modal_harga_cmt').value = harga;
        document.getElementById('modal_qty_input').max = sisa;
        document.getElementById('modal_qty_input').value = sisa;
        document.getElementById('label_maks').innerText = "Maksimal: " + sisa + " Pcs";
        modalKirim.show();
    }

    function konfirmasiTerima(id) {
        Swal.fire({
            title: 'Terima Barang?',
            text: "Barang akan masuk ke riwayat produksi pusat dan status menjadi HUTANG.",
            icon: 'question',
            showCancelButton: true,
            confirmButtonColor: '#198754',
            confirmButtonText: 'Ya, Terima!'
        }).then((result) => {
            if (result.isConfirmed) {
                window.location.href = '/admin/terima-barang/' + id;
            }
        });
    }

    function konfirmasiBayar(id) {
        Swal.fire({
            title: 'Tandai Lunas?',
            text: "Data akan terarsip jika semua stok sudah beres.",
            icon: 'warning',
            showCancelButton: true,
            confirmButtonColor: '#0d6efd',
            confirmButtonText: 'Ya, Sudah Lunas'
        }).then((result) => {
            if (result.isConfirmed) {
                window.location.href = '/admin/bayar-vendor/' + id;
            }
        });
    }
</script>

<%- include('../partials/footer') %>