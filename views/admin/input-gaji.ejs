<%- include('../partials/header') %>
<div class="container mt-4 mb-5">
    <div class="card shadow border-0">
        <div class="card-header bg-primary text-white d-flex justify-content-between align-items-center">
            <h4 class="mb-0"><i class="bi bi-calculator-fill"></i> Rincian Gaji Mingguan</h4>
            <span class="badge bg-light text-dark">Periode: <%= tgl_awal %> s/d <%= tgl_akhir %></span>
        </div>
        <div class="card-body">
            <div class="alert alert-info py-2 d-flex justify-content-between align-items-center" style="font-size: 0.85rem;">
                <div>
                    <i class="bi bi-info-circle-fill"></i> <b>Input Jam:</b> Gunakan titik (.). Contoh: <b>5.4</b> (5 hari 4 jam).
                </div>
                <div class="fw-bold border-start ps-3 border-info">
                    Kebijakan: 1 Hari = <%= config.jam_kerja_reguler || 8 %> Jam | Lembur = GP / <%= config.pembagi_lembur || 4 %>
                </div>
            </div>

            <form action="/proses-print-gaji" method="POST" target="_blank">
                <input type="hidden" name="tgl_awal" value="<%= tgl_awal %>">
                <input type="hidden" name="tgl_akhir" value="<%= tgl_akhir %>">

                <div class="table-responsive">
                    <table class="table table-bordered table-hover align-middle">
                        <thead class="table-dark text-center" style="font-size: 0.85rem;">
                            <tr>
                                <th>Nama Karyawan</th>
                                <th>GP / Hari</th>
                                <th style="width: 110px;">Hari.Jam</th>
                                <th style="width: 100px;">Lembur (Sesi)</th>
                                <th>Bonus Target</th>
                                <th style="width: 130px;">Kasbon</th>
                                <th class="bg-success">Total Terima</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% Object.values(rekap).forEach((op, index) => { %>
                            <tr class="baris-gaji">
                                <td>
                                    <strong><%= op.nama %></strong>
                                    <input type="hidden" name="operator_ids" value="<%= op.id %>">
                                    <input type="hidden" name="nama" value="<%= op.nama %>">
                                </td>
                                <td>
                                    <div class="input-group input-group-sm">
                                        <span class="input-group-text">Rp</span>
                                        <input type="number" name="gp" value="<%= op.gp %>" class="form-control input-gp bg-light" readonly>
                                    </div>
                                </td>
                                <td>
                                    <input type="number" step="0.1" name="hari_kerja" value="6.0" class="form-control form-control-sm text-center fw-bold input-hk">
                                </td>
                                <td>
                                    <input type="number" name="lembur" value="0" class="form-control form-control-sm text-center input-lembur">
                                </td>
                                <td>
                                    <div class="text-end px-2">
                                        <input type="hidden" name="bonus" class="input-bonus-target" value="<%= op.bonus %>">
                                        <span class="fw-bold text-primary">Rp <%= (op.bonus || 0).toLocaleString('id-ID') %></span>
                                    </div>
                                </td>
                                <td>
                                    <div class="input-group input-group-sm">
                                        <span class="input-group-text">+/-</span>
                                        <input type="number" name="adj_manual" value="0" class="form-control fw-bold input-adj">
                                    </div>
                                </td>
                                    <div class="input-group input-group-sm">
                                        <span class="input-group-text text-danger">-</span>
                                        <input type="number" name="kasbon" value="0" class="form-control text-danger fw-bold input-kasbon">
                                    </div>
                                </td>
                                <td>
                                    <td class="text-end fw-bold text-success bg-light" style="font-size: 1.1rem;">
                                    <span class="total-tampil">Rp 0</span>
                                </td>
                            </tr>
                            <% }) %>
                        </tbody>
                    </table>
                </div>

                <div class="mt-4 d-flex justify-content-between">
                    <a href="/input-gaji" class="btn btn-secondary">
                        <i class="bi bi-arrow-left"></i> Ganti Tanggal
                    </a>
                    <button type="submit" class="btn btn-success btn-lg px-5 shadow">
                        <i class="bi bi-printer"></i> PROSES & CETAK SLIP
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

<script>
document.addEventListener('DOMContentLoaded', function() {
    const semuaBaris = document.querySelectorAll('.baris-gaji');

    // --- VARIABEL DARI SETUP DATABASE (Penyebab Error Sebelumnya) ---
    // Pastikan nilai default ada agar JS tidak kosong saat pertama kali load
    const JAM_REGULER = Number("<%= config.jam_kerja_reguler %>") || 8;
    const PEMBAGI_LEMBUR = Number("<%= config.pembagi_lembur %>") || 4;

    function formatRupiah(angka) {
        return 'Rp ' + Math.round(angka).toLocaleString('id-ID');
    }

    function hitungBaris(row) {
        const gp = parseFloat(row.querySelector('.input-gp').value) || 0;
        const hkValue = row.querySelector('.input-hk').value.toString();
        const hkRaw = hkValue.replace(',', '.');
        const lembur = parseFloat(row.querySelector('.input-lembur').value) || 0;
        const bonusTarget = parseFloat(row.querySelector('.input-bonus-target').value) || 0;
        const kasbon = parseFloat(row.querySelector('.input-kasbon').value) || 0;

        let hariFull = 0;
        let jamSisa = 0;

        if (hkRaw.includes('.')) {
            const parts = hkRaw.split('.');
            hariFull = parseInt(parts[0]) || 0;
            jamSisa = parseInt(parts[1]) || 0;
        } else {
            hariFull = parseInt(hkRaw) || 0;
        }

        // Kalkulasi Fleksibel sesuai Setup
        const nominalHK = (hariFull * gp) + ((gp / JAM_REGULER) * jamSisa);
        const nominalLembur = (gp / PEMBAGI_LEMBUR) * lembur; 
        
        const total = nominalHK + nominalLembur + bonusTarget - kasbon;

        // Update UI
        row.querySelector('.total-tampil').innerText = formatRupiah(total);
    }

    // Inisialisasi hitungan
    semuaBaris.forEach(row => {
        hitungBaris(row);
        row.querySelectorAll('input').forEach(input => {
            input.addEventListener('input', () => hitungBaris(row));
        });
    });
});
</script>

<%- include('../partials/footer') %>