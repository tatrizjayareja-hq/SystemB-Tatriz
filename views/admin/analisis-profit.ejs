<%- include('../partials/header') %>
<div class="container mt-3" style="max-width: 900px;">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h5 class="fw-bold mb-0">💰 Analisis Jatah Profit</h5>
        <a href="/laporan-kas" class="btn btn-outline-secondary btn-sm">Kembali</a>
    </div>

    <div class="card shadow-sm border-0 mb-3 bg-primary text-white">
        <div class="card-body p-4">
            <div class="row align-items-center">
                <div class="col-12 text-center">
                    <small class="opacity-75 text-uppercase fw-bold" style="font-size: 10px;">Sisa Jatah Profit (Siap Tarik)</small>
                    <h2 class="fw-bold mb-2">Rp <%= sisaJatah.toLocaleString('id-ID') %></h2>
                    <div class="badge bg-white text-primary px-3">Akumulasi Seluruh Bulan</div>
                </div>
            </div>
            <hr class="opacity-25">
            <div class="row text-center">
                <div class="col-6 border-end">
                    <small class="d-block opacity-75" style="font-size: 10px;">Total Profit Nett</small>
                    <span class="fw-bold text-warning">Rp <%= totalProfitKumulatif.toLocaleString('id-ID') %></span>
                </div>
                <div class="col-6">
                    <small class="d-block opacity-75" style="font-size: 10px;">Total Sudah Diambil</small>
                    <span class="fw-bold text-light">Rp <%= totalSudahDiambil.toLocaleString('id-ID') %></span>
                </div>
            </div>
        </div>
    </div>

    <div class="card shadow-sm mb-3">
        <div class="card-header bg-white py-3 fw-bold">
            <i class="bi bi-calendar-check text-primary me-2"></i> Rincian Profit Bulanan
        </div>
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0" style="font-size: 12px;">
                <thead class="table-light">
                    <tr>
                        <th>BULAN</th>
                        <th class="text-end">PRODUKSI</th>
                        <th class="text-end">OP+BEBAN</th>
                        <th class="text-end text-success">PROFIT NETT</th>
                    </tr>
                </thead>
                <tbody>
                    <% listProfit.forEach(p => { %>
                    <tr>
                        <td class="fw-bold text-uppercase"><%= p.bulan %></td>
                        
                        <td class="text-end">Rp <%= (p.produksi || 0).toLocaleString('id-ID') %></td>
                        
                        <td class="text-end text-muted">
                            Rp <%= ((Number(p.operasional) || 0) + (Number(p.bebanTetap) || 0)).toLocaleString('id-ID') %>
                        </td>
                        
                        <td class="text-end fw-bold text-success">
                            Rp <%= (p.profitNett || 0).toLocaleString('id-ID') %>
                        </td>
                    </tr>
                    <% }) %>
                </tbody>
            </table>
        </div>
    </div>

    <div class="card shadow-sm border-danger mb-3">
        <div class="card-header bg-danger text-white py-3 fw-bold">
            <i class="bi bi-cash-stack me-2"></i> Riwayat Penarikan Jatah Owner
        </div>
        <div class="table-responsive" style="max-height: 300px;">
            <table class="table table-sm table-hover mb-0" style="font-size: 11px;">
                <thead class="table-light sticky-top">
                    <tr>
                        <th style="width: 100px;">TANGGAL</th>
                        <th>KETERANGAN</th>
                        <th class="text-end">JUMLAH</th>
                    </tr>
                </thead>
                <tbody>
                    <% if(listPenarikan.length > 0) { %>
                        <% listPenarikan.forEach(lp => { %>
                        <tr>
                            <td class="text-nowrap"><%= new Date(lp.tanggal).toLocaleDateString('id-ID', {day:'2-digit', month:'2-digit', year:'numeric'}) %></td>
                            <td><%= lp.keterangan %></td>
                            <td class="text-end fw-bold text-danger">- Rp <%= Number(lp.jumlah || 0).toLocaleString('id-ID') %></td>
                        </tr>
                        <% }) %>
                    <% } else { %>
                        <tr>
                            <td colspan="3" class="text-center py-3 text-muted">Belum ada riwayat penarikan.</td>
                        </tr>
                    <% } %>
                </tbody>
            </table>
        </div>
    </div>

    <div class="alert alert-secondary p-2" style="font-size: 10px;">
        <strong>Catatan Perhitungan:</strong><br>
        1. <strong>Profit Nett</strong> = (Hasil Kerja Mesin) - (Biaya Operasional) - (Beban Tetap: Rp <%= (Number(config.beban_tetap) || 0).toLocaleString('id-ID') %>).<br>
        2. Biaya Operasional tidak termasuk Biaya Kontrakan, Bayar Hutang, dan Jatah Owner yang sudah diambil.
    </div>
</div>
<%- include('../partials/footer') %>