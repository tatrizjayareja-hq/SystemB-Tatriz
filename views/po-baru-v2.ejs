<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Input PO Baru - Tatriz System</title>
    <style>
        body { font-family: 'Segoe UI', sans-serif; background: #f4f7f6; padding: 20px; }
        .form-container { max-width: 900px; margin: auto; background: white; padding: 25px; border-radius: 12px; box-shadow: 0 4px 10px rgba(0,0,0,0.1); }
        .grid-header { display: grid; grid-template-columns: 1fr 1fr; gap: 15px; margin-bottom: 20px; }
        .sub-po-row { border: 1px solid #ddd; padding: 15px; border-radius: 8px; margin-bottom: 10px; background: #fafafa; position: relative; }
        
        .grid-sub { display: grid; gap: 10px; }
        /* Grid Pro: Jenis, Desain, Qty, Harga CMT, Harga Cust */
        .grid-pro { grid-template-columns: 2fr 2fr 1fr 1.5fr 1.5fr; }
        /* Grid Standard: Jenis, Desain, Qty, Harga Cust */
        .grid-standard { grid-template-columns: 2fr 2fr 1fr 2fr; }

        label { font-weight: bold; display: block; margin-bottom: 5px; font-size: 11px; color: #666; text-transform: uppercase; }
        input, select { width: 100%; padding: 10px; border: 1px solid #ccc; border-radius: 6px; box-sizing: border-box; font-size: 14px; }
        
        .btn-add { background: #3498db; color: white; border: none; padding: 10px 20px; border-radius: 6px; cursor: pointer; margin-bottom: 20px; font-weight: bold; }
        .btn-save { background: #195e0b; color: white; border: none; padding: 15px; width: 100%; border-radius: 8px; font-size: 18px; font-weight: bold; cursor: pointer; transition: 0.3s; }
        
        .remove-row { color: #e74c3c; cursor: pointer; font-size: 12px; font-weight: bold; position: absolute; top: 10px; right: 15px; }

        @media (max-width: 600px) {
            .grid-header { grid-template-columns: 1fr; }
            .grid-pro, .grid-standard { grid-template-columns: 1fr; gap: 8px; }
            .sub-po-row { padding-top: 35px; }
        }
    </style>
</head>
<% 
    // Akses internal untuk ID 1 dan 100
    const isInternal = access.isInternal; 
%>
<body data-isinternal="<%= isInternal %>">

<div class="form-container">
    <a href="/dashboard" style="text-decoration: none; color: #666; font-size: 14px;">← Kembali</a>
    <h2 style="color: #195e0b;">📝 Input Pesanan Baru (PO)</h2>
    
    <form action="/-v2" method="POST">
        <div class="grid-header">
            <div>
                <label>Tanggal</label>
                <input type="date" name="tanggal" required id="tgl_sekarang">
            </div>
            <div>
                <label>Status</label>
                <select name="status">
                    <option value="Design">Design</option>
                    <option value="Produksi">Produksi</option>
                    <option value="CMT">CMT (Luar)</option>
                    <option value="QC">QC</option>
                    <option value="Clear">Clear (Invoice)</option>
                    <option value="Lunas">Lunas</option>
                </select>
            </div>
            <div>
                <label>Nama PO</label>
                <input type="text" name="nama_po" required list="list_po">
            </div>
            <div>
                <label>Customer</label>
                <input type="text" name="customer" required list="list_customer">
            </div>
        </div>

        <hr style="border: 0; border-top: 1px solid #eee; margin: 20px 0;">
        
        <div id="sub-po-container">
            <div class="sub-po-row">
                <div class="grid-sub <%= isInternal ? 'grid-pro' : 'grid-standard' %>">
                    <div>
                        <label>Jenis</label>
                        <input type="text" name="jenis_bordir[]" list="list_jenis">
                    </div>
                    <div>
                        <label>Desain</label>
                        <input type="text" name="nama_desain[]">
                    </div>
                    <div>
                        <label>Qty</label>
                        <input type="number" name="jumlah[]" required>
                    </div>

                    <% if (isInternal) { %>
                        <div>
                            <label>Harga CMT (Makloon)</label>
                            <input type="number" name="harga_cmt[]" placeholder="Biaya luar" oninput="copyKeOperator(this)">
                        </div>
                    <% } else { %>
                        <input type="hidden" name="harga_cmt[]" class="hidden-cmt">
                    <% } %>

                    <div>
                        <label>Harga Customer</label>
                        <input type="number" name="harga_customer[]" required oninput="logikaTenantUmum(this)">
                    </div>

                    <input type="hidden" name="harga_operator[]" class="hidden-op">
                </div>
            </div>
        </div>

        <button type="button" class="btn-add" onclick="tambahBaris()">+ Tambah Baris</button>
        <button type="submit" class="btn-save">SIMPAN DATA PO</button>
    </form>
</div>

<datalist id="list_po"></datalist>
<datalist id="list_customer"></datalist>
<datalist id="list_jenis"></datalist>

<script>
    // Set tanggal hari ini otomatis
    document.getElementById('tgl_sekarang').valueAsDate = new Date();

    /**
     * Logika untuk Internal (ID 1 & 100):
     * Harga Operator otomatis menyalin nilai dari Harga CMT
     */
    function copyKeOperator(el) {
    const row = el.closest('.grid-sub');
    const hiddenOp = row.querySelector('.hidden-op');
    const hiddenCmt = row.querySelector('.hidden-cmt'); // Tambahkan ini jika ada
    
        if (hiddenOp) {
            hiddenOp.value = el.value; 
        }
        // Jika ada elemen hidden-cmt di baris yang sama, isi juga
        if (hiddenCmt) {
            hiddenCmt.value = el.value;
        }
    }

    /**
     * Logika untuk Tenant Umum:
     * Harga CMT dan Harga Operator otomatis menyalin nilai dari Harga Customer
     */
    function logikaTenantUmum(el) {
        const isInternal = document.body.dataset.isinternal === 'true';
        if (!isInternal) {
            const row = el.closest('.grid-sub');
            const hiddenCmt = row.querySelector('.hidden-cmt');
            const hiddenOp = row.querySelector('.hidden-op');
            if (hiddenCmt) hiddenCmt.value = el.value;
            if (hiddenOp) hiddenOp.value = el.value;
        }
    }

    /**
     * Fungsi menambah baris rincian baru
     */
    function tambahBaris() {
        const container = document.getElementById('sub-po-container');
        const isInternal = document.body.dataset.isinternal === 'true';
        
        const row = document.createElement('div');
        row.className = 'sub-po-row';
        
        const gridClass = isInternal ? 'grid-pro' : 'grid-standard';
        
        // Template kolom CMT berdasarkan akses
        const kolomCmt = isInternal ? 
            `<div><label>Harga CMT (Makloon)</label><input type="number" name="harga_cmt[]" placeholder="Biaya luar" oninput="copyKeOperator(this)"></div>` : 
            `<input type="hidden" name="harga_cmt[]" class="hidden-cmt">`;

        row.innerHTML = `
            <span class="remove-row" onclick="this.parentElement.remove()">✖ Hapus</span>
            <div class="grid-sub ${gridClass}">
                <div><label>Jenis</label><input type="text" name="jenis_bordir[]" list="list_jenis"></div>
                <div><label>Desain</label><input type="text" name="nama_desain[]"></div>
                <div><label>Qty</label><input type="number" name="jumlah[]" required></div>
                ${kolomCmt}
                <div><label>Harga Customer</label><input type="number" name="harga_customer[]" required oninput="logikaTenantUmum(this)"></div>
                <input type="hidden" name="harga_operator[]" class="hidden-op">
            </div>
        `;
        container.appendChild(row);
    }
</script>

</body>
</html>