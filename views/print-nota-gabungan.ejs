<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <title>Nota Transaksi - <%= orders[0].customer %></title>
    <style>
       /* Standar untuk Kertas A5 Portrait */
        @media print {
            @page { 
                size: 148mm 210mm; 
                margin: 5mm; 
            }
            body { 
                padding: 0 !important; 
                margin: 0 !important; 
                background: white !important; 
                -webkit-print-color-adjust: exact; 
                print-color-adjust: exact; 
            }
            .nota-box { 
                border: none !important; 
                margin: 0 !important; 
                width: 100% !important; 
                /* Hapus max-height agar bisa memanjang ke halaman 2 jika perlu */
                min-height: 100vh !important; 
                padding: 2mm !important; 
                box-shadow: none !important;
            }
            .no-print { display: none; }
        }
        
        body { font-family: 'Segoe UI', Helvetica, sans-serif; margin: 0; padding: 20px; background-color: #f4f7f6; color: #333; }
        
        .nota-box {
            width: 148mm; 
            min-height: 210mm; /* Kembali pakai min-height, bukan height mati */
            position: relative; padding: 8mm;
            box-sizing: border-box; display: flex; flex-direction: column;
            border: 1px solid #ddd; margin: auto; background: #fff; box-shadow: 0 4px 10px rgba(0,0,0,0.1);
        }

        /* HEADER */
        .header-container { display: flex; align-items: center; border-bottom: 2px solid #2c3e50; padding-bottom: 5px; margin-bottom: 8px; }
        .logo-header { width: 45px; height: 45px; object-fit: contain; margin-right: 10px; }
        .company-info { flex-grow: 1; }
        .company-info h2 { margin: 0; font-size: 13px; color: #2c3e50; text-transform: uppercase; font-weight: 800; }
        .company-info p { margin: 1px 0; font-size: 9px; line-height: 1.2; color: #555; }
        
        .label-nota { text-align: right; }
        .label-nota h3 { margin: 0; color: #e67e22; font-size: 15px; letter-spacing: 1px; text-transform: uppercase; }
        .label-nota p { margin: 1px 0; font-size: 9px; }

        /* AREA KONTEN (Hapus overflow hidden agar isi tidak terpotong) */
        .content-area { position: relative; z-index: 1; flex-grow: 1; }
        
        /* TABEL */
        table { width: 100%; border-collapse: collapse; margin-top: 2px; font-size: 9.5px; line-height: 1.2; }
        th { background: #2c3e50; color: white; border: 1px solid #2c3e50; padding: 4px; text-align: left; font-weight: 600; }
        td { padding: 3px 4px; vertical-align: middle; border-bottom: 1px dashed #ddd; }
        
        /* Cegah baris terpotong di antara halaman 1 dan 2 */
        tr { page-break-inside: avoid; } 
        
        .master-row td { background: #f8f9fa; font-weight: bold; border-top: 1px solid #ccc; border-bottom: 1px solid #ccc; font-size: 10.5px; padding: 4px; }
        .detail-row td { color: #444; }
        .subtotal-po td { font-style: italic; background: #fff; border-bottom: 1px solid #eee; padding: 2px 4px; }

        /* FOOTER & TTD */
        .footer-nota { margin-top: auto; padding-top: 5px; page-break-inside: avoid; } /* Cegah total pisah dengan tabel jika mepet */
        .total-box { width: 100%; border-top: 2px solid #2c3e50; padding-top: 5px; margin-bottom: 10px; }
        .total-row { display: flex; justify-content: flex-end; margin-bottom: 2px; font-size: 11px; }
        .total-row span:first-child { width: 150px; text-align: right; margin-right: 15px; color: #555; }
        .total-row span:last-child { width: 100px; text-align: right; font-weight: bold; }
        
        .sisa-row { font-size: 13px; font-weight: 800; color: #d63031; border-top: 1px solid #ccc; padding-top: 3px; margin-top: 3px; }
        .lunas-row { font-size: 13px; font-weight: 800; color: #27ae60; border-top: 1px solid #ccc; padding-top: 3px; margin-top: 3px; }

        .ttd-section { display: flex; justify-content: space-between; margin-top: 5px; font-size: 9px; text-align: center; }
        .ttd-box { width: 40%; }
        .ttd-space { height: 40px; }
        
        .watermark { position: absolute; top: 30%; left: 50%; transform: translate(-50%, -50%) rotate(-30deg); opacity: 0.04; width: 280px; z-index: 0; pointer-events: none; }
        .text-end { text-align: right !important; }
        .text-center { text-align: center !important; }
    </style>

    <% if (mode === 'thermal') { %>
        <link rel="stylesheet" href="/css/thermal-style.css">
    <% } %>
</head>

<body>
    <div class="nota-box">
        <img src="<%= config.logo_path %>" class="watermark">
        
        <div class="header-container">
            <img src="<%= config.logo_path %>" class="logo-header">
            <div class="company-info">
                <h2><%= config.nama_perusahaan %></h2>
                <p><%= config.alamat ? config.alamat.replace(/\n/g, ' ') : '' %></p>
                <p><strong>WA: <%= config.no_hp %></strong></p>
            </div>
            <div class="label-nota">
                <h3><%= mode === 'thermal' ? 'STRUK TAGIHAN' : 'NOTA TRANSAKSI' %></h3>
                <p>Tgl: <strong><%= new Date().toLocaleDateString('id-ID', { day:'2-digit', month:'short', year:'numeric' }) %></strong></p>
                <p>Cust: <strong style="font-size: 13px; color: #2c3e50;"><%= orders[0].customer %></strong></p>
            </div>
        </div>

        <div class="content-area">
            <table>
                <thead>
                    <tr>
                        <th class="text-center" style="width: 5%;">No</th>
                        <th style="width: 45%;">Deskripsi & Rincian Pesanan</th>
                        <th class="text-center" style="width: 10%;">Qty</th>
                        <th class="text-end" style="width: 20%;">Harga/Titik</th>
                        <th class="text-end" style="width: 20%;">Total</th>
                    </tr>
                </thead>
                <tbody>
                    <%
                        let grandTotalTagihan = 0;
                        let grandTotalBayar = 0;

                        orders.forEach((po, index) => {
                            let totalHargaPO = (po.total_harga_customer || 0);
                            let totalBayarPO = (po.total_bayar || 0);
                            
                            grandTotalTagihan += totalHargaPO;
                            grandTotalBayar += totalBayarPO;

                            let poDetails = details.filter(d => Number(d.po_id) === Number(po.id));
                            
                            // Hitung Harga 1 Set Baju (Menjumlahkan harga satuan dari tiap titik bordir)
                            let hargaPerSet = poDetails.reduce((sum, d) => sum + (d.harga_customer || 0), 0);
                    %>
                    
                    <tr class="master-row">
                        <td class="text-center"><%= index + 1 %></td>
                        <td colspan="2" style="color: #2c3e50;">PO: <%= po.nama_po %></td>
                        <td colspan="2" class="text-end" style="color: #e67e22; font-size: 10px;">
                            Harga 1 Set = <strong><%= hargaPerSet.toLocaleString('id-ID') %></strong>
                        </td>
                    </tr>

                    <% poDetails.forEach(d => { 
                        let subtotalDetail = (d.jumlah || 0) * (d.harga_customer || 0);
                    %>
                    <tr class="detail-row">
                        <td></td>
                        <td>↳ <%= d.jenis_bordir %></td>
                        <td class="text-center"><%= d.jumlah %> <small>pcs</small></td>
                        <td class="text-end"><%= (d.harga_customer || 0).toLocaleString('id-ID') %></td>
                        <td class="text-end"><%= subtotalDetail.toLocaleString('id-ID') %></td>
                    </tr>
                    <% }) %>

                    <tr class="subtotal-po">
                        <td colspan="3"></td>
                        <td class="text-end">Subtotal PO:</td>
                        <td class="text-end" style="font-weight: bold; color: #2c3e50;">
                            <%= totalHargaPO.toLocaleString('id-ID') %>
                        </td>
                    </tr>

                    <% }) %>
                </tbody>
            </table>
        </div>

        <div class="footer-nota">
            <div class="total-box">
                <div class="total-row">
                    <span>Total Keseluruhan:</span>
                    <span>Rp <%= grandTotalTagihan.toLocaleString('id-ID') %></span>
                </div>
                <div class="total-row" style="color: #27ae60;">
                    <span>Telah Dibayar (DP):</span>
                    <span>Rp <%= grandTotalBayar.toLocaleString('id-ID') %></span>
                </div>
                
                <% let sisa = grandTotalTagihan - grandTotalBayar; %>
                <% if (sisa <= 0) { %>
                    <div class="total-row lunas-row">
                        <span>STATUS:</span>
                        <span>✅ LUNAS</span>
                    </div>
                <% } else { %>
                    <div class="total-row sisa-row">
                        <span>SISA TAGIHAN:</span>
                        <span>Rp <%= sisa.toLocaleString('id-ID') %></span>
                    </div>
                <% } %>
            </div>

            <div class="ttd-section">
                <div class="ttd-box">
                    Penerima / Customer,
                    <div class="ttd-space"></div>
                    ( ............................ )
                </div>
                <div class="ttd-box">
                    Hormat Kami,
                    <div class="ttd-space"></div>
                    <strong><%= config.nama_perusahaan %></strong>
                </div>
            </div>
        </div>
    </div>

    <script>
        window.onload = function() {
            // Otomatis Print Dialog saat halaman selesai dimuat
            setTimeout(() => { window.print(); }, 800);
        };
    </script>
</body>
</html>