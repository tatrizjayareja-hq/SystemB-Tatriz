<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <title>Nota Transaksi</title>
    
    <style>
        body { 
            font-family: 'Segoe UI', Helvetica, sans-serif; 
            margin: 0; 
            background-color: #f4f7f6; 
            color: #333; 
        }
        .nota-box {
            position: relative; 
            box-sizing: border-box; 
            display: flex; 
            flex-direction: column;
            border: 1px solid #ddd; 
            margin: auto; 
            background: #fff; 
            box-shadow: 0 4px 10px rgba(0,0,0,0.1);
        }
        .content-area { position: relative; z-index: 1; flex-grow: 1; }
        .footer-nota { margin-top: auto; padding-top: 10px; page-break-inside: avoid; } 
        .header-container { display: flex; align-items: center; border-bottom: 2px solid #2c3e50; padding-bottom: 5px; margin-bottom: 8px; }
        .logo-header { width: 45px; height: 45px; object-fit: contain; margin-right: 10px; }
        .company-info { flex-grow: 1; }
        .company-info h2 { margin: 0; font-size: 13px; color: #2c3e50; text-transform: uppercase; font-weight: 800; }
        .company-info p { margin: 1px 0; font-size: 9px; line-height: 1.2; color: #555; }
        .label-nota { text-align: right; }
        .label-nota h3 { margin: 0; color: #e67e22; font-size: 15px; letter-spacing: 1px; text-transform: uppercase; }
        .label-nota p { margin: 1px 0; font-size: 9px; }
        table { width: 100%; border-collapse: collapse; margin-top: 2px; line-height: 1.3; }
        th { background: #2c3e50; color: white; border: 1px solid #2c3e50; padding: 5px 4px; text-align: left; font-weight: 600; }
        td { padding: 5px 3px; vertical-align: top; border-bottom: 1px dashed #ddd; word-wrap: break-word; }
        tr { page-break-inside: avoid; } 
        .master-row td { background: #f8f9fa; font-weight: bold; border-top: 1px solid #ccc; border-bottom: 1px solid #ccc; }
        .detail-row td { color: #444; padding: 3px 3px; }
        .subtotal-po td { font-style: italic; background: #fff; border-bottom: 1px solid #eee; padding: 4px 3px; }
        .total-box { width: 100%; border-top: 2px solid #2c3e50; padding-top: 5px; margin-bottom: 10px; }
        .total-row { display: flex; justify-content: flex-end; margin-bottom: 2px; }
        .total-row span:first-child { width: 150px; text-align: right; margin-right: 15px; color: #555; }
        .total-row span:last-child { width: 100px; text-align: right; font-weight: bold; padding-right: 2px; }
        .sisa-row { font-weight: 800; color: #d63031; border-top: 1px solid #ccc; padding-top: 3px; margin-top: 3px; }
        .lunas-row { font-weight: 800; color: #27ae60; border-top: 1px solid #ccc; padding-top: 3px; margin-top: 3px; }
        .ttd-section { display: flex; justify-content: space-between; margin-top: 5px; text-align: center; }
        .ttd-box { width: 40%; }
        .ttd-space { height: 40px; }
        .watermark { position: absolute; top: 40%; left: 50%; transform: translate(-50%, -50%) rotate(-30deg); opacity: 0.04; width: 250px; z-index: 0; pointer-events: none; }
        .text-end { text-align: right !important; }
        .text-center { text-align: center !important; }
    </style>

    <% if (mode === 'simple') { %>
        <style>
            /* MODE SIMPLE - KERTAS A6 PORTRAIT */
            @media print {
                @page { size: 105mm 148mm; margin: 0; }
                body { padding: 0 !important; -webkit-print-color-adjust: exact; print-color-adjust: exact; }
                .nota-box { width: 105mm; min-height: 98vh; padding: 5mm; border: none !important; box-shadow: none !important; }
                * { font-size: 10px !important; }
                .company-info h2 { font-size: 11px !important; }
                .total-row { font-size: 11px !important; }
                .sisa-row, .lunas-row { font-size: 12px !important; }
                .ttd-section { font-size: 9px !important; }
            }
            @media screen { .nota-box { max-width: 105mm; min-height: 148mm; padding: 5mm; } * { font-size: 10px; } }
            table { table-layout: auto; }
        </style>
    <% } else { %>
        <style>
            /* MODE RINCI - KERTAS A5 LANDSCAPE */
            @media print {
                @page { size: A5 landscape; margin: 0.5cm; }
                body { padding: 0 !important; -webkit-print-color-adjust: exact; print-color-adjust: exact; }
                .nota-box { width: 100%; min-height: 98vh; padding: 8mm; border: none !important; box-shadow: none !important; }
                * { font-size: 11px !important; }
                .company-info h2 { font-size: 14px !important; }
                .total-row { font-size: 12px !important; }
                .sisa-row, .lunas-row { font-size: 14px !important; }
                .ttd-section { font-size: 10px !important; }
            }
            @media screen { .nota-box { max-width: 210mm; min-height: 148mm; padding: 8mm; } * { font-size: 11px; } }
            table { table-layout: fixed; }
        </style>
    <% } %>
</head>

<body>
    <div id="loaderSistem" style="
    position: fixed;
    top: 0; left: 0;
    width: 100%; height: 100%;
    background: #195e0b; /* Warna hijau gelap khas Tatriz */
    z-index: 99999; /* Dipastikan paling atas menutupi semua menu */
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    transition: opacity 0.3s ease, visibility 0.3s ease;
">
    <div class="spinner-tatriz"></div>
    <p style="color: white; margin-top: 18px; font-weight: bold; font-size: 14px; letter-spacing: 1px; font-family: sans-serif; text-align: center;">
        MEMUAT SISTEM TATRIZ...
    </p>
</div>

<style>
    .spinner-tatriz {
        width: 50px; height: 50px;
        border: 5px solid rgba(255,255,255,0.2);
        border-top: 5px solid #59cf77; /* Warna hijau muda aksen */
        border-radius: 50%;
        animation: putarLoaderTatriz 1s linear infinite;
    }
    @keyframes putarLoaderTatriz {
        0% { transform: rotate(0deg); }
        100% { transform: rotate(360deg); }
    }
    /* Kelas untuk menghilangkan loader dengan halus */
    .loader-hilang {
        opacity: 0 !important;
        visibility: hidden !important;
    }
</style>
    <div class="nota-box">
        <img src="<%= config.logo_path %>" class="watermark">
        
        <div class="header-container">
            <img src="<%= config.logo_path %>" class="logo-header">
            <div class="company-info">
                <h2><%= config.nama_perusahaan %></h2>
                <p><%= config.alamat ? config.alamat.replace(/\n/g, ' ') : '' %></p>
                <p><strong>WA: <%= config.no_hp %></strong></p>
            </div>
            <div class="label-nota">
                <h3>NOTA RESMI</h3>
                <p>Tgl: <strong><%= new Date().toLocaleDateString('id-ID', { day:'2-digit', month:'short', year:'numeric' }) %></strong></p>
                <p>Cust: <strong style="font-size: 12px; color: #2c3e50;"><%= orders[0].customer %></strong></p>
            </div>
        </div>

        <div class="content-area">
            <table>
                <thead>
                    <tr>
                        <% if (mode === 'simple') { %>
                            <th class="text-center" style="width: 8%;">No</th>
                            <th style="width: 45%;">Deskripsi Pesanan</th>
                            <th class="text-center" style="width: 15%;">Qty</th>
                            <th class="text-end" style="width: 15%;">Harga</th>
                            <th class="text-end" style="width: 17%;">Total</th>
                        <% } else { %>
                            <th class="text-center" style="width: 5%;">No</th>
                            <th style="width: 45%;">Deskripsi & Rincian Pesanan</th>
                            <th class="text-center" style="width: 10%;">Qty</th>
                            <th class="text-end" style="width: 20%;">Harga/Titik</th>
                            <th class="text-end" style="width: 20%;">Total</th>
                        <% } %>
                    </tr>
                </thead>
                <tbody>
                    <%
                        let grandTotalTagihan = 0;
                        let grandTotalBayar = 0;

                        orders.forEach((po, index) => {
                            let totalHargaPO = (po.total_harga_customer || 0);
                            let totalBayarPO = (po.total_bayar || 0);
                            
                            grandTotalTagihan += totalHargaPO;
                            grandTotalBayar += totalBayarPO;

                            let poDetails = details.filter(d => Number(d.po_id) === Number(po.id));
                    %>

                    <% if (mode === 'simple') { 
                        // Logika Qty Konsisten (Anti-Error)
                        let qtys = poDetails.map(d => Number(d.jumlah));
                        let maxQty = qtys.length > 0 ? Math.max(...qtys) : 0;
                        let isKonsisten = qtys.every(q => q === maxQty);

                        let teksQty = isKonsisten ? `${maxQty} pcs` : `${maxQty} pcs*`;
                        let teksHargaSatuan = (isKonsisten && maxQty > 0) 
                            ? Math.round(totalHargaPO / maxQty).toLocaleString('id-ID') 
                            : "-";
                    %>
                        <tr>
                            <td class="text-center"><%= index + 1 %></td>
                            <td style="font-weight: bold; color: #2c3e50;"><%= po.nama_po %>
                                <% if (!isKonsisten) { %><br><small style="font-weight:normal; color:#888;">*Qty bordir variatif</small><% } %>
                            </td>
                            <td class="text-center"><%= teksQty %></td>
                            <td class="text-end"><%= teksHargaSatuan %></td>
                            <td class="text-end" style="font-weight: bold;"><%= totalHargaPO.toLocaleString('id-ID') %></td>
                        </tr>

                    <% } else { 
                        let hargaPerSet = poDetails.reduce((sum, d) => sum + (d.harga_customer || 0), 0);
                    %>
                        <tr class="master-row">
                            <td class="text-center"><%= index + 1 %></td>
                            <td colspan="2" style="color: #2c3e50;">PO: <%= po.nama_po %></td>
                            <td colspan="2" class="text-end" style="color: #e67e22; font-size: 10px;">
                                Harga 1 Set = <strong><%= hargaPerSet.toLocaleString('id-ID') %></strong>
                            </td>
                        </tr>

                        <% poDetails.forEach(d => { 
                            let subtotalDetail = (d.jumlah || 0) * (d.harga_customer || 0);
                        %>
                        <tr class="detail-row">
                            <td></td>
                            <td>↳ <%= d.jenis_bordir %></td>
                            <td class="text-center"><%= d.jumlah %> <small>pcs</small></td>
                            <td class="text-end"><%= (d.harga_customer || 0).toLocaleString('id-ID') %></td>
                            <td class="text-end"><%= subtotalDetail.toLocaleString('id-ID') %></td>
                        </tr>
                        <% }) %>

                        <tr class="subtotal-po">
                            <td colspan="3"></td>
                            <td class="text-end">Subtotal PO:</td>
                            <td class="text-end" style="font-weight: bold; color: #2c3e50;"><%= totalHargaPO.toLocaleString('id-ID') %></td>
                        </tr>
                    <% } %>

                    <% }) %>
                </tbody>
            </table>
        </div>

        <div class="footer-nota">
            <div class="total-box">
                <div class="total-row">
                    <span>Total Keseluruhan:</span>
                    <span>Rp <%= grandTotalTagihan.toLocaleString('id-ID') %></span>
                </div>
                <div class="total-row" style="color: #27ae60;">
                    <span>Telah Dibayar (DP):</span>
                    <span>Rp <%= grandTotalBayar.toLocaleString('id-ID') %></span>
                </div>
                
                <% let sisa = grandTotalTagihan - grandTotalBayar; %>
                <% if (sisa <= 0) { %>
                    <div class="total-row lunas-row">
                        <span>STATUS:</span>
                        <span>✅ LUNAS</span>
                    </div>
                <% } else { %>
                    <div class="total-row sisa-row">
                        <span>SISA TAGIHAN:</span>
                        <span>Rp <%= sisa.toLocaleString('id-ID') %></span>
                    </div>
                <% } %>
            </div>

            <div class="ttd-section">
                <div class="ttd-box">
                    Penerima / Customer,<br>
                    <div class="ttd-space"></div>
                    ( ............................ )
                </div>
                <div class="ttd-box">
                    Hormat Kami,<br>
                    <div class="ttd-space"></div>
                    <strong><%= config.nama_perusahaan %></strong>
                </div>
            </div>
        </div>
    </div>

    <script>
        window.onload = function() {
            // Bersihkan nama customer dari karakter aneh dan ganti spasi dengan strip (-)
            const namaCust = "<%= orders[0].customer %>".replace(/[^a-zA-Z0-9 ]/g, "").replace(/\s+/g, '-');
            
            // Format tanggal (contoh: 09-06-2026)
            const tgl = new Date().toLocaleDateString('id-ID').replace(/\//g, '-');
            
            // Set judul dokumen (akan menjadi default nama file saat di-save ke PDF)
            document.title = "Nota-" + namaCust + "-" + tgl;
            
            // Otomatis Print Dialog
            setTimeout(() => { window.print(); }, 800);
        };
    </script>
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            const loader = document.getElementById('loaderSistem');
            if (loader) {
                setTimeout(function() {
                    loader.classList.add('loader-hilang');
                }, 200);
            }
        });
        setTimeout(function() {
            const loader = document.getElementById('loaderSistem');
            if (loader && !loader.classList.contains('loader-hilang')) {
                loader.classList.add('loader-hilang');
            }
        }, 4000);
    </script>
</body>
</html>