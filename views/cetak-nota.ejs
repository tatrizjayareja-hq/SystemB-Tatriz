<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <title>Nota - <%= po.nama_po %></title>
    <style>
        /* CSS UTAMA */
        @media print { 
            @page { 
                size: 105mm 148mm; 
                margin: 0; 
            } 
            body { 
                -webkit-print-color-adjust: exact; 
                print-color-adjust: exact;
                background-color: white !important;
            } 
            .nota-box { 
                border: none !important; 
                box-shadow: none !important;
                margin: 0 !important;
                width: 100% !important;
                height: 100% !important;
            }
        }

        body { 
            font-family: 'Segoe UI', Roboto, Helvetica, Arial, sans-serif; 
            margin: 0; padding: 0; 
            background-color: #f4f4f9; 
            display: flex;
            justify-content: center;
        }

        .nota-box { 
            width: 105mm; 
            height: 148mm; 
            background-color: #fff;
            padding: 10mm 8mm; 
            box-sizing: border-box; 
            display: flex;
            flex-direction: column; 
            position: relative;
            border: 1px solid #ddd;
            margin: 20px 0;
            box-shadow: 0 4px 15px rgba(0,0,0,0.1);
        }

        .watermark { 
            position: absolute; top: 55%; left: 50%; 
            transform: translate(-50%, -50%) rotate(-30deg);
            opacity: 0.04; width: 60%; z-index: 0; pointer-events: none;
        }

        .header-container { 
            display: flex; 
            align-items: flex-start; 
            border-bottom: 2px solid #333; 
            padding-bottom: 8px; 
            margin-bottom: 12px;
            z-index: 1;
        }
        .logo-header { width: 45px; height: 45px; object-fit: contain; margin-right: 12px; }
        .company-info { flex-grow: 1; }
        .company-info h2 { margin: 0; font-size: 11px; color: #1a1a1a; text-transform: uppercase; letter-spacing: 0.5px; }
        .company-info p { margin: 2px 0; font-size: 8px; color: #444; line-height: 1.3; }

        .label-nota { text-align: right; }
        .label-nota h3 { margin: 0; color: #e67e22; font-size: 12px; font-weight: bold; }
        .label-nota p { margin: 2px 0 0 0; font-size: 8px; color: #555; }

        .content-area { 
            flex-grow: 1; 
            position: relative; 
            z-index: 1; 
        }
        table { width: 100%; border-collapse: collapse; margin-top: 5px; }
        th { 
            font-size: 9px; 
            text-transform: uppercase; 
            color: #555; 
            border-bottom: 1px solid #333; 
            padding: 8px 4px; 
            text-align: left; 
        }
        td { 
            font-size: 10px; 
            padding: 10px 4px; 
            border-bottom: 1px solid #eee;
            color: #333;
        }

        .footer-nota { 
            margin-top: auto; 
            z-index: 1;
        }
        
        .total-box { 
            border-top: 1px solid #eee;
            padding-top: 8px;
            margin-bottom: 10px; 
        }
        .total-row { 
            display: flex; 
            justify-content: space-between; 
            margin-bottom: 4px; 
            font-size: 10px; 
        }
        .grand-total { 
            font-size: 13px; 
            font-weight: bold; 
            border-top: 1.5px solid #333; 
            padding-top: 6px; 
            margin-top: 4px; 
        }

        .warning-box {
            color: #c0392b; 
            font-size: 7.5px; 
            margin-bottom: 15px; 
            background: #fffafa; 
            padding: 6px; 
            border: 1px dashed #ff7675; 
            border-radius: 4px; 
            text-align: center;
            font-style: italic;
        }

        .ttd-section { 
            display: flex; 
            justify-content: space-between; 
            font-size: 10px; 
            text-align: center; 
        }
        .ttd-box { width: 40%; }
        .ttd-space { height: 45px; } 
    </style>

    <% if (mode === 'thermal') { %>
        <style>
            .nota-box { box-shadow: none; border: none; padding: 5mm; }
            .watermark { display: none; }
            .no-print { display: none; }
        </style>
        <link rel="stylesheet" href="/css/thermal-style.css">
    <% } %>
</head>
<body>
    <div class="nota-box">
        <img src="<%= config.logo_path %>" class="watermark">
        
        <div class="header-container">
            <img src="<%= config.logo_path %>" class="logo-header">
            <div class="company-info">
                <h2><%= config.nama_perusahaan %></h2>
                <p><%= config.alamat.replace(/\n/g, ' ') %></p>
                <p><strong>WA: <%= config.no_hp %></strong></p>
            </div>
            <div class="label-nota">
                <h3><%= mode === 'thermal' ? 'STRUK' : 'NOTA RESMI' %></h3>
                <p>ID: #<%= po.id %></p>
                <p><%= tgl_sekarang %></p>
            </div>
        </div>

        <div class="content-area">
            <p style="font-size: 9px; margin-bottom: 8px;">Kepada Yth: <strong><%= po.customer %></strong></p>
            
            <% 
                let qtys = details.map(d => d.jumlah);
                let qtyTampil = qtys[0] || 0; 
                let hargaSatuan = qtyTampil > 0 ? (po.total_harga_customer / qtyTampil) : 0;
            %>

            <table>
                <thead>
                    <tr>
                        <th style="width: 50%;">Deskripsi Barang</th>
                        <th style="text-align: center; width: 15%;">Qty</th>
                        <th style="text-align: right; width: 35%;">Subtotal</th>
                    </tr>
                </thead>
                <tbody>
                    <tr>
                        <td>
                            <strong><%= po.nama_po %></strong><br>
                            <span style="font-size: 8px; color: #777;">@ Rp <%= Math.round(hargaSatuan).toLocaleString('id-ID') %></span>
                        </td>
                        <td style="text-align: center;"><%= qtyTampil %> Pcs</td>
                        <td style="text-align: right; font-weight: bold;">
                            <%= po.total_harga_customer.toLocaleString('id-ID') %>
                        </td>
                    </tr>
                </tbody>
            </table>
        </div>

        <div class="footer-nota">
            <div class="total-box">
                <div class="total-row">
                    <span>Total Tagihan</span>
                    <span>Rp <%= po.total_harga_customer.toLocaleString('id-ID') %></span>
                </div>
                <div class="total-row" style="color: #27ae60;">
                    <span>Total Bayar</span>
                    <span>Rp <%= (po.total_bayar || 0).toLocaleString('id-ID') %></span>
                </div>
                <div class="total-row grand-total">
                    <span>SISA</span>
                    <span>Rp <%= (Number(po.total_harga_customer || 0) - Number(po.total_bayar || 0)).toLocaleString('id-ID') %></span>
                </div>
            </div>

            <div class="warning-box">
                "Barang yang sudah dibeli tidak dapat ditukar atau dikembalikan. Terimakasih."
            </div>

            <div class="ttd-section">
                <div class="ttd-box">
                    Penerima,
                    <div class="ttd-space"></div>
                    ( ............................ )
                </div>
                <div class="ttd-box">
                    Hormat Kami,
                    <div class="ttd-space"></div>
                    ( <strong><%= config.nama_perusahaan.split(' ')[0] %></strong> )
                </div>
            </div>
        </div>
    </div>

    <script>
        window.onload = function() {
            const namaCust = "<%= po.customer %>";
            const tgl = new Date().toLocaleDateString('id-ID').replace(/\//g, '-');
            document.title = "Nota_" + namaCust.replace(/\s+/g, '_') + "_" + tgl;
            
            setTimeout(() => { 
                window.print(); 
                window.onafterprint = function() {
                    // window.close(); 
                }
            }, 600);
        };
    </script>
</body>
</html>