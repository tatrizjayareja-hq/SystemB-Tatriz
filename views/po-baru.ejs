<!DOCTYPE html>
<html lang="id">
<head>
    <style>
        /* Tambahan CSS sedikit untuk merapikan tampilan non-internal */
        .grid-standard { grid-template-columns: 2fr 2fr 1fr 2fr !important; }
    </style>
</head>
<% 
    // Menggunakan variabel access yang dikirim dari middleware server.js
    const showOpPrice = access.isInternal; 
%>
<body data-isinternal="<%= showOpPrice %>">

<div class="form-container">
    <a href="/dashboard" style="text-decoration: none; color: #666; font-size: 14px;">← Kembali</a>
    <h2 style="color: #195e0b;">📝 Input Pesanan Baru (PO)</h2>
    
    <form action="/save-po" method="POST">
        <div id="sub-po-container">
            <div class="sub-po-row">
                <div class="grid-sub <%= showOpPrice ? 'grid-pro' : 'grid-standard' %>">
                    <div>
                        <label>Jenis</label>
                        <input type="text" name="jenis_bordir[]" list="list_jenis">
                    </div>
                    <div>
                        <label>Desain</label>
                        <input type="text" name="nama_desain[]">
                    </div>
                    <div>
                        <label>Qty</label>
                        <input type="number" name="jumlah[]" required>
                    </div>

                    <% if (showOpPrice) { %>
                        <div>
                            <label>Harga Op</label>
                            <input type="number" name="harga_operator[]">
                        </div>
                    <% } else { %>
                        <input type="hidden" name="harga_operator[]" class="hidden-op">
                    <% } %>

                    <div>
                        <label>Harga Cust</label>
                        <input type="number" name="harga_customer[]" required oninput="sinkronkanHarga(this)">
                    </div>
                </div>
            </div>
        </div>

        <button type="button" class="btn-add" onclick="tambahBaris()">+ Tambah Baris</button>
        <button type="submit" class="btn-save">SIMPAN DATA PO</button>
    </form>
</div>

<script>
    document.getElementById('tgl_sekarang').valueAsDate = new Date();

    function sinkronkanHarga(el) {
        // Jika bukan internal, kita paksa harga operator sama dengan harga customer di background
        const row = el.closest('.grid-sub');
        const hiddenOp = row.querySelector('.hidden-op');
        if (hiddenOp) hiddenOp.value = el.value;
    }

    function tambahBaris() {
        const container = document.getElementById('sub-po-container');
        // Ambil data dari atribut body
        const isInternal = document.body.dataset.isinternal === 'true';
        
        const row = document.createElement('div');
        row.className = 'sub-po-row';
        
        const gridClass = isInternal ? 'grid-pro' : 'grid-standard';
        
        // Kondisi kolom operator di Javascript
        let kolomOp = '';
        if (isInternal) {
            kolomOp = `<div><label>Harga Op</label><input type="number" name="harga_operator[]"></div>`;
        } else {
            kolomOp = `<input type="hidden" name="harga_operator[]" class="hidden-op">`;
        }

        row.innerHTML = `
            <span class="remove-row" onclick="this.parentElement.remove()">✖ Hapus</span>
            <div class="grid-sub ${gridClass}">
                <div><label>Jenis</label><input type="text" name="jenis_bordir[]" list="list_jenis"></div>
                <div><label>Desain</label><input type="text" name="nama_desain[]"></div>
                <div><label>Qty</label><input type="number" name="jumlah[]"></div>
                ${kolomOp}
                <div><label>Harga Cust</label><input type="number" name="harga_customer[]" required oninput="sinkronkanHarga(this)"></div>
            </div>
        `;
        container.appendChild(row);
    }
</script>
</body>
</html>