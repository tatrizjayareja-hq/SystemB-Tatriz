<footer class="mt-5 py-3 bg-light border-top">
        <div class="container text-center">
            <p class="text-muted mb-0">
                &copy; 2026 <strong><%= config.nama_perusahaan %></strong> - <%= config.nama_aplikasi %>
            </p>
            <small class="text-secondary">Sistem Manajemen Produksi & Payroll Tatriz</small>
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
<script>
        document.addEventListener('DOMContentLoaded', function() {
            const loader = document.getElementById('loaderSistem');
            if (loader) {
                setTimeout(function() {
                    loader.classList.add('loader-hilang');
                }, 200);
            }
        });
        setTimeout(function() {
            const loader = document.getElementById('loaderSistem');
            if (loader && !loader.classList.contains('loader-hilang')) {
                loader.classList.add('loader-hilang');
            }
        }, 4000);
    </script>

</body>
</html>