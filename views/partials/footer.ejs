<footer class="mt-5 py-3 bg-light border-top">
        <div class="container text-center">
            <p class="text-muted mb-0">
                &copy; 2026 <strong><%= config.nama_perusahaan %></strong> - <%= config.nama_aplikasi %>
            </p>
            <small class="text-secondary">Sistem Manajemen Produksi & Payroll Tatriz</small>
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>

    <script>
        function tampilkanLoader() {
            const loader = document.getElementById('quickLoader');
            if (loader) loader.classList.add('show');
        }

        document.addEventListener('DOMContentLoaded', () => {
            // Sembunyikan loader dengan halus saat halaman selesai dimuat sepenuhnya
            const loader = document.getElementById('quickLoader');
            if (loader) {
                setTimeout(() => {
                    loader.classList.remove('show');
                }, 100); // Jeda sangat singkat agar transisi lebih natural
            }

            // Pasang trigger loader otomatis ke semua elemen dengan class 'nav-link-load'
            const links = document.querySelectorAll('.nav-link-load');
            links.forEach(link => {
                link.addEventListener('click', function(e) {
                    // Hanya jalankan animasi jika link tidak membuka tab baru dan tidak dicegah oleh konfirmasi alert
                    if (this.target !== '_blank' && !this.hasAttribute('onclick')) {
                        tampilkanLoader();
                    }
                });
            });

            // Fallback pengaman: Jika koneksi internet putus/lambat, loader otomatis hilang dalam 6 detik
            setTimeout(function() {
                if (loader && loader.classList.contains('show')) {
                    loader.classList.remove('show');
                }
            }, 6000);
        });
    </script>

</body>
</html>