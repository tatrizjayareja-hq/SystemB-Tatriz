<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= config.nama_aplikasi %></title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <style>
        body { background-color: #f8f9fa; }
        .nav-link { color: #333; }
        .nav-link:hover { color: #198754; }
    </style>
</head>
<body>
    <div id="loaderSistem" style="
    position: fixed;
    top: 0; left: 0;
    width: 100%; height: 100%;
    background: #195e0b; /* Warna hijau gelap khas Tatriz */
    z-index: 99999; /* Dipastikan paling atas menutupi semua menu */
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    transition: opacity 0.3s ease, visibility 0.3s ease;
">
    <div class="spinner-tatriz"></div>
    <p style="color: white; margin-top: 18px; font-weight: bold; font-size: 14px; letter-spacing: 1px; font-family: sans-serif; text-align: center;">
        MEMUAT SISTEM TATRIZ...
    </p>
</div>

<style>
    .spinner-tatriz {
        width: 50px; height: 50px;
        border: 5px solid rgba(255,255,255,0.2);
        border-top: 5px solid #59cf77; /* Warna hijau muda aksen */
        border-radius: 50%;
        animation: putarLoaderTatriz 1s linear infinite;
    }
    @keyframes putarLoaderTatriz {
        0% { transform: rotate(0deg); }
        100% { transform: rotate(360deg); }
    }
    /* Kelas untuk menghilangkan loader dengan halus */
    .loader-hilang {
        opacity: 0 !important;
        visibility: hidden !important;
    }
</style>
    
    <nav class="navbar navbar-expand-lg navbar-dark bg-dark mb-4">
        <div class="container">
            <a class="navbar-brand" href="/dashboard"><%= config.nama_perusahaan %></a>
            <div class="navbar-nav">
                <a class="nav-link" href="/dashboard">Dashboard</a>
                <a class="nav-link" href="/po-data-v2">Data PO</a>
                <li class="nav-item" style="list-style: none;">
                    <a class="nav-link" href="/daftar-produksi">
                        <i class="bi bi-list-check"></i>
                        <span>Daftar Produksi</span>
                    </a>
                </li>
                <a class="nav-link text-danger" href="/logout">Logout</a>               
            </div>
        </div>
    </nav>