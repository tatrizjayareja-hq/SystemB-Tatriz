<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Input Kerja - Tatriz</title>
    <style>
        body { font-family: 'Segoe UI', sans-serif; background: #f0f2f5; margin: 0; padding: 15px; }
        .welcome-section { margin-bottom: 20px; }
        .card { background: white; padding: 20px; border-radius: 15px; box-shadow: 0 4px 10px rgba(0,0,0,0.05); }
        .motivation { font-style: italic; color: #666; font-size: 13px; margin-bottom: 15px; display: block; }
        
        /* Hitung Mundur Target */
        .target-monitor { background: #fff9eb; border: 1px solid #ffeaa7; padding: 15px; border-radius: 10px; margin-bottom: 20px; }
        .target-value { color: #d63031; font-weight: bold; font-size: 18px; }

        .input-group { margin-bottom: 15px; }
        label { display: block; font-weight: bold; margin-bottom: 5px; font-size: 13px; color: #333; }
        input, select { width: 100%; padding: 12px; border: 1px solid #ddd; border-radius: 8px; font-size: 16px; background: #fff; }
        
        .btn-setor { background: #0984e3; color: white; border: none; padding: 15px; width: 100%; border-radius: 10px; font-weight: bold; font-size: 16px; cursor: pointer; margin-top: 10px; }
        .info-bordir { background: #f8f9fa; padding: 10px; border-radius: 8px; margin-top: 10px; border-left: 4px solid #0984e3; display: none; }
    </style>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
</head>
<body>
<div id="loaderSistem" style="
    position: fixed;
    top: 0; left: 0;
    width: 100%; height: 100%;
    background: #195e0b; /* Warna hijau gelap khas Tatriz */
    z-index: 99999; /* Dipastikan paling atas menutupi semua menu */
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    transition: opacity 0.3s ease, visibility 0.3s ease;
">
    <div class="spinner-tatriz"></div>
    <p style="color: white; margin-top: 18px; font-weight: bold; font-size: 14px; letter-spacing: 1px; font-family: sans-serif; text-align: center;">
        MEMUAT SISTEM TATRIZ...
    </p>
</div>

<style>
    .spinner-tatriz {
        width: 50px; height: 50px;
        border: 5px solid rgba(255,255,255,0.2);
        border-top: 5px solid #59cf77; /* Warna hijau muda aksen */
        border-radius: 50%;
        animation: putarLoaderTatriz 1s linear infinite;
    }
    @keyframes putarLoaderTatriz {
        0% { transform: rotate(0deg); }
        100% { transform: rotate(360deg); }
    }
    /* Kelas untuk menghilangkan loader dengan halus */
    .loader-hilang {
        opacity: 0 !important;
        visibility: hidden !important;
    }
</style>
<div class="welcome-section">
    <strong>Halo, <%= user.nama %>! 👋</strong>
    <span class="motivation">"Semangat! Setiap tusukan jarum adalah rezeki."</span>
</div>

<% if (access.isInternal) { %>
    <div class="target-monitor" id="monitor_target">
        <small>Target Bonus Hari Ini:</small><br>
        <% if (kurangnya > 0) { %>
            <span>Kurang <span class="target-value">Rp <%= kurangnya.toLocaleString() %></span> lagi untuk bonus!</span>
        <% } else { %>
            <span style="color: #27ae60; font-weight: bold;">🎉 Target tercapai! Bonus terkunci.</span>
        <% } %>
    </div>
<% } %>

<div class="card">
    <form action="/simpan-kerja" method="POST">
        <div class="input-group">
    <label>Tanggal & Shift</label>
    <div style="display: grid; grid-template-columns: 2fr 1.5fr; gap: 10px;">
                <input type="date" name="tanggal" id="tgl_kerja" required>
                <script>document.getElementById('tgl_kerja').valueAsDate = new Date();</script>
                <select name="shift">
                    <option value="Pagi">Pagi</option>
                    <option value="Sore">Sore</option>
                    <option value="Malam">Malam</option>
                </select>
            </div>
        </div>

        <div class="input-group" style="background: #f8f9fa; padding: 12px; border-radius: 8px; border: 1px dashed #ced4da; margin-top: 10px;">
            <label style="color: #195e0b; margin-bottom: 8px;"><i class="bi bi-clock-history"></i> Absen Durasi Jam Kerja</label>
            <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 10px;">
                <div>
                    <small style="color: #666; font-size: 11px; display: block; margin-bottom: 4px;">Jam Kerja Reguler</small>
                    <input type="number" name="jam_reguler" id="input_jam_reguler" value="<%= config.jam_kerja_reguler || 8 %>" min="0" max="24" step="0.5" required style="padding: 8px; font-size: 14px;">
                </div>
                <div>
                    <small style="color: #666; font-size: 11px; display: block; margin-bottom: 4px;">Jam Lembur (Kelebihan)</small>
                    <input type="number" name="jam_lembur" id="input_jam_lembur" value="0" min="0" max="24" step="0.5" required style="padding: 8px; font-size: 14px;">
                </div>
            </div>
        </div>
        <div class="input-group">
            <label>Pilih Pesanan (PO)</label>
            <select name="po_id" id="select_po" onchange="muatDaftarDesain(this.value)" required>
                <option value="">-- Pilih PO --</option>
                <% active_pos.forEach(po => { %>
                    <option value="<%= po.id %>"><%= po.nama_po %></option>
                <% }) %>
            </select>
        </div>

        <div class="input-group">
            <label>Pilih Jenis Bordir</label>
            <select name="detail_id" id="select_jenis" onchange="pilihOtomatisDesain(this)" required disabled>
                <option value="">-- Pilih Jenis --</option>
            </select>
        </div>

        <input type="hidden" name="harga_op" id="input_harga_op">

        <div id="info_bordir" class="info-bordir" style="background: #e8f4fd; padding: 15px; border-radius: 10px; display: none; margin-bottom: 15px; border-left: 5px solid #0984e3;">
            <div style="margin-bottom: 5px;">
                <small style="color: #666;">Nama Desain:</small><br>
                <strong id="display_nama_desain" style="font-size: 16px; color: #333;"></strong>
            </div>
            
            <% if (access.isInternal) { %>
            <div style="margin-bottom: 10px;">
                <small style="color: #666;">Upah per Pcs:</small><br>
                <strong id="display_harga" style="color: #27ae60;"></strong>
            </div>
            <% } %>
            
            <label>Jumlah Hasil (Pcs)</label>
            <input type="number" name="jumlah_setor" id="input_setor" placeholder="0" min="1" required style="width: 100%; padding: 10px; border-radius: 8px; border: 1px solid #ddd;">
        </div>

        <div class="input-group">
            <label>Pilih Mesin / Jalur Kerja</label>
            <select name="mesin_id" id="select_mesin" required>
                <option value="">-- Gunakan Mesin Mana? --</option>
                <% daftarMesin.forEach(m => { %>
                    <option value="<%= m.id %>"><%= m.nama_mesin %></option>
                <% }) %>
            </select>
        </div>

        <button type="submit" class="btn-setor">SIMPAN HASIL KERJA</button>
    </form>
</div>

<div style="margin-top: 25px; padding: 0 10px;">
    <a href="/hasil-saya" style="display: block; text-align: center; background: white; color: #0984e3; padding: 12px; border-radius: 10px; text-decoration: none; font-weight: bold; border: 2px solid #0984e3; margin-bottom: 15px;">
        🔍 LIHAT REKAP HASIL KERJA SAYA
    </a>
    
    <div style="text-align: center;">
        <a href="/logout" style="color: #e74c3c; text-decoration: none; font-size: 14px; font-weight: bold;">
            🚪 Keluar (Logout)
        </a>
    </div>
</div>

<script>
let dataSimpanan = []; 

async function muatDaftarDesain(poId) {
    const selectJenis = document.getElementById('select_jenis');
    const infoDiv = document.getElementById('info_bordir');
    
    infoDiv.style.display = 'none';
    if(!poId) { selectJenis.disabled = true; return; }

    try {
        const res = await fetch(`/api/po-details/${poId}`);
        dataSimpanan = await res.json(); 
        
        let html = '<option value="">-- Pilih Jenis Bordir --</option>';
        dataSimpanan.forEach(d => {
            html += `<option value="${d.id}" 
                         data-nama="${d.nama_desain}" 
                         data-harga="${d.harga_operator}" 
                         data-sisa="${d.sisa}">${d.jenis_bordir} (Sisa: ${d.sisa})</option>`;
        });
        
        selectJenis.innerHTML = html;
        selectJenis.disabled = false;
    } catch (err) {
        console.error("Gagal ambil data:", err);
    }
}

function pilihOtomatisDesain(el) {
    const infoDiv = document.getElementById('info_bordir');
    const selected = el.options[el.selectedIndex];
    const isInternal = document.body.dataset.isinternal === 'true'; // Kita bisa gunakan flag ini
    
    if(el.value) {
        const namaDesain = selected.getAttribute('data-nama');
        const harga = selected.getAttribute('data-harga');
        const sisa = selected.getAttribute('data-sisa');

        document.getElementById('display_nama_desain').innerText = namaDesain;
        
        // Element display_harga mungkin tidak ada di DOM jika bukan internal
        const displayHargaEl = document.getElementById('display_harga');
        if (displayHargaEl) {
            displayHargaEl.innerText = "Rp " + parseInt(harga).toLocaleString('id-ID');
        }

        document.getElementById('input_harga_op').value = harga;
        
        const inputSetor = document.getElementById('input_setor');
        inputSetor.placeholder = "Sisa Target: " + sisa; 
        
        infoDiv.style.display = 'block';
    } else {
        infoDiv.style.display = 'none';
    }
}
</script>
<script>
    document.addEventListener('DOMContentLoaded', function() {
        const loader = document.getElementById('loaderSistem');
        if (loader) {
            setTimeout(function() {
                loader.classList.add('loader-hilang');
            }, 200);
        }
    });
    setTimeout(function() {
        const loader = document.getElementById('loaderSistem');
        if (loader && !loader.classList.contains('loader-hilang')) {
            loader.classList.add('loader-hilang');
        }
    }, 4000);
</script>
<script>
    // ==========================================
    // 1. FITUR AUTO-SELECT PO (DARI KIOSK)
    // ==========================================
    document.addEventListener('DOMContentLoaded', function() {
        const kioskPoId = "<%= kiosk_po_id %>"; // Nilai dari backend
        if (kioskPoId && kioskPoId !== 'null') {
            const selectPO = document.getElementById('select_po');
            selectPO.value = kioskPoId;
            // Panggil fungsi muatDaftarDesain agar dropdown Jenis Bordir otomatis terisi
            muatDaftarDesain(kioskPoId);
        }
    });

    // ==========================================
    // 2. FITUR POPUP POST-SIMPAN (LANJUT ATAU KELUAR)
    // ==========================================
    document.addEventListener('DOMContentLoaded', function() {
        const urlParams = new URLSearchParams(window.location.search);
        if (urlParams.get('success') === 'true') {
            Swal.fire({
                title: 'Kerja Bagus! 🚀',
                text: 'Data hasil kerja & durasi absen berhasil disimpan.',
                icon: 'success',
                showCancelButton: true,
                confirmButtonColor: '#0984e3',
                cancelButtonColor: '#e74c3c',
                confirmButtonText: 'Input PO Lain',
                cancelButtonText: 'Keluar (Logout)',
                allowOutsideClick: false // Paksa user memilih
            }).then((result) => {
                if (result.isConfirmed) {
                    // Bersihkan URL agar popup tidak muncul lagi jika di-refresh
                    window.history.replaceState({}, document.title, "/operator");
                } else {
                    // Logout dan kembali ke Kiosk
                    window.location.href = '/logout';
                }
            });
        }
    });

    // ==========================================
    // 3. FITUR IDLE TIMEOUT (KEAMANAN KIOSK)
    // ==========================================
    let idleTime = 0;
    const idleLimitSeconds = 60; // Set batas waktu diam: 60 detik

    // Reset timer jika ada aktivitas di layar
    function resetIdleTimer() {
        idleTime = 0;
    }

    // Pasang sensor aktivitas
    document.addEventListener('mousemove', resetIdleTimer);
    document.addEventListener('keypress', resetIdleTimer);
    document.addEventListener('touchstart', resetIdleTimer); // Untuk layar sentuh tablet
    document.addEventListener('scroll', resetIdleTimer);

    // Jalankan timer setiap detik
    setInterval(function() {
        idleTime++;
        if (idleTime >= idleLimitSeconds) {
            // Jika menganggur melebih batas waktu, otomatis logout
            window.location.href = '/logout';
        }
    }, 1000); // 1000 ms = 1 detik
    // ==========================================
    // 1. FITUR AUTO-SELECT PO (DARI KIOSK)
    // ==========================================
    document.addEventListener('DOMContentLoaded', async function() {
        const urlParams = new URLSearchParams(window.location.search);
        const kioskPoId = urlParams.get('po_id');
        const kioskDetailId = urlParams.get('detail_id');

        if (kioskPoId && kioskPoId !== 'null') {
            const selectPO = document.getElementById('select_po');
            selectPO.value = kioskPoId;
            
            // Muat daftar desain (Fungsi Asli Anda)
            await muatDaftarDesain(kioskPoId);
            
            // Jika ada detail ID dari kiosk, otomatis pilih itemnya
            if (kioskDetailId) {
                setTimeout(() => { // Kasih jeda kecil untuk merender DOM option-nya
                    const selectJenis = document.getElementById('select_jenis');
                    selectJenis.value = kioskDetailId;
                    pilihOtomatisDesain(selectJenis); // Trigger pemunculan info_bordir
                }, 100);
            }
        }
    });
</script>
</body>
</html>