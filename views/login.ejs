<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Login - Tatriz SystemB</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

    <link rel="manifest" href="/manifest.json">
    <meta name="theme-color" content="#195e0b">
    <script>
      if ('serviceWorker' in navigator) {
        window.addEventListener('load', () => {
          navigator.serviceWorker.register('/service-worker.js')
            .then(reg => console.log('PWA Tatriz Berhasil Aktif!', reg.scope))
            .catch(err => console.error('PWA Tatriz Gagal:', err));
        });
      }
    </script>
    <style>
        :root {
            --dark-green: #195e0b;
            --primary-green: #59cf77;
            --accent-green: #48b865;
            --text-gray: #636e72;
        }

        body, html {
            margin: 0;
            padding: 0;
            min-height: 100vh;
            font-family: 'Segoe UI', Roboto, sans-serif;
            background: linear-gradient(135deg, #195e0b 0%, #48b865 100%);
            display: flex;
            justify-content: center;
            align-items: center;
        }

        /* --- CONTAINER UTAMA --- */
        .login-container {
            width: 450px; /* Ukuran ideal untuk form vertikal */
            max-width: 90%;
            margin: 20px auto;
        }

        .login-card {
            background: white;
            border-radius: 20px;
            overflow: hidden;
            box-shadow: 0 20px 40px rgba(0,0,0,0.3);
            display: flex;
            flex-direction: column; /* ATAS - BAWAH */
        }

        /* --- BAGIAN ATAS: BRANDING --- */
        .card-header {
            background: white;
            padding: 40px 30px 20px;
            text-align: center;
        }

        .card-header img {
            width: 120px;
            height: auto;
            margin-bottom: 15px;
        }

        .card-header h1 {
            color: var(--dark-green);
            margin: 0;
            font-size: 26px;
            font-weight: 800;
        }

        .card-header .tagline {
            color: var(--text-gray);
            font-size: 14px;
            margin-top: 8px;
            line-height: 1.4;
        }

        /* --- BAGIAN BAWAH: FORM --- */
        .card-body {
            background-color: var(--dark-green);
            color: white;
            padding: 40px 35px;
        }

        .card-body h2 {
            margin: 0 0 5px 0;
            font-size: 22px;
            text-align: center;
        }

        .card-body p {
            font-size: 13px;
            opacity: 0.7;
            margin-bottom: 25px;
            text-align: center;
        }

        .form-group {
            margin-bottom: 18px;
        }

        .form-group label {
            display: block;
            font-size: 11px;
            margin-bottom: 8px;
            text-transform: uppercase;
            letter-spacing: 1px;
        }

        .input-wrapper {
            position: relative;
        }

        .input-wrapper i {
            position: absolute;
            left: 15px;
            top: 50%;
            transform: translateY(-50%);
            color: rgba(255,255,255,0.5);
        }

        .input-wrapper input {
            width: 100%;
            padding: 14px 15px 14px 45px;
            background: rgba(255,255,255,0.1);
            border: 1px solid rgba(255,255,255,0.2);
            border-radius: 10px;
            color: white;
            box-sizing: border-box;
            outline: none;
            transition: 0.3s;
            font-size: 16px; /* Mencegah auto-zoom di iPhone */
        }

        .input-wrapper input:focus {
            background: rgba(255,255,255,0.15);
            border-color: var(--primary-green);
            box-shadow: 0 0 0 4px rgba(89, 207, 119, 0.1);
        }

        .btn-login {
            width: 100%;
            padding: 15px;
            background: var(--primary-green);
            color: var(--dark-green);
            border: none;
            border-radius: 10px;
            font-weight: bold;
            font-size: 15px;
            cursor: pointer;
            transition: 0.3s;
            margin-top: 10px;
            text-transform: uppercase;
            letter-spacing: 1px;
        }

        .btn-login:hover {
            background: white;
            transform: translateY(-2px);
        }

        /* --- FOOTER / LINK --- */
        .card-footer {
            padding: 20px;
            text-align: center;
            background: #f9f9f9;
            font-size: 13px;
        }

        .card-footer a {
            color: var(--dark-green);
            text-decoration: none;
            font-weight: bold;
        }

        /* Info Sistem Baru */
        .setup-info {
            margin-top: 15px;
            padding: 10px;
            background: rgba(255, 255, 255, 0.05);
            border-radius: 8px;
            font-size: 12px;
            color: #fab1a0;
            text-align: center;
        }

        /* Responsive Mobile */
        @media (max-width: 480px) {
            .login-container { width: 95%; }
            .card-header { padding: 30px 20px 15px; }
            .card-body { padding: 30px 20px; }
        }

        .forgot-password-link {
            text-align: right;
            margin-bottom: 15px;
            margin-top: -5px;
        }
        
        .forgot-password-link a {
            color: #fab1a0;
            font-size: 11px;
            text-decoration: none;
            transition: 0.2s;
        }

        .forgot-password-link a:hover {
            color: white;
            text-decoration: underline;
        }
    </style>
</head>
<body>

    <div id="loaderSistem" style="
    position: fixed;
    top: 0; left: 0;
    width: 100%; height: 100%;
    background: rgba(25, 94, 11, 0.95); /* Warna hijau gelap khas Tatriz */
    z-index: 9999;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    transition: opacity 0.4s ease, visibility 0.4s ease;
">
    <div style="
        width: 50px; height: 50px;
        border: 5px solid rgba(255,255,255,0.2);
        border-top: 5px solid #59cf77; /* Warna hijau muda aksen */
        border-radius: 50%;
        animation: putarLoader 1s linear infinite;
    "></div>
    <p style="color: white; margin-top: 15px; font-weight: bold; font-size: 14px; letter-spacing: 1px;">
        MEMUAT SISTEM TATRIZ...
    </p>
</div>

<style>
    @keyframes putarLoader {
        0% { transform: rotate(0deg); }
        100% { transform: rotate(360deg); }
    }
    /* Kelas gaib untuk menghilangkan loader dengan halus */
    .loader-hilang {
        opacity: 0 !important;
        visibility: hidden !important;
    }
</style>

    <div class="login-container">
        <div class="login-card">
            <div class="card-header">
                <img src="/img/Tatriz SystemB.png" alt="Logo Tatriz SystemB">
                <h1>Tatriz SystemB</h1>
                <p class="tagline">Solusi digital cerdas untuk manajemen bordir profesional.</p>
            </div>

            <div class="card-body">
                <h2>Portal Masuk</h2>
                <p>Gunakan akun terdaftar Anda</p>

                <form action="/login" method="POST">
                    <div class="form-group">
                        <label>Username</label>
                        <div class="input-wrapper">
                            <i class="fas fa-user"></i>
                            <input type="text" name="username" placeholder="Username" required>
                        </div>
                    </div>
                    <div class="form-group" style="margin-bottom: 5px;">
                        <label>Password</label>
                        <div class="input-wrapper">
                            <i class="fas fa-lock"></i>
                            <input type="password" name="password" placeholder="Password" required>
                        </div>
                    </div>
                    
                    <div class="forgot-password-link">
                        <a href="#" onclick="pemicuLupaPassword()">Lupa Password?</a>
                    </div>

                    <button type="submit" class="btn-login">Masuk Sekarang</button>
                </form>
                <div id="areaInstalPWA" style="display: none; margin-top: 20px; padding: 15px; background: rgba(255,255,255,0.1); border: 1px dashed rgba(255,255,255,0.3); border-radius: 10px; text-align: center;">
                    <p style="margin: 0 0 10px 0; font-size: 13px; color: white; opacity: 0.9;">
                        <i class="fas fa-mobile-alt"></i> Gunakan versi aplikasi untuk akses lebih cepat dan nyaman di HP.
                    </p>
                    <button id="btnInstalPWA" class="btn-login" style="background: #ffffff; color: #195e0b; margin-top: 0;">
                        <i class="fas fa-download"></i> INSTAL APLIKASI HP
                    </button>
                </div>

                <% if (isNew) { %>
                <div class="setup-info">
                    <i class="fas fa-info-circle"></i> Sistem baru. 
                    <a href="/register" style="color: white; text-decoration: underline;">Klik Setup Awal</a>
                </div>
                <% } %>
            </div>

            <div class="card-footer">
                Belum bergabung? <a href="/register">Daftar Perusahaan</a>
            </div>
        </div>
    </div>

    <script>
        function pemicuLupaPassword() {
        Swal.fire({
            title: 'Lupa Password?',
            html: `
                <p style="font-size: 14px;">Masukkan <b>Username</b> atau <b>Nama Toko</b> Anda agar kami bisa mencarinya.</p>
            `,
            input: 'text',
            inputPlaceholder: 'Ketik username / nama toko...',
            showCancelButton: true,
            confirmButtonColor: '#25D366', // Warna hijau khas WhatsApp
            confirmButtonText: '<i class="fab fa-whatsapp"></i> Hubungi Developer',
            cancelButtonText: 'Batal'
        }).then((result) => {
            if (result.isConfirmed && result.value) {
                const pesan = `Halo Developer Tatriz, saya lupa password login untuk akun saya (Username/Toko: *${result.value}*). Mohon bantuannya untuk reset password sementara.`;
                const noWA = '6281315290003';
                
                window.open(`https://api.whatsapp.com/send/?phone=${noWA}&text=${encodeURIComponent(pesan)}`, '_blank');
            }
        });
    }
    let pemicuInstal;
const areaInstal = document.getElementById('areaInstalPWA');
const btnInstal = document.getElementById('btnInstalPWA');

// Browser mendeteksi bahwa web ini bisa diinstal sebagai PWA
window.addEventListener('beforeinstallprompt', (e) => {
    // Cegah browser menampilkan banner bawaannya yang kecil di bawah
    e.preventDefault();
    // Simpan kejadian ini ke variabel
    pemicuInstal = e;
    
    // TAMPILKAN tombol buatan kita ke pengguna awam
    areaInstal.style.display = 'block';
});

// Ketika tombol buatan kita diklik oleh user
btnInstal.addEventListener('click', async () => {
    if (!pemicuInstal) return;
    
    // Munculkan perintah instalasi resmi dari sistem HP
    pemicuInstal.prompt();
    
    // Tunggu jawaban dari user (Apakah mereka klik 'Setuju' atau 'Batal')
    const { outcome } = await pemicuInstal.userChoice;
    console.log(`Pilihan user: ${outcome}`);
    
    // Bersihkan pemicu, tombol kita sembunyikan lagi karena proses sudah selesai
    pemicuInstal = null;
    areaInstal.style.style.display = 'none';
});

// Jika aplikasi ternyata sudah terinstal di HP mereka, otomatis sembunyikan tombol
window.addEventListener('appinstalled', () => {
    areaInstal.style.display = 'none';
    pemicuInstal = null;
});
    </script>
    <script>
    // Begitu seluruh elemen halaman (gambar, css, text) selesai dimuat 100%
    window.addEventListener('load', function() {
        const loader = document.getElementById('loaderSistem');
        if (loader) {
            // Tambahkan kelas untuk efek memudar (fade out) selama 0.4 detik
            loader.classList.add('loader-hilang');
        }
    });
</script>
</body>
</html>