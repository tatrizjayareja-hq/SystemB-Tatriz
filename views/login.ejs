<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Login - Tatriz SystemB</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

    <link rel="manifest" href="/manifest.json">
    <meta name="theme-color" content="#195e0b">
    <script>
      if ('serviceWorker' in navigator) {
        window.addEventListener('load', () => {
          navigator.serviceWorker.register('/service-worker.js')
            .then(reg => console.log('PWA Tatriz Berhasil Aktif!', reg.scope))
            .catch(err => console.error('PWA Tatriz Gagal:', err));
        });
      }
    </script>
    <style>
        :root {
            /* Warna Original Tatriz */
            --dark-green: #195e0b;
            --primary-green: #59cf77;
            --accent-green: #48b865;
            --text-gray: #636e72;
            
            /* Tambahan Tema World Cup (Emas & Stadion) */
            --wc-gold: #FFD700;
            --wc-gold-dark: #DAA520;
            --wc-pitch-dark: #0d3805;
            --wc-pitch-light: #144f08;
        }

        body, html {
            margin: 0;
            padding: 0;
            min-height: 100vh;
            font-family: 'Segoe UI', Roboto, sans-serif;
            /* Background pola rumput stadion sepak bola dengan efek lampu sorot (vignette) */
            background: radial-gradient(circle at center, transparent 0%, rgba(0,0,0,0.6) 100%),
                        repeating-linear-gradient(
                            90deg,
                            var(--wc-pitch-dark),
                            var(--wc-pitch-dark) 40px,
                            var(--wc-pitch-light) 40px,
                            var(--wc-pitch-light) 80px
                        );
            display: flex;
            justify-content: center;
            align-items: center;
        }

        /* --- CONTAINER UTAMA --- */
        .login-container {
            width: 450px;
            max-width: 90%;
            margin: 20px auto;
        }

        .login-card {
            background: white;
            border-radius: 20px;
            overflow: hidden;
            /* Bayangan dengan nuansa emas tipis */
            box-shadow: 0 15px 35px rgba(0,0,0,0.5), 0 0 20px rgba(218, 165, 32, 0.2);
            display: flex;
            flex-direction: column;
            border: 1px solid rgba(255, 215, 0, 0.3); /* Border emas tipis */
        }

        /* --- BAGIAN ATAS: BRANDING --- */
        .card-header {
            background: white;
            padding: 40px 30px 20px;
            text-align: center;
            position: relative;
        }

        /* Aksen pita/garis atas bergaya World Cup */
        .card-header::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 6px;
            background: linear-gradient(90deg, var(--dark-green), var(--wc-gold), var(--dark-green));
        }

        .card-header img {
            width: 120px;
            height: auto;
            margin-bottom: 15px;
        }

        .card-header h1 {
            color: var(--dark-green);
            margin: 0;
            font-size: 26px;
            font-weight: 900; /* Dibuat lebih tebal agar lebih bold */
            text-transform: uppercase;
            letter-spacing: 1px;
        }

        .card-header .tagline {
            color: var(--text-gray);
            font-size: 14px;
            margin-top: 8px;
            line-height: 1.4;
        }

        /* --- BAGIAN BAWAH: FORM --- */
        .card-body {
            /* Menggunakan hijau Tatriz dengan pola samar jaring gawang (opsional/visual) */
            background-color: var(--dark-green);
            background-image: radial-gradient(rgba(255, 255, 255, 0.05) 1px, transparent 1px);
            background-size: 15px 15px;
            color: white;
            padding: 40px 35px;
            position: relative;
        }

        .card-body h2 {
            margin: 0 0 5px 0;
            font-size: 22px;
            text-align: center;
            color: var(--wc-gold); /* Teks Emas */
            text-transform: uppercase;
            letter-spacing: 2px;
        }

        .card-body p {
            font-size: 13px;
            opacity: 0.8;
            margin-bottom: 25px;
            text-align: center;
            color: #ecf0f1;
        }

        .form-group {
            margin-bottom: 18px;
        }

        .form-group label {
            display: block;
            font-size: 11px;
            margin-bottom: 8px;
            text-transform: uppercase;
            letter-spacing: 1px;
            color: var(--wc-gold); /* Label aksen emas */
        }

        .input-wrapper {
            position: relative;
        }

        .input-wrapper i {
            position: absolute;
            left: 15px;
            top: 50%;
            transform: translateY(-50%);
            color: var(--wc-gold-dark); /* Ikon Emas */
        }

        .input-wrapper input {
            width: 100%;
            padding: 14px 15px 14px 45px;
            background: rgba(0, 0, 0, 0.2); /* Lebih gelap sedikit untuk kontras */
            border: 1px solid rgba(218, 165, 32, 0.4); /* Border emas samar */
            border-radius: 10px;
            color: white;
            box-sizing: border-box;
            outline: none;
            transition: 0.3s;
            font-size: 16px;
        }

        .input-wrapper input:focus {
            background: rgba(0, 0, 0, 0.4);
            border-color: var(--wc-gold);
            box-shadow: 0 0 10px rgba(255, 215, 0, 0.3); /* Glow emas saat ngetik */
        }

        /* Tombol Emas Ala Trofi World Cup */
        .btn-login {
            width: 100%;
            padding: 15px;
            background: linear-gradient(135deg, #FFD700 0%, #DAA520 100%);
            color: #111;
            border: none;
            border-radius: 10px;
            font-weight: 900;
            font-size: 15px;
            cursor: pointer;
            transition: 0.3s;
            margin-top: 10px;
            text-transform: uppercase;
            letter-spacing: 1px;
            box-shadow: 0 5px 15px rgba(218, 165, 32, 0.4);
        }

        .btn-login:hover {
            background: linear-gradient(135deg, #FFF8DC 0%, #FFD700 100%);
            transform: translateY(-3px);
            box-shadow: 0 8px 20px rgba(218, 165, 32, 0.6);
        }

        /* --- FOOTER / LINK --- */
        .card-footer {
            padding: 20px;
            text-align: center;
            background: #f1f2f6;
            font-size: 13px;
        }

        .card-footer a {
            color: var(--dark-green);
            text-decoration: none;
            font-weight: 900;
            text-transform: uppercase;
        }

        /* Info Sistem Baru */
        .setup-info {
            margin-top: 15px;
            padding: 10px;
            background: rgba(255, 215, 0, 0.1); /* Background samar emas */
            border: 1px solid rgba(255, 215, 0, 0.3);
            border-radius: 8px;
            font-size: 12px;
            color: var(--wc-gold);
            text-align: center;
        }

        /* Responsive Mobile */
        @media (max-width: 480px) {
            .login-container { width: 95%; }
            .card-header { padding: 30px 20px 15px; }
            .card-body { padding: 30px 20px; }
        }

        .forgot-password-link {
            text-align: right;
            margin-bottom: 15px;
            margin-top: -5px;
        }
        
        .forgot-password-link a {
            color: #ecf0f1;
            font-size: 11px;
            text-decoration: none;
            transition: 0.2s;
        }

        .forgot-password-link a:hover {
            color: var(--wc-gold); /* Hover emas */
            text-decoration: underline;
        }
    </style>
</head>
<body>

    <div id="loaderSistem" style="
    position: fixed;
    top: 0; left: 0;
    width: 100%; height: 100%;
    background: rgba(13, 56, 5, 0.98); /* Stadion gelap */
    z-index: 9999;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    transition: opacity 0.4s ease, visibility 0.4s ease;
">
    <div style="
        width: 60px; height: 60px;
        border: 5px solid rgba(255, 215, 0, 0.1);
        border-top: 5px solid #FFD700; /* Warna Emas */
        border-radius: 50%;
        animation: putarLoader 1s linear infinite;
        box-shadow: 0 0 15px rgba(255, 215, 0, 0.5); /* Efek glow */
    "></div>
    <p style="color: #FFD700; margin-top: 20px; font-weight: bold; font-size: 14px; letter-spacing: 2px;">
        MEMUAT SISTEM TATRIZ...
    </p>
</div>

<style>
    @keyframes putarLoader {
        0% { transform: rotate(0deg); }
        100% { transform: rotate(360deg); }
    }
    .loader-hilang {
        opacity: 0 !important;
        visibility: hidden !important;
    }
</style>

    <div class="login-container">
        <div class="login-card">
            <div class="card-header">
                <img src="/img/Tatriz SystemB.png" alt="Logo Tatriz SystemB">
                <h1>Tatriz SystemB</h1>
                <p class="tagline">Solusi digital cerdas untuk manajemen bordir profesional.</p>
            </div>

            <div class="card-body">
                <h2>Portal Masuk</h2>
                <p>Gunakan akun terdaftar Anda</p>

                <form action="/login" method="POST">
                    <div class="form-group">
                        <label>Username</label>
                        <div class="input-wrapper">
                            <i class="fas fa-user"></i>
                            <input type="text" name="username" placeholder="Username" required>
                        </div>
                    </div>
                    <div class="form-group" style="margin-bottom: 5px;">
                        <label>Password</label>
                        <div class="input-wrapper">
                            <i class="fas fa-lock"></i>
                            <input type="password" name="password" placeholder="Password" required>
                        </div>
                    </div>
                    
                    <div class="forgot-password-link">
                        <a href="#" onclick="pemicuLupaPassword()">Lupa Password?</a>
                    </div>

                    <button type="submit" class="btn-login"><i class="fas fa-futbol"></i> Masuk Sekarang</button>
                </form>
                
                <div id="areaInstalPWA" style="display: none; margin-top: 20px; padding: 15px; background: rgba(0,0,0,0.2); border: 1px dashed rgba(255,215,0,0.5); border-radius: 10px; text-align: center;">
                    <p style="margin: 0 0 10px 0; font-size: 13px; color: white; opacity: 0.9;">
                        <i class="fas fa-mobile-alt" style="color: var(--wc-gold);"></i> Akses secepat pemain andalan! Instal versi HP.
                    </p>
                    <button id="btnInstalPWA" class="btn-login" style="background: white; color: var(--dark-green); margin-top: 0; box-shadow: none;">
                        <i class="fas fa-download"></i> INSTAL APLIKASI HP
                    </button>
                </div>

                <% if (isNew) { %>
                <div class="setup-info">
                    <i class="fas fa-trophy"></i> Sistem baru siap digunakan. 
                    <a href="/register" style="color: white; text-decoration: underline; font-weight: bold;">Klik Setup Awal</a>
                </div>
                <% } %>
            </div>

            <div class="card-footer">
                Belum bergabung? <a href="/register">Daftar Perusahaan</a>
            </div>
        </div>
    </div>

    <script>
        function pemicuLupaPassword() {
        Swal.fire({
            title: 'Lupa Password?',
            html: `
                <p style="font-size: 14px;">Masukkan <b>Username</b> atau <b>Nama Toko</b> Anda agar kami bisa mencarinya.</p>
            `,
            input: 'text',
            inputPlaceholder: 'Ketik username / nama toko...',
            showCancelButton: true,
            confirmButtonColor: '#DAA520', // Warna tombol SweetAlert diubah jadi Emas agar serasi
            confirmButtonText: '<i class="fab fa-whatsapp"></i> Hubungi Developer',
            cancelButtonText: 'Batal'
        }).then((result) => {
            if (result.isConfirmed && result.value) {
                const pesan = `Halo Developer Tatriz, saya lupa password login untuk akun saya (Username/Toko: *${result.value}*). Mohon bantuannya untuk reset password sementara.`;
                const noWA = '6281315290003';
                
                window.open(`https://api.whatsapp.com/send/?phone=${noWA}&text=${encodeURIComponent(pesan)}`, '_blank');
            }
        });
    }
   let pemicuInstal;
const areaInstal = document.getElementById('areaInstalPWA');
const btnInstal = document.getElementById('btnInstalPWA');

const isAppInstalled = window.matchMedia('(display-mode: standalone)').matches || window.navigator.standalone;

if (!isAppInstalled) {
    areaInstal.style.display = 'block';
}

window.addEventListener('beforeinstallprompt', (e) => {
    e.preventDefault();
    pemicuInstal = e;
    areaInstal.style.display = 'block';
});

btnInstal.addEventListener('click', async () => {
    if (pemicuInstal) {
        pemicuInstal.prompt();
        
        const { outcome } = await pemicuInstal.userChoice;
        console.log(`Pilihan user: ${outcome}`);
        
        if (outcome === 'accepted') {
            console.log('User menginstal PWA');
        }
        pemicuInstal = null; 
    } else {
        Swal.fire({
            title: 'Cara Instal Aplikasi',
            html: `
                <div style="text-align: left; font-size: 14px;">
                    <b>Untuk Desktop (Chrome/Edge):</b><br>
                    Klik ikon <i class="fas fa-download"></i> atau komputer kecil di pojok kanan atas kolom alamat URL browser Anda.<br><br>
                    <b>Untuk iPhone/iOS (Safari):</b><br>
                    Klik tombol <b>Bagikan (Share)</b> <i class="fas fa-share-square"></i> lalu pilih <b>"Tambahkan ke Layar Utama" (Add to Home Screen)</b>.
                </div>
            `,
            icon: 'info',
            confirmButtonColor: '#DAA520' // Warna Emas juga
        });
    }
});

window.addEventListener('appinstalled', () => {
    console.log('PWA berhasil terpasang di sistem.');
    areaInstal.style.display = 'none'; 
});
    </script>
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            const loader = document.getElementById('loaderSistem');
            if (loader) {
                setTimeout(function() {
                    loader.classList.add('loader-hilang');
                }, 200);
            }
        });
        setTimeout(function() {
            const loader = document.getElementById('loaderSistem');
            if (loader && !loader.classList.contains('loader-hilang')) {
                loader.classList.add('loader-hilang');
            }
        }, 4000);
    </script>
</body>
</html>