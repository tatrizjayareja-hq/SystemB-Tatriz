<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Nota Manual - Tatriz</title>
    <style>
        /* CSS UNTUK TAMPILAN LAYAR */
        body { font-family: 'Segoe UI', sans-serif; background: #f4f7f6; padding: 15px; margin: 0; }
        .container { max-width: 600px; margin: auto; background: white; padding: 20px; border-radius: 12px; box-shadow: 0 4px 10px rgba(0,0,0,0.1); }
        .form-group { margin-bottom: 15px; }
        label { display: block; font-weight: bold; margin-bottom: 5px; font-size: 13px; }
        input { width: 100%; padding: 10px; border: 1px solid #ddd; border-radius: 8px; box-sizing: border-box; }
        table.input-table { width: 100%; border-collapse: collapse; margin-top: 10px; }
        th { text-align: left; font-size: 12px; color: #666; padding: 5px; }
        .btn { padding: 12px; border: none; border-radius: 8px; cursor: pointer; font-weight: bold; width: 100%; margin-top: 10px; }
        .btn-preview { background: #3498db; color: white; font-size: 16px; }

        /* MODAL PREVIEW */
        #modalPreview { 
            display: none; position: fixed; top: 0; left: 0; width: 100%; height: 100%; 
            background: rgba(0,0,0,0.85); z-index: 1000; overflow-y: auto; padding: 20px; 
        }
        .preview-content { 
            background: white; width: 105mm; height: 148mm; margin: auto; 
            padding: 8mm; position: relative; box-shadow: 0 0 20px rgba(0,0,0,0.5); 
            box-sizing: border-box; display: flex; flex-direction: column; overflow: hidden;
        }

        /* CSS KHUSUS CETAK */
        @media print {
            @page { size: 105mm 148mm; margin: 0; }
            body { background: none; padding: 0; margin: 0; }
            .container, .no-print { display: none !important; }
            #modalPreview { position: absolute; top: 0; left: 0; width: 100%; display: block; background: none; padding: 0; }
            .preview-content { border: none; box-shadow: none; margin: 0; width: 105mm; height: 148mm; padding: 8mm; }
        }
    </style>
</head>
<body>

<div class="container">
    <a href="/dashboard" style="text-decoration: none; color: #666; font-size: 14px;">⬅ Kembali ke Dashboard</a>
    <h2 style="margin-top: 10px; color: #2c3e50;">📝 Buat Nota Manual</h2>
    <hr>

    <div class="form-group">
        <label>Nama Customer</label>
        <input type="text" id="cust" placeholder="Nama pelanggan (Kosongkan jika Umum)">
    </div>

    <table id="tabelItem" class="input-table">
        <thead>
            <tr>
                <th>Nama Barang / Jasa</th>
                <th width="70">Qty</th>
                <th width="120">Harga</th>
            </tr>
        </thead>
        <tbody>
            <tr>
                <td><input type="text" class="nama" placeholder="Contoh: Bordir Jaket"></td>
                <td><input type="number" class="qty" value="1"></td>
                <td><input type="number" class="hrg" placeholder="Rp"></td>
            </tr>
        </tbody>
    </table>
    
    <button class="btn" style="background:#f1f2f6; border:1px dashed #ccc;" onclick="tambahBaris()">+ Tambah Baris</button>
    <button class="btn btn-preview" onclick="bukaPreview()">LIHAT PRATINJAU NOTA</button>
</div>

<div id="modalPreview">
    <div class="no-print" style="text-align: center; margin-bottom: 20px;">
        <button onclick="tutupPreview()" style="background: #e74c3c; color: white; border: none; padding: 10px 25px; border-radius: 30px; cursor: pointer; font-weight: bold;">❌ EDIT</button>
        <button onclick="window.print()" style="background: #27ae60; color: white; border: none; padding: 10px 25px; border-radius: 30px; cursor: pointer; font-weight: bold; margin-left: 15px;">🖨️ CETAK</button>
    </div>
    <div class="preview-content" id="areaCetak"></div>
</div>

<script>
    function tambahBaris() {
        const tbody = document.querySelector("#tabelItem tbody");
        const row = tbody.insertRow();
        row.innerHTML = `<td><input type="text" class="nama"></td>
                         <td><input type="number" class="qty" value="1"></td>
                         <td><input type="number" class="hrg"></td>`;
    }

    function bukaPreview() {
        const cust = document.getElementById('cust').value || "Umum";
        const rows = document.querySelectorAll("#tabelItem tbody tr");
        
        // 1. Ambil data config secara aman
        const logoPath = "/uploads/<%= config.logo_path %>"; 
        const namaToko = "<%= config.nama_perusahaan %>";
        const alamatToko = `<%= config.alamat %>`.replace(/\n/g, ' ');
        const waToko = "<%= config.no_hp %>";

        let htmlItem = "";
        let total = 0;

        rows.forEach(row => {
            const nama = row.querySelector('.nama').value;
            const qty = parseFloat(row.querySelector('.qty').value) || 0;
            const hrg = parseFloat(row.querySelector('.hrg').value) || 0;
            
            if(nama && hrg > 0) {
                const sub = qty * hrg;
                total += sub;
                htmlItem += `
                    <tr>
                        <td style="padding: 4px 0; border-bottom: 1px solid #eee; font-size: 10px;">${nama}</td>
                        <td style="text-align: center; border-bottom: 1px solid #eee; font-size: 10px;">${qty}</td>
                        <td style="text-align: right; border-bottom: 1px solid #eee; font-size: 10px;">${hrg.toLocaleString('id-ID')}</td>
                        <td style="text-align: right; border-bottom: 1px solid #eee; font-size: 10px; font-weight: bold;">${sub.toLocaleString('id-ID')}</td>
                    </tr>`;
            }
        });

        if (total === 0) return alert("Isi data barang dulu!");

        // 2. Buat Template tunggal
        const template = `
            <div style="position: relative; height: 100%; display: flex; flex-direction: column; color: #333;">
                <img src="${logoPath}" style="position: absolute; top: 50%; left: 50%; transform: translate(-50%, -50%) rotate(-30deg); opacity: 0.05; width: 180px; z-index: 0;">
                
                <div style="display: flex; align-items: center; border-bottom: 2px solid #333; padding-bottom: 8px; margin-bottom: 10px; z-index: 1;">
                    <img src="${logoPath}" style="width: 45px; height: 45px; margin-right: 10px; object-fit: contain;">
                    <div style="flex-grow:1">
                        <h2 style="margin:0; font-size: 14px; text-transform: uppercase;">${namaToko}</h2>
                        <p style="margin:1px 0; font-size: 9px;">${alamatToko}</p>
                        <p style="margin:1px 0; font-size: 9px; font-weight: bold;">WA: ${waToko}</p>
                    </div>
                </div>

                <div style="display: flex; justify-content: space-between; font-size: 11px; margin-bottom: 10px; z-index: 1;">
                    <span>Cust: <b>${cust}</b></span>
                    <span>Tgl: ${new Date().toLocaleDateString('id-ID')}</span>
                </div>

                <div style="flex-grow: 1; z-index: 1;">
                    <table style="width: 100%; border-collapse: collapse;">
                        <thead>
                            <tr style="border-bottom: 1px solid #333; text-align: left; font-size: 10px;">
                                <th>Item</th><th style="text-align:center">Qty</th><th style="text-align:right">Harga</th><th style="text-align:right">Total</th>
                            </tr>
                        </thead>
                        <tbody>${htmlItem}</tbody>
                    </table>
                </div>

                <div style="z-index: 1; margin-top: auto; border-top: 1px solid #333; padding-top: 5px;">
                    <div style="display: flex; justify-content: space-between; font-weight: bold; font-size: 13px;">
                        <span>TOTAL:</span><span>Rp ${total.toLocaleString('id-ID')}</span>
                    </div>
                    <div style="margin-top: 15px; display: flex; justify-content: space-between; font-size: 9px; text-align: center;">
                        <div style="width: 45%;">Penerima<br><br><br>( ............ )</div>
                        <div style="width: 45%;">Hormat Kami<br><br><br>( ............ )</div>
                    </div>
                </div>
            </div>
        `;

        document.getElementById('areaCetak').innerHTML = template;
        document.getElementById('modalPreview').style.display = 'block';
    }

    function tutupPreview() { document.getElementById('modalPreview').style.display = 'none'; }
</script>
</body>
</html>