<%- include('partials/header') %>
<style>
    body { font-family: 'Segoe UI', sans-serif; background: #f4f7f6; padding: 10px; }
    .card { background: white; border-radius: 12px; margin-bottom: 10px; box-shadow: 0 2px 5px rgba(0,0,0,0.05); border: none; }
    .row-pemasukan { background-color: #f0fff4 !important; }
    .row-pengeluaran { background-color: #fff5f5 !important; }
    .text-pemasukan { color: #27ae60; font-weight: bold; }
    .text-pengeluaran { color: #d63031; font-weight: bold; }
    .compact-table td, .compact-table th { padding: 4px 8px !important; font-size: 11px; }
    .sticky-top { position: sticky; top: 0; z-index: 10; background: white; }
    
    /* Style Overlay Gembok yang dipertebal (0.98) */
    .locked-overlay {
        position: absolute; 
        top: 0; left: 0;
        width: 100%; height: 100%; 
        background: rgba(245, 245, 245, 0.98); 
        backdrop-filter: blur(8px); 
        -webkit-backdrop-filter: blur(8px); 
        z-index: 20; 
        display: flex; flex-direction: column; align-items: center; 
        justify-content: center; cursor: pointer; border-radius: 12px;
    }
</style>

<div class="container-fluid" style="max-width: 900px;">
    <div class="d-flex justify-content-between align-items-center mb-2">
        <a href="/dashboard" class="text-decoration-none text-muted small">← Dashboard</a>
        <h5 class="mb-0 fw-bold">📊 Rapor Keuangan</h5>
        <a href="/input-kas" class="btn btn-success btn-sm fw-bold">+ KAS</a>
    </div>

    <form action="/laporan-kas" method="GET" class="mb-2">
        <input type="month" name="bulan" value="<%= bulanIni %>" class="form-control form-control-sm" onchange="this.form.submit()">
    </form>

    <div class="row g-2 mb-2">
        <div class="col-md-7">
            <div class="card shadow-sm mb-2" style="border-left: 5px solid #6c5ce7; position: relative; overflow: hidden;">
                <% if (!isPro) { %>
                    <div class="locked-overlay" onclick="ajakUpgrade('Analisis Profit')">
                        <i class="bi bi-lock-fill text-warning fs-3 mb-1"></i>
                        <span class="badge bg-dark" style="font-size: 8px;">Upgarde PRO Untuk Lihat Profit Bulanan</span>
                    </div>
                <% } %>

                <div class="card-body p-2">
                    <small class="fw-bold text-uppercase" style="color: #6c5ce7; font-size: 10px;">💰 Performa Owner (Nett)</small>
                    <div class="row text-center g-0 mt-1">
                        <div class="col-6">
                            <small class="text-muted d-block" style="font-size: 9px;">Hasil Kerja Mesin</small>
                            <strong style="font-size: 12px;">Rp <%= Number(nilaiProduksi || 0).toLocaleString('id-ID') %></strong>
                        </div>
                        <div class="col-6 border-start">
                            <small class="text-muted d-block" style="font-size: 9px;">Beban Operasional</small>
                            <strong class="text-danger" style="font-size: 12px;">Rp <%= (Number(totalBiaya || 0) + Number(config.beban_tetap || 0)).toLocaleString('id-ID') %></strong>
                        </div>
                    </div>

                    <div class="text-center mt-2 border-top pt-1 bg-dark rounded">
                        <small class="fw-bold text-white" style="font-size: 9px;">HAK PROFIT OWNER BULAN INI:</small>
                        <strong class="text-warning d-block" style="font-size: 18px;">
                            Rp <%= Number(estimasiProfit || 0).toLocaleString('id-ID') %>
                        </strong>
                    </div>
                </div>
            </div>

            <div class="card shadow-sm mb-2" style="border-left: 5px solid #27ae60; position: relative; overflow: hidden; background: #f9fffb;">
                <% if (!isPro) { %>
                    <div class="locked-overlay" onclick="ajakUpgrade('Analisis Akumulasi Profit')">
                        <i class="bi bi-lock-fill text-success fs-5 mb-1"></i>
                        <small class="fw-bold text-dark" style="font-size: 8px;">Rincian Tabungan Profit Locked</small>
                    </div>
                <% } %>
                <div class="card-body p-2 d-flex justify-content-between align-items-center">
                    <div>
                        <small class="fw-bold text-uppercase" style="color: #27ae60; font-size: 10px;">📈 Tabungan Jatah Profit (Akumulasi)</small>
                        <h5 class="mb-0 fw-bold" style="color: #2d3436; font-size: 13px;">Riwayat & Penarikan</h5>
                        <a href="/analisis-profit" class="text-decoration-none fw-bold" style="font-size: 10px; color: #27ae60;">LIHAT RINCIAN & LOG TARIK →</a>
                    </div>
                    <div class="text-success opacity-25">
                        <i class="bi bi-safe2-fill" style="font-size: 2rem;"></i>
                    </div>
                </div>
            </div>

            <div class="card shadow-sm" style="border-left: 5px solid #e17055; background-color: #fff9f7;">
                </div>
        </div>
        </div>

                    <div class="text-center mt-2 border-top pt-1 bg-dark rounded">
                        <small class="fw-bold text-white" style="font-size: 9px;">HAK PROFIT OWNER BULAN INI:</small>
                        <strong class="text-warning d-block" style="font-size: 18px;">
                            Rp <%= Number(estimasiProfit || 0).toLocaleString('id-ID') %>
                        </strong>
                    </div>
                </div>
            </div>

            <div class="card shadow-sm" style="border-left: 5px solid #e17055; background-color: #fff9f7;">
                <div class="card-body p-2">
                    <small class="fw-bold text-uppercase" style="color: #e17055; font-size: 10px;">🏥 Kewajiban Kas Saat Ini</small>
                    <div class="row text-center g-0 mt-1">
                        <div class="col-6">
                            <small class="text-muted d-block" style="font-size: 9px;">Sisa Hutang (Total)</small>
                            <strong class="text-danger" style="font-size: 11px;">Rp <%= Number(sisaHutangRiil || 0).toLocaleString('id-ID') %></strong>
                        </div>
                        <div class="col-6 border-start">
                            <small class="text-muted d-block" style="font-size: 9px;">Sisa Kontrakan</small>
                            <strong class="text-secondary" style="font-size: 11px;">
                                <%= sisaBebanKontrakan <= 0 ? 'LUNAS' : 'Rp ' + Number(sisaBebanKontrakan || 0).toLocaleString('id-ID') %>
                            </strong>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-5">
            <div class="card shadow-sm h-100" style="position: relative; overflow: hidden;">
                <% if (!isPro) { %>
                    <div class="locked-overlay" onclick="ajakUpgrade('Omzet Harian')">
                        <i class="bi bi-lock-fill text-primary fs-5 mb-1"></i>
                        <small class="fw-bold text-dark" style="font-size: 8px;">Omzet Harian Locked</small>
                    </div>
                <% } %>
                <div class="p-2 bg-primary text-white fw-bold" style="font-size: 10px; border-radius: 12px 12px 0 0;">
                    <i class="bi bi-calendar3"></i> OMZET HARIAN
                </div>
                <div class="table-responsive" style="max-height: 155px; overflow-y: auto;">
                    <table class="table table-sm table-hover mb-0 compact-table">
                        <tbody>
                            <% monitorHarian.forEach(m => { %>
                                <tr>
                                    <td><%= new Date(m.tanggal).toLocaleDateString('id-ID', {day:'2-digit', month:'2-digit'}) %></td>
                                    <td class="text-end fw-bold">Rp <%= Number(m.total_harian || 0).toLocaleString('id-ID') %></td>
                                </tr>
                            <% }) %>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>

    <div class="card shadow-sm mb-2" style="border-left: 5px solid #0984e3; background: #eef7ff; position: relative; overflow: hidden;">
        <% if (!isPro) { %>
            <div class="locked-overlay" onclick="ajakUpgrade('Rekap Piutang')" style="flex-direction: row; gap: 10px;">
                <span class="badge bg-primary px-3 py-2 shadow-sm"><i class="bi bi-lock-fill"></i> Buka Analisis Piutang (PRO)</span>
            </div>
        <% } %>
        <div class="card-body p-2 d-flex justify-content-between align-items-center">
            <div>
                <small class="fw-bold text-uppercase" style="color: #0984e3; font-size: 10px;">🔍 Piutang Berjalan (Akumulatif)</small>
                <h4 class="mb-0 fw-bold" style="color: #0984e3;">Rp <%= Number(piutangBerjalan || 0).toLocaleString('id-ID') %></h4>
                <p class="mb-0 text-muted" style="font-size: 9px;">Total hasil kerja mesin yang belum dibayar pelanggan.</p>
            </div>
            <div class="text-primary opacity-25">
                <i class="bi bi-person-badge-fill" style="font-size: 2.5rem;"></i>
            </div>
        </div>
    </div>

    <div class="card p-2 bg-dark text-white mb-2 shadow">
        <div class="d-flex justify-content-between align-items-center px-2">
            <small class="fw-bold" style="font-size: 10px; color: #aaa;">SALDO FISIK LACI (CASH ON HAND):</small>
            <strong class="text-warning" style="font-size: 18px;">Rp <%= Number(saldoRiil || 0).toLocaleString('id-ID') %></strong>
        </div>
    </div>

    <div class="card shadow-sm border-0 overflow-hidden">
        <div class="card-header bg-white p-2">
            <input type="text" id="liveSearch" class="form-control form-control-sm" placeholder="Cari rincian transaksi..." onkeyup="filterTabel()">
        </div>
        <div class="table-responsive" style="max-height: 400px; overflow-y: auto;">
            <table class="table table-hover align-middle mb-0" id="tabelKas" style="font-size: 12px;">
                <thead class="table-light sticky-top">
                    <tr>
                        <th style="width: 85px;">TGL</th>
                        <th>KATEGORI & KETERANGAN</th> 
                        <th class="text-end">JUMLAH</th>
                        <th class="text-center" style="width: 70px;">AKSI</th>
                    </tr>
                </thead>
                <tbody>
                    <% rincianKas.forEach(item => { %>
                        <tr class="<%= item.jenis === 'PEMASUKAN' ? 'row-pemasukan' : 'row-pengeluaran' %>">
                            <td style="font-size: 11px; white-space: nowrap;">
                                <%= item.tanggal ? new Date(item.tanggal).toLocaleDateString('id-ID', {day:'2-digit', month:'2-digit', year:'numeric'}) : '-' %>
                            </td>
                            <td>
                                <strong><%= item.kategori %></strong>
                                <% if (item.customer) { %>
                                    <span class="badge bg-info p-1" style="font-size: 9px; margin-left: 5px;"><%= item.customer %></span>
                                <% } %>
                                <br><small class="text-muted" style="font-size: 10px;"><%= item.keterangan %></small>
                            </td>
                            <td class="text-end <%= item.jenis === 'PEMASUKAN' ? 'text-pemasukan' : 'text-pengeluaran' %>">
                                <%= item.jenis === 'PEMASUKAN' ? '+' : '-' %> <%= Number(item.jumlah || 0).toLocaleString('id-ID') %>
                            </td>
                            <td class="text-center">
                                <div class="btn-group">
                                    <button class="btn btn-sm p-0 px-1" onclick="persiapanEditKas('<%= item.id %>', '<%= item.tanggal %>', '<%= item.jenis %>', '<%= item.kategori %>', '<%= item.jumlah %>', '<%= item.keterangan %>', '<%= item.po_id %>')">✏️</button>
                                    <a href="/hapus-kas/<%= item.id %>" class="btn btn-sm p-0 px-1" onclick="return confirm('Hapus transaksi?')">🗑️</a>
                                </div>
                            </td>
                        </tr>
                    <% }) %>
                </tbody>
            </table>
        </div>
    </div>
</div>

<script>
    function filterTabel() {
        let input = document.getElementById("liveSearch").value.toLowerCase();
        let rows = document.querySelectorAll("#tabelKas tbody tr");
        rows.forEach(row => {
            row.style.display = row.innerText.toLowerCase().includes(input) ? "" : "none";
        });
    }

    function persiapanEditKas(id, tgl, jenis, kat, jml, ket, poId) {
        let d = new Date(tgl);
        let formattedDate = d.toISOString().split('T')[0];
        const data = { id, tgl: formattedDate, jenis, kat, jml, ket, poId: (poId === 'null' || !poId) ? "" : poId };
        sessionStorage.setItem('editDataKas', JSON.stringify(data));
        window.location.href = '/input-kas';
    }

    function ajakUpgrade(fitur) {
        if (typeof Swal !== 'undefined') {
            Swal.fire({
                title: 'Fitur Terkunci!',
                text: 'Fitur ' + fitur + ' hanya tersedia untuk pengguna Akun PRO. Tingkatkan manajemen bordir Anda sekarang!',
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#2ecc71',
                confirmButtonText: 'Upgrade PRO Sekarang',
                cancelButtonText: 'Nanti Dulu'
            }).then((result) => {
                if (result.isConfirmed) {
                    window.open('https://wa.me/+6281315290003?text=Halo%20Admin%20Tatriz,%20saya%20tertarik%20upgrade%20PRO%20untuk%20' + fitur, '_blank');
                }
            });
        } else {
            alert("Fitur " + fitur + " hanya tersedia untuk Akun PRO.");
        }
    }
</script>
<%- include('partials/footer') %>