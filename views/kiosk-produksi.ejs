<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>Kiosk Produksi - Tatriz</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
    <style>
        body { background: #1e272e; color: #fff; font-family: 'Segoe UI', sans-serif; overflow-x: hidden; }
        .kiosk-header { background: #0fb9b1; padding: 15px 20px; box-shadow: 0 4px 6px rgba(0,0,0,0.3); }
        .po-card { background: #2d3436; border: 2px solid #636e72; border-radius: 12px; cursor: pointer; transition: 0.2s; }
        .po-card:active { transform: scale(0.98); border-color: #0fb9b1; }
        .po-title { font-size: 1.2rem; font-weight: bold; color: #0fb9b1; }
        .modal-content { background: #f5f6fa; color: #2d3436; border-radius: 15px; }
        .btn-numpad { width: 100%; height: 60px; font-size: 24px; font-weight: bold; border-radius: 10px; margin-bottom: 10px; }
        .form-select-lg { height: 60px; font-size: 1.2rem; font-weight: bold; }
    </style>
</head>
<body>

    <div class="kiosk-header d-flex justify-content-between align-items-center">
        <h4 class="mb-0 fw-bold"><i class="bi bi-display"></i> TERMINAL PRODUKSI TATRIZ</h4>
        <div id="clock" class="fs-5 fw-bold">00:00:00</div>
    </div>

    <div class="container-fluid py-4">
        <div class="row g-3">
            <% if (orders.length === 0) { %>
                <div class="col-12 text-center py-5 text-muted">
                    <i class="bi bi-inbox fs-1"></i>
                    <h4>Tidak ada antrian produksi saat ini.</h4>
                </div>
            <% } %>

            <% orders.forEach(po => { %>
                <div class="col-6 col-md-4 col-lg-3">
                    <div class="po-card p-3 h-100" onclick="bukaLoginKiosk('<%= po.id %>', '<%= po.nama_po %>')">
                        <div class="d-flex justify-content-between align-items-start mb-2">
                            <span class="badge <%= po.status === 'Produksi' ? 'bg-success' : 'bg-warning text-dark' %>">
                                <%= po.status %>
                            </span>
                            <span class="badge bg-light text-dark fw-bold border"><%= po.qty_tampil || 0 %> Pcs</span>
                        </div>
                        <div class="po-title text-truncate"><%= po.nama_po %></div>
                        <small class="text-light opacity-75 d-block text-truncate"><i class="bi bi-person"></i> <%= po.customer %></small>
                    </div>
                </div>
            <% }) %>
        </div>
    </div>

    <div class="modal fade" id="modalLoginKiosk" tabindex="-1" data-bs-backdrop="static">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content shadow-lg border-0">
                <form action="/login-kiosk" method="POST">
                    <div class="modal-header bg-primary text-white py-3">
                        <h5 class="modal-title fw-bold"><i class="bi bi-person-bounding-box"></i> Login Operator</h5>
                        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                    </div>
                    <div class="modal-body p-4">
                        <div class="text-center mb-4">
                            <small class="text-muted text-uppercase fw-bold">Pekerjaan Terpilih:</small>
                            <h4 class="fw-bold text-primary mb-0" id="display_nama_po">NAMA PO</h4>
                            <input type="hidden" name="po_id" id="input_po_id">
                        </div>

                        <div class="mb-3">
                            <label class="fw-bold text-secondary mb-2">Pilih Nama Anda:</label>
                            <select name="user_id" class="form-select form-select-lg shadow-sm" required>
                                <option value="">-- Ketuk untuk memilih --</option>
                                <% karyawan.forEach(k => { %>
                                    <option value="<%= k.id %>"><%= k.nama_lengkap.toUpperCase() %></option>
                                <% }) %>
                            </select>
                        </div>

                        <div class="mb-4">
                            <label class="fw-bold text-secondary mb-2">Masukkan Password:</label>
                            <input type="password" name="password" id="input_password" class="form-control form-select-lg shadow-sm text-center" placeholder="••••••" required>
                        </div>

                        <button type="submit" class="btn btn-primary w-100 py-3 fs-5 fw-bold shadow">
                            MASUK & INPUT HASIL <i class="bi bi-arrow-right-circle ms-2"></i>
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        // Jam Digital Realtime
        setInterval(() => {
            const now = new Date();
            document.getElementById('clock').innerText = now.toLocaleTimeString('id-ID');
        }, 1000);

        function bukaLoginKiosk(poId, namaPo) {
            document.getElementById('display_nama_po').innerText = namaPo;
            document.getElementById('input_po_id').value = poId;
            document.getElementById('input_password').value = ''; // Kosongkan password sisa orang sebelumnya
            new bootstrap.Modal(document.getElementById('modalLoginKiosk')).show();
        }
    </script>
</body>
</html>