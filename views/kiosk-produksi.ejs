<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>Terminal Produksi - <%= config.nama_perusahaan %></title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
    <style>
        body { background: #1e272e; color: #fff; font-family: 'Segoe UI', sans-serif; overflow-x: hidden; padding-bottom: 30px; user-select: none; -webkit-user-select: none; }
        
        .kiosk-header { background: #0a463c; padding: 15px 20px; box-shadow: 0 4px 10px rgba(0,0,0,0.5); border-bottom: 3px solid #0fb9b1; }
        .logo-img { height: 40px; background: white; padding: 4px; border-radius: 6px; }
        
        .po-card { 
            background: #2d3436; 
            border-left: 6px solid #636e72;
            border-radius: 12px; transition: 0.2s; 
            overflow: hidden;
            box-shadow: 0 4px 6px rgba(0,0,0,0.2);
        }
        
        .po-card-header { padding: 15px; cursor: pointer; transition: 0.2s; }
        .po-card-header:active { background: rgba(255,255,255,0.05); }
        
        .po-card.new { border-left-color: #0fb9b1; }   
        .po-card.under { border-left-color: #f39c12; } 
        .po-card.done { border-left-color: #2ecc71; }  
        .po-card.over { border-left-color: #ff4757; }  

        .po-title { font-size: 1.15rem; font-weight: bold; color: #fff; line-height: 1.3; }
        
        .collapse-area {
            background: #1e272e; 
            padding: 15px;
            border-top: 1px solid #636e72;
            box-shadow: inset 0 5px 10px rgba(0,0,0,0.2);
        }
        .sub-item {
            background: #f5f6fa;
            color: #2f3640;
            padding: 12px 15px;
            border-radius: 8px;
            margin-bottom: 10px;
            cursor: pointer;
            border-left: 4px solid #0fb9b1;
            transition: 0.2s;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }
        .sub-item:active { transform: scale(0.95); background: #dcdde1; }
        .sub-item:last-child { margin-bottom: 0; }

        .modal-content { background: #f5f6fa; color: #2d3436; border-radius: 15px; }
        .form-select-lg, .form-control-lg { height: 55px; font-size: 1.1rem; font-weight: bold; border-radius: 10px;}
        
        .blink-warn { animation: blinker 1.2s linear infinite; }
        @keyframes blinker { 50% { opacity: 0.4; } }

        /* Global Quick Loader Integration */
        #quickLoader {
            position: fixed; top: 0; left: 0; width: 100%; height: 100%;
            background: rgba(0, 0, 0, 0.7); backdrop-filter: blur(4px); -webkit-backdrop-filter: blur(4px);
            z-index: 99999; display: flex; justify-content: center; align-items: center;
            opacity: 0; visibility: hidden; transition: opacity 0.2s ease-in-out;
        }
        #quickLoader.show { opacity: 1; visibility: visible; }
    </style>
</head>
<body>

    <body>
    <% 
        let targetHarianDB = parseFloat(config.target_omzet_harian) || 1000000;
        let totalNilaiAntrian = 0;
        orders.forEach(po => {
            totalNilaiAntrian += parseFloat(po.total_harga_customer || 0);
        });
        
        let estimasiHariGlobal = Math.ceil(totalNilaiAntrian / targetHarianDB); 
        
        let tglSelesaiGlobal = new Date();
        tglSelesaiGlobal.setDate(tglSelesaiGlobal.getDate() + estimasiHariGlobal);
        
        let d = tglSelesaiGlobal.getDate().toString().padStart(2, '0');
        let m = (tglSelesaiGlobal.getMonth() + 1).toString().padStart(2, '0');
        let y = tglSelesaiGlobal.getFullYear();
        let teksTanggalSelesai = `${d}/${m}/${y}`;
    %>

    <div id="quickLoader">
        <div class="spinner-border text-primary" style="width: 3rem; height: 3rem;" role="status"></div>
    </div>

    <div class="kiosk-header d-flex justify-content-between align-items-center flex-wrap gap-2 sticky-top">
        <div class="d-flex align-items-center gap-3">
            <% if (config.logo_path) { %>
                <img src="<%= config.logo_path %>" alt="Logo" class="logo-img shadow-sm">
            <% } %>
            <h5 class="mb-0 fw-bold d-none d-sm-block text-light" style="letter-spacing: 1px;">TERMINAL MESIN</h5>
            <h6 class="mb-0 fw-bold d-block d-sm-none text-light">KIOSK PRODUKSI</h6>
        </div>
        <div class="d-flex align-items-center gap-2">
        <div class="fs-6 fw-bold bg-warning text-dark px-3 py-1 rounded shadow-sm border border-light">
            <i class="bi bi-flag-fill"></i> Selesai: <%= teksTanggalSelesai %>
        </div>
        <button onclick="toggleKioskFullscreen()" class="btn btn-sm btn-outline-light border-secondary"><i class="bi bi-fullscreen"></i></button>
        <div id="clock" class="fs-6 fw-bold bg-dark px-3 py-1 rounded border border-secondary text-info font-monospace">00:00:00</div>
    </div>

    <% if (!details || details.length === 0) { %>
        <div class="alert alert-danger m-3 fw-bold text-center">
            <i class="bi bi-exclamation-triangle-fill fs-4 d-block mb-2"></i>
            ERROR SISTEM: Data rincian desain (PO Detail) gagal dikirim dari Server!
        </div>
    <% } %>

    <div class="container-fluid py-3 px-3 px-md-4">
        <div class="row g-3">
            <% if (orders.length === 0) { %>
                <div class="col-12 text-center py-5 text-muted">
                    <i class="bi bi-inbox fs-1"></i>
                    <h5 class="mt-3">Mesin kosong. Tidak ada antrian produksi saat ini.</h5>
                </div>
            <% } %>

            <% orders.forEach(po => { 
                let cardState = "new";
                if (po.is_over) cardState = "over";
                else if (po.is_under) cardState = "under";
                else if (po.is_empty) cardState = "new";
                else cardState = "done";

                let percent = 0;
                let qtyTotal = parseInt(po.qty_tampil) || 0;
                let setorTotal = parseInt(po.total_setor) || 0;
                
                if (qtyTotal > 0) {
                    percent = Math.round((setorTotal / qtyTotal) * 100);
                    if (percent > 100) percent = 100;
                }
            %>
                <div class="col-12 col-md-6 col-lg-4 align-self-start">
                    <div class="po-card <%= cardState %> shadow-sm">
                        <div class="po-card-header" data-bs-toggle="collapse" data-bs-target="#collapsePO_<%= po.id %>" aria-expanded="false">
                            <div class="d-flex justify-content-between align-items-center mb-2">
                                <div class="d-flex gap-1">
                                    <span class="badge <%= po.status === 'Produksi' ? 'bg-success' : 'bg-secondary text-white' %> px-2 py-1 shadow-sm">
                                        <i class="bi <%= po.status === 'Produksi' ? 'bi-play-fill' : 'bi-pause-fill' %>"></i> <%= po.status %>
                                    </span>
                                    <span class="badge bg-warning text-dark fw-bold shadow-sm" style="border: 1px solid #d35400;">
                                        <i class="bi bi-list-ol"></i> URUTAN #<%= index + 1 %>
                                    </span>
                                </div>
                                <span class="badge bg-light text-dark fw-bold border"><%= qtyTotal %> Pcs</span>
                            </div>
                            
                            <div class="po-title text-truncate mb-1"><%= po.nama_po %></div>
                            <small class="text-light opacity-75 d-block text-truncate mb-3"><i class="bi bi-person-fill text-info"></i> <%= po.customer %></small>
                            
                            <div class="d-flex justify-content-between align-items-end" style="font-size: 11px;">
                                <span class="text-white-50">Total Mesin:<br><strong class="text-white" style="font-size: 14px;"><%= setorTotal %> / <%= qtyTotal %></strong></span>
                                
                                <div class="text-end">
                                    <% if (po.is_over) { %>
                                        <span class="text-danger fw-bold blink-warn bg-danger bg-opacity-25 px-2 py-1 rounded border border-danger"><i class="bi bi-exclamation-triangle-fill"></i> ADA LEBIH</span>
                                    <% } else if (po.is_under) { %>
                                        <span class="text-warning fw-bold"><i class="bi bi-exclamation-circle-fill"></i> MASIH KURANG</span>
                                    <% } else if (po.is_empty) { %>
                                        <span class="text-info fw-bold opacity-75"><i class="bi bi-clock"></i> BELUM KERJA</span>
                                    <% } else { %>
                                        <span class="text-success fw-bold"><i class="bi bi-check-circle-fill"></i> LENGKAP</span>
                                    <% } %>
                                    <br><small class="text-white-50"><i class="bi bi-chevron-down mt-1"></i> Ketuk rincian</small>
                                </div>
                            </div>
                            
                            <div class="progress mt-2" style="height: 5px; background: #636e72;">
                                <div class="progress-bar <%= cardState === 'over' ? 'bg-danger' : (cardState === 'under' ? 'bg-warning' : (cardState === 'done' ? 'bg-success' : 'bg-info')) %>" 
                                     role="progressbar" style="width: <%= percent + '%' %>;"></div>
                            </div>
                        </div>

                        <div class="collapse" id="collapsePO_<%= po.id %>">
                            <div class="collapse-area">
                                <div class="text-center mb-2">
                                    <small class="text-info fw-bold text-uppercase" style="font-size: 10px; letter-spacing: 1px;">PILIH DESAIN UNTUK DIKERJAKAN</small>
                                </div>

                                <% 
                                    const subItems = details.filter(d => d.po_id == po.id); 
                                    if (subItems.length === 0) { 
                                %>
                                    <div class="alert alert-danger text-center small p-2 mb-0 border border-danger">
                                        <i class="bi bi-exclamation-circle-fill"></i> Data detail kosong/tidak ditemukan!
                                    </div>
                                <%  } else { 
                                        subItems.forEach(sub => {
                                            let warnaTeks = "text-success";
                                            let targetPcs = parseInt(sub.jumlah) || 0;     
                                            let sudahSetor = parseInt(sub.total_produksi) || 0; 
                                            let sisa = targetPcs - sudahSetor;
                                            
                                            if(sisa < 0) warnaTeks = "text-danger blink-warn"; 
                                            else if(sisa > 0) warnaTeks = "text-warning"; 
                                            else warnaTeks = "text-success"; 

                                            let poAman = po.nama_po ? po.nama_po.replace(/'/g, "\\'") : "";
                                            let desainAman = sub.nama_desain ? sub.nama_desain.replace(/'/g, "\\'") : "";
                                %>
                                    <div class="sub-item shadow-sm" onclick="bukaLoginKiosk('<%= po.id %>', '<%= poAman %>', '<%= sub.id %>', '<%= desainAman %>')">
                                        <div>
                                            <strong class="d-block text-dark" style="font-size: 14px;"><%= sub.nama_desain %></strong>
                                            <small class="text-muted"><%= sub.jenis_bordir %></small>
                                        </div>
                                        <div class="text-end">
                                            <span class="badge bg-dark text-white fw-bold mb-1"><%= sudahSetor %> / <%= targetPcs %></span><br>
                                            <small class="<%= warnaTeks %> fw-bold" style="font-size: 10px;">
                                                <%= sisa < 0 ? 'LEBIHAN +' + Math.abs(sisa) : (sisa === 0 ? '✔ LENGKAP' : 'SISA ' + sisa) %>
                                            </small>
                                        </div>
                                    </div>
                                <%      }); 
                                    } 
                                %>
                            </div>
                        </div>
                    </div>
                </div>
            <% }) %>
        </div>
    </div>

    <div class="modal fade" id="modalLoginKiosk" tabindex="-1" data-bs-backdrop="static">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content shadow-lg border-0">
                <form action="/login-kiosk" method="POST" onsubmit="tampilkanLoaderGlobal()">
                    <div class="modal-header bg-dark text-white py-3 border-bottom border-4 border-primary">
                        <h5 class="modal-title fw-bold"><i class="bi bi-person-bounding-box text-primary"></i> IDENTIFIKASI OPERATOR</h5>
                        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                    </div>
                    <div class="modal-body p-4 bg-white">
                        <div class="text-center mb-4 p-3 bg-light rounded border border-secondary border-opacity-25">
                            <small class="text-muted text-uppercase fw-bold d-block mb-1">Mengerjakan:</small>
                            <h4 class="fw-bold text-dark mb-0" id="display_nama_po">NAMA PO</h4>
                            <p class="text-primary fw-bold mb-0 mt-1" id="display_nama_desain" style="font-size: 14px;"></p>
                            
                            <input type="hidden" name="po_id" id="input_po_id">
                            <input type="hidden" name="detail_id" id="input_detail_id">
                        </div>

                        <div class="mb-3">
                            <label class="fw-bold text-secondary mb-2 small text-uppercase">1. Pilih Nama Anda:</label>
                            <select name="user_id" class="form-select form-select-lg shadow-sm border-secondary border-opacity-50" required>
                                <option value="">-- Sentuh untuk mencari nama --</option>
                                <% karyawan.forEach(k => { %>
                                    <option value="<%= k.id %>"><%= k.nama_lengkap.toUpperCase() %></option>
                                <% }) %>
                            </select>
                        </div>

                        <div class="mb-4">
                            <label class="fw-bold text-secondary mb-2 small text-uppercase">2. Masukkan Password / PIN:</label>
                            <input type="password" name="password" id="input_password" class="form-control form-control-lg shadow-sm text-center border-secondary border-opacity-50" placeholder="••••••" required>
                        </div>

                        <button type="submit" class="btn btn-primary w-100 py-3 fs-5 fw-bold shadow-sm rounded-3">
                            MASUK & INPUT HASIL <i class="bi bi-arrow-right-circle-fill ms-2"></i>
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        // Jam digital
        setInterval(() => {
            const now = new Date();
            document.getElementById('clock').innerText = now.toLocaleTimeString('id-ID', { hour12: false });
        }, 1000);

        function bukaLoginKiosk(poId, namaPo, detailId, namaDesain) {
            document.getElementById('display_nama_po').innerText = namaPo;
            document.getElementById('display_nama_desain').innerText = "Item: " + namaDesain;
            
            document.getElementById('input_po_id').value = poId;
            document.getElementById('input_detail_id').value = detailId;
            
            document.getElementById('input_password').value = ''; 
            new bootstrap.Modal(document.getElementById('modalLoginKiosk')).show();
        }

        function tampilkanLoaderGlobal() {
            const loader = document.getElementById('quickLoader');
            if (loader) loader.classList.add('show');
        }

        // ==========================================
        // 🔒 SISTEM PENGUNCI NAVIGASI KIOSK (ANTI-ESCAPE)
        // ==========================================
        
        // 1. Mencegah aksi klik kanan & tahan layar di tablet (memblokir inspeksi menu peramban)
        document.addEventListener('contextmenu', event => event.preventDefault());

        // 2. Perangkap tombol BACK (History Trap)
        function kunciRiwayatBrowser() {
            window.history.pushState({ noBackExits: true }, "");
        }

        // Paksakan status awal saat sistem dimuat
        kunciRiwayatBrowser();

        // Tangkap setiap kali operator mencoba menekan tombol kembali fisik di perangkat
        window.addEventListener('popstate', function (event) {
            // Suntikkan kembali riwayat palsu ke depan agar posisi navigasi terkunci di tempat
            kunciRiwayatBrowser();
            
            // Beri notifikasi peringatan halus tanpa mengganggu estetika antarmuka
            if (typeof Swal !== 'undefined') {
                Swal.fire({
                    title: 'Akses Terkunci',
                    text: 'Gunakan tombol internal aplikasi untuk berpindah halaman.',
                    icon: 'info',
                    toast: true,
                    position: 'top-end',
                    showConfirmButton: false,
                    timer: 2500
                });
            }
        });

        // 3. Fitur Layar Penuh Otomatis (Fullscreen Kiosk Mode)
        function toggleKioskFullscreen() {
            const doc = window.document;
            const docEl = doc.documentElement;

            const requestFullscreen = docEl.requestFullscreen || docEl.mozRequestFullScreen || docEl.webkitRequestFullScreen || docEl.msRequestFullscreen;
            const exitFullscreen = doc.exitFullscreen || doc.mozCancelFullScreen || doc.webkitExitFullscreen || doc.msExitFullscreen;

            if (!doc.fullscreenElement && !doc.mozFullScreenElement && !doc.webkitFullscreenElement && !doc.msFullscreenElement) {
                requestFullscreen.call(docEl);
            } else {
                exitFullscreen.call(doc);
            }
        }
    </script>
</body>
</html>