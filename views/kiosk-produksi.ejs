<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>Kiosk Produksi - <%= config.nama_perusahaan %></title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
    <style>
        body { background: #1e272e; color: #fff; font-family: 'Segoe UI', sans-serif; overflow-x: hidden; padding-bottom: 30px;}
        
        /* Header & Logo */
        .kiosk-header { background: #0a463c; padding: 15px 20px; box-shadow: 0 4px 10px rgba(0,0,0,0.5); border-bottom: 3px solid #0fb9b1; }
        .logo-img { height: 40px; background: white; padding: 4px; border-radius: 6px; }
        
        /* Kartu PO Dinamis */
        .po-card { 
            background: #2d3436; 
            border-left: 6px solid #636e72;
            border-radius: 12px; cursor: pointer; transition: 0.2s; 
            position: relative; overflow: hidden;
            box-shadow: 0 4px 6px rgba(0,0,0,0.2);
        }
        .po-card:active { transform: scale(0.97); }
        
        /* Aksen Warna Berdasarkan Progres Kerja */
        .po-card.new { border-left-color: #0fb9b1; }    /* Belum Mulai */
        .po-card.under { border-left-color: #f39c12; }  /* Kurang (Kuning) */
        .po-card.done { border-left-color: #2ecc71; }   /* Pas / Lengkap (Hijau) */
        .po-card.over { border-left-color: #ff4757; }   /* Lebih (Merah) */

        .po-title { font-size: 1.15rem; font-weight: bold; color: #fff; line-height: 1.3; }
        .modal-content { background: #f5f6fa; color: #2d3436; border-radius: 15px; }
        .form-select-lg, .form-control-lg { height: 55px; font-size: 1.1rem; font-weight: bold; border-radius: 10px;}
        
        /* Animasi Berkedip */
        .blink-warn { animation: blinker 1.2s linear infinite; }
        @keyframes blinker { 50% { opacity: 0.4; } }
    </style>
</head>
<body>

    <div class="kiosk-header d-flex justify-content-between align-items-center flex-wrap gap-2 sticky-top">
        <div class="d-flex align-items-center gap-3">
            <% if (config.logo_path) { %>
                <img src="<%= config.logo_path %>" alt="Logo" class="logo-img shadow-sm">
            <% } %>
            <h5 class="mb-0 fw-bold d-none d-sm-block text-light" style="letter-spacing: 1px;">TERMINAL PRODUKSI</h5>
            <h6 class="mb-0 fw-bold d-block d-sm-none text-light">KIOSK PRODUKSI</h6>
        </div>
        <div id="clock" class="fs-6 fw-bold bg-dark px-3 py-1 rounded border border-secondary text-info font-monospace">00:00:00</div>
    </div>

    <div class="container-fluid py-3 px-3 px-md-4">
        <div class="row g-3">
            <% if (orders.length === 0) { %>
                <div class="col-12 text-center py-5 text-muted">
                    <i class="bi bi-inbox fs-1"></i>
                    <h5 class="mt-3">Mesin kosong. Tidak ada antrian produksi saat ini.</h5>
                </div>
            <% } %>

            <% orders.forEach(po => { 
                let cardState = "new";
                let percent = 0;
                
                if (po.qty_tampil > 0) {
                    percent = Math.round((po.total_setor / po.qty_tampil) * 100);
                    if (percent > 100) percent = 100;
                    
                    if (po.total_setor > po.qty_tampil) {
                        cardState = "over";
                    } else if (po.total_setor > 0 && po.total_setor < po.qty_tampil) {
                        cardState = "under";
                    } else if (po.total_setor == po.qty_tampil && po.qty_tampil > 0) {
                        cardState = "done";
                    }
                }
            %>
                <div class="col-12 col-md-6 col-lg-3">
                    <div class="po-card <%= cardState %> p-3 h-100" onclick="bukaLoginKiosk('<%= po.id %>', '<%= po.nama_po %>')">
                        <div class="d-flex justify-content-between align-items-center mb-2">
                            <span class="badge <%= po.status === 'Produksi' ? 'bg-success' : 'bg-secondary text-white' %> px-2 py-1">
                                <i class="bi <%= po.status === 'Produksi' ? 'bi-play-fill' : 'bi-pause-fill' %>"></i> <%= po.status %>
                            </span>
                            <span class="badge bg-light text-dark fw-bold border"><%= po.qty_tampil || 0 %> Pcs</span>
                        </div>
                        
                        <div class="po-title text-truncate mb-1"><%= po.nama_po %></div>
                        <small class="text-light opacity-75 d-block text-truncate mb-3"><i class="bi bi-person-fill text-info"></i> <%= po.customer %></small>
                        
                        <div class="d-flex justify-content-between align-items-end" style="font-size: 11px;">
                            <span class="text-white-50">Terkumpul:<br><strong class="text-white" style="font-size: 14px;"><%= po.total_setor %> Pcs</strong></span>
                            
                            <% if (cardState === 'over') { %>
                                <span class="text-danger fw-bold blink-warn bg-danger bg-opacity-25 px-2 py-1 rounded border border-danger">LEBIH <%= po.total_setor - po.qty_tampil %></span>
                            <% } else if (cardState === 'under') { %>
                                <span class="text-warning fw-bold">SISA <%= po.qty_tampil - po.total_setor %></span>
                            <% } else if (cardState === 'done') { %>
                                <span class="text-success fw-bold"><i class="bi bi-check-all"></i> LENGKAP</span>
                            <% } else { %>
                                <span class="text-info fw-bold opacity-75">BELUM MULAI</span>
                            <% } %>
                        </div>
                        
                        <div class="progress mt-2" style="height: 5px; background: #636e72;">
                            <div class="progress-bar <%= cardState === 'over' ? 'bg-danger' : (cardState === 'under' ? 'bg-warning' : (cardState === 'done' ? 'bg-success' : 'bg-info')) %>" 
                                 role="progressbar" style="width: <%= percent + '%' %>;"></div>
                        </div>
                    </div>
                </div>
            <% }) %>
        </div>
    </div>

    <div class="modal fade" id="modalLoginKiosk" tabindex="-1" data-bs-backdrop="static">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content shadow-lg border-0">
                <form action="/login-kiosk" method="POST">
                    <div class="modal-header bg-dark text-white py-3 border-bottom border-4 border-primary">
                        <h5 class="modal-title fw-bold"><i class="bi bi-person-bounding-box text-primary"></i> IDENTIFIKASI OPERATOR</h5>
                        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                    </div>
                    <div class="modal-body p-4 bg-white">
                        <div class="text-center mb-4 p-3 bg-light rounded border border-secondary border-opacity-25">
                            <small class="text-muted text-uppercase fw-bold d-block mb-1">Mengerjakan Pesanan:</small>
                            <h4 class="fw-bold text-dark mb-0" id="display_nama_po">NAMA PO</h4>
                            <input type="hidden" name="po_id" id="input_po_id">
                        </div>

                        <div class="mb-3">
                            <label class="fw-bold text-secondary mb-2 small text-uppercase">1. Pilih Nama Anda:</label>
                            <select name="user_id" class="form-select form-select-lg shadow-sm border-secondary border-opacity-50" required>
                                <option value="">-- Sentuh untuk mencari nama --</option>
                                <% karyawan.forEach(k => { %>
                                    <option value="<%= k.id %>"><%= k.nama_lengkap.toUpperCase() %></option>
                                <% }) %>
                            </select>
                        </div>

                        <div class="mb-4">
                            <label class="fw-bold text-secondary mb-2 small text-uppercase">2. Masukkan Password / PIN:</label>
                            <input type="password" name="password" id="input_password" class="form-control form-control-lg shadow-sm text-center border-secondary border-opacity-50" placeholder="••••••" required>
                        </div>

                        <button type="submit" class="btn btn-primary w-100 py-3 fs-5 fw-bold shadow-sm rounded-3">
                            MASUK & INPUT HASIL <i class="bi bi-arrow-right-circle-fill ms-2"></i>
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        // Jam Digital Realtime
        setInterval(() => {
            const now = new Date();
            document.getElementById('clock').innerText = now.toLocaleTimeString('id-ID', { hour12: false });
        }, 1000);

        function bukaLoginKiosk(poId, namaPo) {
            document.getElementById('display_nama_po').innerText = namaPo;
            document.getElementById('input_po_id').value = poId;
            document.getElementById('input_password').value = ''; 
            new bootstrap.Modal(document.getElementById('modalLoginKiosk')).show();
        }
    </script>
</body>
</html>