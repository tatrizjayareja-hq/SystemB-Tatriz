<%- include('../partials/header') %>

<div class="container-fluid mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h4><i class="bi bi-box-seam"></i> Manajemen Pesanan (PO)</h4>
        <div class="d-flex gap-2">
            <a href="/dashboard" class="btn btn-outline-secondary btn-sm">
                <i class="bi bi-arrow-left"></i> Dashboard
            </a>
            <a href="/po-baru" class="btn btn-success btn-sm fw-bold">
                <i class="bi bi-plus-lg"></i> INPUT PO BARU
            </a>
        </div>
    </div>

    <div id="bulkActionArea" class="alert alert-success d-none justify-content-between align-items-center shadow-sm">
        <div>
            <strong id="countSelected" class="text-success">0 PO Terpilih</strong>
            <small class="text-muted ms-2">(Hanya untuk customer yang sama)</small>
        </div>
        <button onclick="prosesNotaGabungan()" class="btn btn-dark btn-sm fw-bold">
            <i class="bi bi-file-earmark-pdf"></i> BUAT NOTA GABUNGAN
        </button>
    </div>

    <div class="card shadow-sm border-0 mb-4">
        <div class="card-body">
            <div class="row g-3 align-items-end">
                <div class="col-md-4">
                    <label class="form-label small fw-bold text-muted">Cari Nama PO / Customer</label>
                    <input type="text" id="liveSearch" class="form-control" placeholder="Ketik nama..." onkeyup="jalankanFilter()">
                </div>
                <div class="col-md-3">
                    <label class="form-label small fw-bold text-muted">Filter Status</label>
                    <select id="filterStatus" class="form-select" onchange="jalankanFilter()">
                        <option value="ALL">-- Semua Status --</option>
                        <option value="Design">Design</option>
                        <option value="Produksi">Produksi</option>
                        <option value="CMT">CMT (Luar)</option>
                        <option value="QC">QC</option>
                        <option value="Clear">Clear</option>
                        <option value="DP/Cicil">DP/Cicil</option>
                        <option value="Lunas">Lunas</option>
                    </select>
                </div>
                <div class="col-md-3">
                    <div class="form-check mb-2">
                        <input class="form-check-input" type="checkbox" id="checkLunas" onchange="sinkronLunas(this)">
                        <label class="form-check-label small fw-bold" for="checkLunas">
                            Auto-Hide Lunas
                        </label>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="card shadow-sm border-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0" style="font-size: 13px;">
                <thead class="table-primary text-uppercase">
                    <tr>
                        <th class="text-center" style="width: 40px;">#</th>
                        <th>Tanggal</th>
                        <th>Data Pesanan (PO)</th>
                        <th class="text-center">Total Qty</th>
                        
                        <% if (user.tenantId === 1 || user.tenantLevel >= 2) { %>
                            <th class="text-end">Total Op</th>
                        <% } %>

                        <th class="text-end">Total Cust</th>
                        <th class="text-center">Status</th>
                        <th class="text-center">Aksi</th>
                    </tr>
                </thead>
                <tbody id="bodyPO">
                    <% orders.forEach(function(po) { %>
                        <tr class="clickable-row" style="cursor: pointer;" onclick="toggleDetail('<%= po.id %>')">
                            <td class="text-center" onclick="event.stopPropagation()">
                                <input type="checkbox" class="form-check-input po-checkbox" value="<%= po.id %>" data-customer="<%= po.customer %>" onchange="updateCounter()">
                            </td>
                            <td class="text-muted"><%= po.tanggal.split('-').reverse().join('/') %></td>
                            <td>
                                <strong class="text-dark"><%= po.nama_po %></strong><br>
                                <small class="text-muted"><i class="bi bi-person"></i> <%= po.customer %></small>
                            </td>
                            <td class="text-center">
                                <span class="badge bg-light text-dark border">
                                    <%= (po.qty_tampil || 0) %> Pcs
                                </span>
                                <% if (po.variasi_jumlah > 1) { %>
                                    <br><span class="badge bg-warning text-dark mt-1" style="font-size: 9px;">Multiple Items</span>
                                <% } %>
                            </td>

                            <% if (user.tenantId === 1 || user.tenantLevel >= 2) { %>
                                <td class="text-end fw-bold">Rp <%= (po.total_harga_operator || 0).toLocaleString('id-ID') %></td>
                            <% } %>

                            <td class="text-end fw-bold text-success">Rp <%= (po.total_harga_customer || 0).toLocaleString('id-ID') %></td>
                            
                            <td onclick="event.stopPropagation()">
                                <form action="/update-status/<%= po.id %>" method="POST" class="d-flex gap-1">
                                    <select name="status_baru" class="form-select form-select-sm" style="width: 110px; font-size: 11px;">
                                        <option value="Design" <%= po.status === 'Design' ? 'selected' : '' %>>Design</option>
                                        <option value="Produksi" <%= po.status === 'Produksi' ? 'selected' : '' %>>Produksi</option>
                                        <option value="CMT" <%= po.status === 'CMT' ? 'selected' : '' %>>CMT</option>
                                        <option value="QC" <%= po.status === 'QC' ? 'selected' : '' %>>QC</option>
                                        <option value="Clear" <%= po.status === 'Clear' ? 'selected' : '' %>>Clear</option>
                                        <option value="DP/Cicil" <%= po.status === 'DP/Cicil' ? 'selected' : '' %>>DP/Cicil</option>
                                        <option value="Lunas" <%= po.status === 'Lunas' ? 'selected' : '' %>>Lunas</option>
                                    </select>
                                    <button type="submit" class="btn btn-sm btn-primary"><i class="bi bi-save"></i></button>
                                </form>
                            </td>

                            <td class="text-center" onclick="event.stopPropagation()">
                                <div class="btn-group">
                                    <button type="button" class="btn btn-sm btn-outline-dark dropdown-toggle" data-bs-toggle="dropdown">
                                        Opsi
                                    </button>
                                    <ul class="dropdown-menu dropdown-menu-end shadow" style="font-size: 13px;">
                                        <li><button class="dropdown-item" onclick="toggleDetail('<%= po.id %>')"><i class="bi bi-eye"></i> Lihat Rincian</button></li>
                                        <li><a class="dropdown-item" href="/edit-po/<%= po.id %>"><i class="bi bi-pencil text-warning"></i> Edit Data PO</a></li>
                                        <li><hr class="dropdown-divider"></li>
                                        <li><a class="dropdown-item" href="/cetak-nota/<%= po.id %>" target="_blank"><i class="bi bi-printer"></i> Nota A6</a></li>
                                        <li><a class="dropdown-item" href="/cetak-nota-rinci/<%= po.id %>" target="_blank"><i class="bi bi-card-list"></i> Nota Rinci</a></li>
                                        <li><hr class="dropdown-divider"></li>
                                        <li><a class="dropdown-item text-danger" href="/delete-po/<%= po.id %>" onclick="return confirm('Hapus PO ini?')"><i class="bi bi-trash"></i> Hapus PO</a></li>
                                    </ul>
                                </div>
                            </td>
                        </tr>

                        <tr id="detail-<%= po.id %>" class="detail-row d-none">
                            <td colspan="8" class="bg-light p-3">
                                <div class="card card-body border-0 shadow-sm">
                                    <h6 class="fw-bold mb-3"><i class="bi bi-info-circle"></i> Rincian Item Bordir</h6>
                                    <table class="table table-sm table-bordered bg-white mb-0">
                                        <thead class="table-light">
                                            <tr class="text-center" style="font-size: 12px;">
                                                <th>Jenis</th>
                                                <th>Nama Desain</th>
                                                <th>Qty</th>
                                                <% if (user.tenantId === 1 || user.tenantLevel >= 2) { %>
                                                    <th class="text-end">Harga Op</th>
                                                    <th class="text-end">Total Op</th>
                                                <% } %>
                                                <th class="text-end">Harga Cust</th>
                                                <th class="text-end">Total Cust</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            <% details.forEach(function(sub) { %>
                                                <% if (sub.po_id === po.id) { %>
                                                    <tr style="font-size: 12px;">
                                                        <td><%= sub.jenis_bordir %></td>
                                                        <td class="fw-bold"><%= sub.nama_desain %></td>
                                                        <td class="text-center"><%= sub.jumlah %> Pcs</td>
                                                        <% if (user.tenantId === 1 || user.tenantLevel >= 2) { %>
                                                            <td class="text-end">Rp <%= (sub.harga_operator || 0).toLocaleString('id-ID') %></td>
                                                            <td class="text-end fw-bold">Rp <%= ((sub.jumlah || 0) * (sub.harga_operator || 0)).toLocaleString('id-ID') %></td>
                                                        <% } %>
                                                        <td class="text-end">Rp <%= (sub.harga_customer || 0).toLocaleString('id-ID') %></td>
                                                        <td class="text-end fw-bold text-success">Rp <%= ((sub.jumlah || 0) * (sub.harga_customer || 0)).toLocaleString('id-ID') %></td>
                                                    </tr>
                                                <% } %>
                                            <% }); %>
                                        </tbody>
                                    </table>
                                </div>
                            </td>
                        </tr>
                    <% }); %>
                </tbody>
            </table>
        </div>
    </div>
</div>

<script>
    // Fitur Toggle Detail Row
    function toggleDetail(id) {
        const row = document.getElementById('detail-' + id);
        row.classList.toggle('d-none');
    }

    // Fitur Filter & Pencarian
    function jalankanFilter() {
        let inputNama = document.getElementById("liveSearch").value.toLowerCase();
        let inputStatus = document.getElementById("filterStatus").value;
        let hideLunas = document.getElementById("checkLunas").checked;

        // Simpan state ke LocalStorage agar tidak hilang saat refresh
        localStorage.setItem('filterNama', inputNama);
        localStorage.setItem('filterStatus', inputStatus);
        localStorage.setItem('hideLunas', hideLunas);

        let rows = document.querySelectorAll("#bodyPO tr.clickable-row");
        rows.forEach(row => {
            let textContent = row.innerText.toLowerCase();
            let statusSelect = row.querySelector("select[name='status_baru']");
            let currentStatus = statusSelect ? statusSelect.value : "";

            let matchNama = textContent.includes(inputNama);
            let matchStatus = (inputStatus === "ALL" || currentStatus === inputStatus);
            let checkLunasHide = !(hideLunas && currentStatus === "Lunas");

            if (matchNama && matchStatus && checkLunasHide) {
                row.style.display = "";
            } else {
                row.style.display = "none";
                // Tutup rincian jika baris utama disembunyikan
                let poId = row.querySelector('.po-checkbox').value;
                document.getElementById('detail-' + poId).classList.add('d-none');
            }
        });
    }

    function sinkronLunas(cb) {
        const dropStatus = document.getElementById('filterStatus');
        if (cb.checked && dropStatus.value === 'Lunas') dropStatus.value = 'ALL';
        jalankanFilter();
    }

    // Fitur Checkbox & Nota Gabungan
    function updateCounter() {
        const checked = document.querySelectorAll('.po-checkbox:checked');
        const bar = document.getElementById('bulkActionArea');
        const countLabel = document.getElementById('countSelected');
        
        if (checked.length > 0) {
            bar.classList.remove('d-none');
            bar.classList.add('d-flex');
            countLabel.innerText = checked.length + " PO Terpilih";
        } else {
            bar.classList.add('d-none');
            bar.classList.remove('d-flex');
        }
    }

    function prosesNotaGabungan() {
        const checked = document.querySelectorAll('.po-checkbox:checked');
        let ids = [];
        let customers = new Set();
        checked.forEach(cb => {
            ids.push(cb.value);
            customers.add(cb.getAttribute('data-customer'));
        });

        if (customers.size > 1) {
            alert("❌ Gagal: Nota Gabungan hanya bisa dibuat untuk 1 Customer yang sama.");
            return;
        }
        window.open(`/cetak-nota-gabungan?ids=${ids.join(',')}`, '_blank');
    }

    // Load state awal
    window.onload = function() {
        const savedNama = localStorage.getItem('filterNama');
        const savedStatus = localStorage.getItem('filterStatus');
        const savedLunas = localStorage.getItem('hideLunas');

        if (savedStatus !== null) {
            document.getElementById('liveSearch').value = savedNama || "";
            document.getElementById('filterStatus').value = savedStatus;
            document.getElementById('checkLunas').checked = (savedLunas === 'true');
        } else {
            // Default awal
            document.getElementById('filterStatus').value = "Produksi";
            document.getElementById('checkLunas').checked = true;
        }
        jalankanFilter();
    };
</script>

<%- include('../partials/footer') %>