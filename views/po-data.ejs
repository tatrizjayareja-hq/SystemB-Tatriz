<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Manajemen Pesanan - Tatriz</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
    
    <style>
        body { background: #f4f7f6; font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; }
        .table-primary { background-color: #0d6efd !important; }
        .clickable-row { cursor: pointer; transition: 0.2s; }
        .clickable-row:hover { background-color: #f1fdf4 !important; }
        .detail-row { display: none; background-color: #f8f9fa; }
        .badge-variasi { font-size: 10px; background: #fff3e0; color: #e67e22; border: 1px solid #ffe0b2; }
        .action-dropdown { position: relative; display: inline-block; }
        .dropdown-content { 
            display: none; position: absolute; right: 0; background-color: #fff; 
            min-width: 180px; box-shadow: 0 8px 16px rgba(0,0,0,0.1); 
            z-index: 1000; border-radius: 8px; border: 1px solid #ddd; 
        }
        .dropdown-content a, .dropdown-content button { 
            color: #333; padding: 10px 15px; text-decoration: none; 
            display: block; font-size: 13px; text-align: left; width: 100%; border: none; background: none; 
        }
        .dropdown-content a:hover, .dropdown-content button:hover { background-color: #f8f9fa; color: #0d6efd; }
        .show { display: block; }
        #bulkActionArea { display: none; }
        .blink-warn { animation: blinker 1.5s linear infinite; color: #dc3545; font-weight: bold; }
        @keyframes blinker { 50% { opacity: 0; } }
        /* Style tambahan untuk tombol kecil */
        .btn-xs { padding: 1px 5px; font-size: 10px; border-radius: 3px; }
    </style>
</head>
<body>

<div class="container-fluid py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <a href="/dashboard" class="text-decoration-none text-muted fw-bold">
            <i class="bi bi-arrow-left"></i> Kembali ke Dashboard
        </a>
        <div class="btn-group shadow-sm">
            <a href="/po-baru" class="btn btn-success fw-bold px-4">
                <i class="bi bi-plus-lg"></i> INPUT PO BARU
            </a>
            <a href="/daftar-produksi" class="btn btn-primary fw-bold px-4">
                <i class="bi bi-speedometer2"></i> DAFTAR PRODUKSI
            </a>
        </div>
    </div>

    <div id="bulkActionArea" class="alert alert-info border-info d-flex justify-content-between align-items-center shadow-sm">
        <div>
            <i class="bi bi-check-all fs-5"></i>
            <strong id="countSelected" class="ms-2">0 PO Terpilih</strong>
            <small class="text-muted ms-2">(Customer harus sama)</small>
        </div>
        <button onclick="prosesNotaGabungan()" class="btn btn-dark btn-sm fw-bold">
            <i class="bi bi-file-earmark-pdf"></i> BUAT NOTA GABUNGAN
        </button>
    </div>

    <div class="card shadow-sm border-0 mb-4">
        <div class="card-header bg-white py-3">
            <div class="row g-3 align-items-center">
                <div class="col-md-5">
                    <label class="small fw-bold text-muted">Cari Nama PO / Customer</label>
                    <input type="text" id="liveSearch" class="form-control" placeholder="Ketik nama..." onkeyup="jalankanFilter()">
                </div>
                <div class="col-md-3">
                    <label class="small fw-bold text-muted">Filter Status</label>
                    <select id="filterStatus" class="form-select" onchange="jalankanFilter()">
                        <option value="ALL">-- Semua Status --</option>
                        <option value="Design">Design</option>
                        <option value="Produksi">Produksi</option>
                        <option value="CMT">CMT (Luar)</option>
                        <option value="QC">QC</option>
                        <option value="Clear">Clear</option>
                        <option value="DP/Cicil">DP/Cicil</option>
                        <option value="Lunas">Lunas</option>
                    </select>
                </div>
                <div class="col-md-4 pt-4">
                    <div class="form-check form-switch">
                        <input class="form-check-input" type="checkbox" id="checkLunas" onchange="sinkronLunas(this)">
                        <label class="form-check-label fw-bold small" for="checkLunas">Auto-Hide Lunas</label>
                    </div>
                </div>
            </div>
        </div>

        <div class="table-responsive">
            <table class="table table-hover table-bordered align-middle mb-0" style="font-size: 13px;">
                <thead class="table-primary text-white text-uppercase text-center">
                    <tr>
                        <th style="width: 40px;">Sel</th>
                        <th style="width: 100px;">Tanggal</th>
                        <th>Data Pesanan / Customer</th>
                        <th style="width: 60px;">Qty</th>
                        <th style="width: 120px;">Audit Prod</th>
                        <th class="text-end">Total Cust</th>
                        <th>Status</th>
                        <th style="width: 100px;">Aksi</th>
                    </tr>
                </thead>
                <tbody id="bodyPO">
                    <% orders.forEach(function(po) { %>
                        <tr class="clickable-row <%= po.is_over ? 'table-danger' : '' %>" onclick="toggleDetail('<%= po.id %>')">
                            <td class="text-center" onclick="event.stopPropagation()">
                                <input type="checkbox" class="form-check-input po-checkbox" value="<%= po.id %>" data-customer="<%= po.customer %>" onchange="updateCounter()">
                            </td>
                            <td class="text-center text-muted"><%= po.tanggal.split('-').reverse().join('/') %></td>
                            <td>
                                <strong class="text-dark"><%= po.nama_po %></strong><br>
                                <small class="text-secondary"><i class="bi bi-person"></i> <%= po.customer %></small>
                                <% if (po.variasi_jumlah > 1) { %>
                                    <span class="badge badge-variasi ms-1">+<%= po.variasi_jumlah %> Item</span>
                                <% } %>
                            </td>
                            <td class="text-center fw-bold"><%= po.qty_tampil || 0 %></td>
                            
                            <td class="text-center">
                                <% if (po.is_over) { %>
                                    <span class="blink-warn"><i class="bi bi-exclamation-triangle-fill"></i> TIDAK SINKRON</span>
                                <% } else { %>
                                    <span class="text-success"><i class="bi bi-check-circle-fill"></i> Normal</span>
                                <% } %>
                            </td>

                            <td class="text-end fw-bold text-success">
                                <%= (po.total_harga_customer || 0).toLocaleString('id-ID') %>
                            </td>

                            <td onclick="event.stopPropagation()">
                                <form action="/update-status/<%= po.id %>" method="POST" class="d-flex gap-1">
                                    <select name="status_baru" class="form-select form-select-sm py-0" style="font-size: 11px;">
                                        <option value="Design" <%= po.status === 'Design' ? 'selected' : '' %>>Design</option>
                                        <option value="Produksi" <%= po.status === 'Produksi' ? 'selected' : '' %>>Produksi</option>
                                        <option value="CMT" <%= po.status === 'CMT' ? 'selected' : '' %>>CMT</option>
                                        <option value="QC" <%= po.status === 'QC' ? 'selected' : '' %>>QC</option>
                                        <option value="Clear" <%= po.status === 'Clear' ? 'selected' : '' %>>Clear</option>
                                        <option value="DP/Cicil" <%= po.status === 'DP/Cicil' ? 'selected' : '' %>>DP/Cicil</option>
                                        <option value="Lunas" <%= po.status === 'Lunas' ? 'selected' : '' %>>Lunas</option>
                                    </select>
                                    <button type="submit" class="btn btn-sm btn-primary py-0"><i class="bi bi-save"></i></button>
                                </form>
                            </td>

                            <td class="text-center" onclick="event.stopPropagation()">
                                <div class="action-dropdown">
                                    <button class="btn btn-sm btn-outline-dark py-0 px-2" onclick="toggleMenu(event, '<%= po.id %>')">
                                        Opsi <i class="bi bi-chevron-down small"></i>
                                    </button>
                                    <div id="menu-<%= po.id %>" class="dropdown-content shadow rounded">
                                        <button onclick="toggleDetail('<%= po.id %>')"><i class="bi bi-eye text-info"></i> Detail Progres</button>
                                        <a href="/edit-po/<%= po.id %>"><i class="bi bi-pencil-square text-warning"></i> Edit Data PO</a>
                                        <a href="/cetak-nota/<%= po.id %>" target="_blank"><i class="bi bi-printer"></i> Nota A6</a>
                                        <a href="/cetak-nota-rinci/<%= po.id %>" target="_blank"><i class="bi bi-list-check"></i> Nota Rinci</a>
                                        <a href="/delete-po/<%= po.id %>" class="text-danger fw-bold" onclick="return confirm('Hapus PO ini?')"><i class="bi bi-trash"></i> Hapus PO</a>
                                    </div>
                                </div>
                            </td>
                        </tr>

                        <tr id="detail-<%= po.id %>" class="detail-row">
                            <td colspan="9" class="p-0">
                                <div class="bg-white p-3 border-bottom border-start border-5 border-primary m-2 shadow-sm rounded">
                                    <div class="d-flex justify-content-between align-items-center mb-2">
                                        <h6 class="fw-bold text-primary mb-0"><i class="bi bi-speedometer2 me-2"></i>Monitor Progres Produksi</h6>
                                        <a href="/daftar-produksi" class="btn btn-xs btn-outline-primary py-0 px-2" style="font-size: 10px;">Audit Log</a>
                                    </div>
                                    <table class="table table-sm table-bordered mb-0" style="font-size: 11px;">
                                        <thead class="table-dark">
                                            <tr class="text-center">
                                                <th>Jenis</th>
                                                <th>Nama Desain</th>
                                                <th>Setor Op / Target</th>
                                                <th class="bg-success">Lulus QC</th>
                                                <th>Reject (Op - QC)</th>
                                                <th>Aksi QC</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            <% details.filter(d => d.po_id === po.id).forEach(function(sub) { 
                                                let totalOp = sub.total_produksi || 0;
                                                let totalQc = sub.total_qc || 0;
                                                let target = sub.jumlah;
                                                let reject = totalOp - totalQc;
                                            %>
                                                <tr class="text-center">
                                                    <td class="text-start ps-2"><%= sub.jenis_bordir %></td>
                                                    <td class="text-start"><strong><%= sub.nama_desain %></strong></td>
                                                    <td><strong><%= totalOp %></strong> / <%= target %></td>
                                                    
                                                    <td class="fw-bold text-success" style="background: #f0fff4;">
                                                        <%= totalQc %>
                                                    </td>

                                                    <td class="fw-bold">
                                                        <% if (reject > 0) { %>
                                                            <span class="text-danger"><i class="bi bi-x-octagon-fill"></i> <%= reject %></span>
                                                        <% } else if (reject < 0) { %>
                                                            <span class="text-warning"><%= reject %> (Audit QC)</span>
                                                        <% } else { %>
                                                            <span class="text-success">0</span>
                                                        <% } %>
                                                    </td>

                                                    <td onclick="event.stopPropagation()">
                                                        <button class="btn btn-xs btn-outline-success py-0 px-2" 
                                                                onclick="bukaModalQC('<%= sub.id %>', '<%= sub.nama_desain %>', '<%= totalQc %>')">
                                                            <i class="bi bi-pencil-square"></i> EDIT QC
                                                        </button>
                                                    </td>
                                                </tr>
                                            <% }); %>
                                        </tbody>
                                    </table>
                                </div>
                            </td>
                        </tr>
                    <% }); %>
                </tbody>
            </table>
        </div>
    </div>
</div>

<div class="modal fade" id="modalQC" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-sm modal-dialog-centered">
        <div class="modal-content shadow-lg border-0">
            <form action="/update-qc-cepat" method="POST">
                <div class="modal-header bg-success text-white py-2">
                    <h6 class="modal-title fw-bold"><i class="bi bi-shield-check"></i> Koreksi Hasil QC</h6>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body text-center">
                    <input type="hidden" name="detail_id" id="qc_detail_id">
                    <p class="small mb-2 fw-bold text-muted" id="qc_nama_desain"></p>
                    <label class="small fw-bold d-block mb-1">Total Lulus QC Baru:</label>
                    <input type="number" name="jumlah_qc_baru" id="qc_jumlah_input" 
                           class="form-control form-control-lg text-center fw-bold" 
                           required min="0">
                    <small class="text-muted" style="font-size: 10px;">*Menggantikan total riwayat QC sebelumnya.</small>
                </div>
                <div class="modal-footer p-2 border-0">
                    <button type="submit" class="btn btn-success w-100 fw-bold">SIMPAN PERUBAHAN</button>
                </div>
            </form>
        </div>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>

<script>
    function toggleDetail(id) {
        const row = document.getElementById('detail-' + id);
        if(row) row.style.display = (row.style.display === 'table-row') ? 'none' : 'table-row';
    }

    function toggleMenu(event, id) {
        event.stopPropagation();
        const allMenus = document.querySelectorAll('.dropdown-content');
        allMenus.forEach(menu => {
            if (menu.id !== 'menu-' + id) menu.classList.remove('show');
        });
        document.getElementById('menu-' + id).classList.toggle('show');
    }

    window.onclick = function(event) {
        if (!event.target.closest('.action-dropdown')) {
            document.querySelectorAll(".dropdown-content").forEach(d => d.classList.remove('show'));
        }
    }

    function jalankanFilter() {
        let inputNama = document.getElementById("liveSearch").value.toLowerCase();
        let inputStatus = document.getElementById("filterStatus").value;
        let hideLunas = document.getElementById("checkLunas").checked;

        localStorage.setItem('filterNama', inputNama);
        localStorage.setItem('filterStatus', inputStatus);
        localStorage.setItem('hideLunas', hideLunas);

        let rows = document.querySelectorAll("#bodyPO tr.clickable-row");
        rows.forEach(row => {
            let text = row.innerText.toLowerCase();
            let status = row.querySelector("select").value;
            let match = text.includes(inputNama) && (inputStatus === "ALL" || status === inputStatus);
            
            if (match && !(hideLunas && status === "Lunas")) {
                row.style.display = "";
            } else {
                row.style.display = "none";
                let id = row.querySelector('.po-checkbox').value;
                let detailRow = document.getElementById('detail-' + id);
                if(detailRow) detailRow.style.display = "none";
            }
        });
    }

    function updateCounter() {
        const checked = document.querySelectorAll('.po-checkbox:checked');
        const bar = document.getElementById('bulkActionArea');
        if (checked.length > 0) {
            bar.style.display = 'flex';
            document.getElementById('countSelected').innerText = checked.length + " PO Terpilih";
        } else {
            bar.style.display = 'none';
        }
    }

    function prosesNotaGabungan() {
        const checked = document.querySelectorAll('.po-checkbox:checked');
        let ids = Array.from(checked).map(cb => cb.value);
        let customers = new Set(Array.from(checked).map(cb => cb.getAttribute('data-customer')));

        if (customers.size > 1) return alert("❌ Nota Gabungan hanya untuk 1 Customer yang sama.");
        window.open(`/cetak-nota-gabungan?ids=${ids.join(',')}`, '_blank');
    }

    function sinkronLunas(cb) {
        if (cb.checked && document.getElementById('filterStatus').value === 'Lunas') {
            document.getElementById('filterStatus').value = 'ALL';
        }
        jalankanFilter();
    }

    // Fungsi Pemicu Modal QC
    function bukaModalQC(id, nama, jumlah) {
        document.getElementById('qc_detail_id').value = id;
        document.getElementById('qc_nama_desain').innerText = nama;
        document.getElementById('qc_jumlah_input').value = jumlah;
        
        var myModal = new bootstrap.Modal(document.getElementById('modalQC'));
        myModal.show();
    }

    window.onload = function() {
        const savedNama = localStorage.getItem('filterNama');
        const savedStatus = localStorage.getItem('filterStatus');
        const savedHideLunas = localStorage.getItem('hideLunas');

        if (savedNama !== null) document.getElementById('liveSearch').value = savedNama;
        if (savedStatus !== null) document.getElementById('filterStatus').value = savedStatus;
        if (savedHideLunas !== null) document.getElementById('checkLunas').checked = (savedHideLunas === 'true');

        jalankanFilter();
    };
</script>

</body>
</html>