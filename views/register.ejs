<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Daftar Akun Baru - Tatriz SystemB</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">

    <style>
        :root {
            --dark-green: #195e0b;
            --primary-green: #59cf77;
            --accent-green: #48b865;
        }

        body, html {
            margin: 0;
            padding: 0;
            min-height: 100vh;
            font-family: 'Segoe UI', Roboto, sans-serif;
            background: linear-gradient(135deg, #195e0b 0%, #48b865 100%);
            display: flex;
            justify-content: center;
            align-items: center;
        }

        /* --- CARD UTAMA (VERTIKAL UNTUK MOBILE) --- */
        .register-card {
            display: flex;
            flex-direction: column; /* Vertikal secara default */
            width: 400px; /* Ukuran standar mobile-friendly */
            max-width: 90%;
            background: white;
            border-radius: 20px;
            overflow: hidden;
            box-shadow: 0 20px 40px rgba(0,0,0,0.3);
            margin: 20px 0;
        }

        /* --- BAGIAN ATAS: BRANDING --- */
        .side-branding {
            background: white;
            display: flex;
            flex-direction: column;
            justify-content: center;
            align-items: center;
            padding: 30px 20px;
            text-align: center;
            border-bottom: 1px solid #eee;
        }

        .side-branding img {
            width: 80px; /* Lebih kecil untuk mobile */
            height: auto;
            margin-bottom: 15px;
        }

        .side-branding h1 {
            color: var(--dark-green);
            margin: 0;
            font-size: 24px;
            font-weight: 800;
        }

        .side-branding .tagline {
            color: #636e72;
            font-size: 13px;
            margin-top: 10px;
            line-height: 1.5;
        }

        /* --- BAGIAN BAWAH: FORM --- */
        .side-form {
            background-color: var(--dark-green);
            color: white;
            padding: 30px;
            display: flex;
            flex-direction: column;
        }

        .side-form h2 {
            margin: 0 0 5px 0;
            font-size: 22px;
            text-align: center;
        }

        .side-form p {
            font-size: 12px;
            opacity: 0.8;
            margin-bottom: 20px;
            text-align: center;
        }

        .form-group {
            margin-bottom: 15px;
        }

        .form-group label {
            display: block;
            font-size: 10px;
            margin-bottom: 5px;
            text-transform: uppercase;
            letter-spacing: 1px;
            font-weight: bold;
        }

        .input-wrapper {
            position: relative;
        }

        .input-wrapper i {
            position: absolute;
            left: 15px;
            top: 50%;
            transform: translateY(-50%);
            color: rgba(255,255,255,0.5);
        }

        .input-wrapper input {
            width: 100%;
            padding: 12px 15px 12px 40px;
            background: rgba(255,255,255,0.1);
            border: 1px solid rgba(255,255,255,0.2);
            border-radius: 8px;
            color: white;
            box-sizing: border-box;
            outline: none;
            transition: 0.3s;
            font-size: 14px;
        }

        .input-wrapper input:focus {
            background: rgba(255,255,255,0.2);
            border-color: var(--primary-green);
        }

        .btn-register {
            width: 100%;
            padding: 14px;
            background: var(--primary-green);
            color: var(--dark-green);
            border: none;
            border-radius: 8px;
            font-weight: bold;
            font-size: 15px;
            cursor: pointer;
            transition: 0.3s;
            margin-top: 10px;
            text-transform: uppercase;
        }

        .btn-register:hover {
            background: white;
            transform: translateY(-2px);
        }

        .login-link {
            margin-top: 20px;
            font-size: 13px;
            text-align: center;
            opacity: 0.9;
        }

        .login-link a {
            color: var(--primary-green);
            text-decoration: none;
            font-weight: bold;
        }

        /* Desktop View (Jika layar lebar, tetap cantik) */
        @media (min-width: 769px) {
            .register-card {
                width: 450px;
            }
        }
    </style>
</head>
<body>

    <div class="register-card">
        <div class="side-branding">
            <img src="/img/Tatriz SystemB.png" alt="Logo Tatriz SystemB">
            <h1>Tatriz SystemB</h1>
            <p class="tagline">Manajemen Bordir Cerdas & Otomatis</p>
        </div>

        <div class="side-form">
            <h2>Registrasi Akun</h2>
            <p>Lengkapi data untuk unit usaha baru.</p>

            <form action="/register-tenant" method="POST">
                <div class="form-group">
                    <label>Nama Perusahaan</label>
                    <div class="input-wrapper">
                        <i class="fas fa-building"></i>
                        <input type="text" name="nama_toko" placeholder="Contoh: Tatriz Solo" required>
                    </div>
                </div>

                <div class="form-group">
                    <label>Username Admin</label>
                    <div class="input-wrapper">
                        <i class="fas fa-user-shield"></i>
                        <input type="text" name="username" placeholder="Username login" required>
                    </div>
                </div>

                <div class="form-group">
                    <label>Password</label>
                    <div class="input-wrapper">
                        <i class="fas fa-key"></i>
                        <input type="password" name="password" placeholder="Minimal 6 karakter" required>
                    </div>
                </div>

                <div class="form-group">
                    <label>Kode Aktivasi</label>
                    <div class="input-wrapper">
                        <i class="fas fa-shield-alt"></i>
                        <input type="text" name="activation_code" placeholder="Minta kode ke Admin" required>
                    </div>
                    <p style="text-align: left; font-size: 9px; margin-top: 5px; color: #ffeb3b;">*Kode ini diperlukan untuk memvalidasi pendaftaran baru.</p>
                </div>

                <button type="submit" class="btn-register">Daftar Sekarang</button>
            </form>

            <div class="login-link">
                Sudah punya akun? <a href="/">Masuk</a>
            </div>
        </div>
    </div>

</body>
</html>