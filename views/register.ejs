<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Daftar Akun Baru - Tatriz SystemB</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">

    <style>
        :root {
            --dark-green: #195e0b;
            --primary-green: #59cf77;
            --accent-green: #48b865;
            --bg-light: #f8f9fa;
            --text-dark: #2d3748;
            --text-muted: #718096;
        }

        body, html {
            margin: 0;
            padding: 0;
            min-height: 100vh;
            font-family: 'Segoe UI', Roboto, sans-serif;
            /* Mengubah arah gradient agar berbeda dengan login */
            background: linear-gradient(225deg, #48b865 0%, #195e0b 100%);
            display: flex;
            justify-content: center;
            align-items: center;
        }

        /* --- CARD UTAMA (SEKARANG FULL LIGHT THEME) --- */
        .register-card {
            display: flex;
            flex-direction: column;
            width: 400px;
            max-width: 90%;
            background: white;
            border-radius: 20px;
            overflow: hidden;
            box-shadow: 0 25px 50px rgba(0,0,0,0.25);
            margin: 20px 0;
            /* Memberi border top tebal sebagai penanda instan halaman registrasi */
            border-top: 8px solid var(--primary-green);
        }

        /* --- BAGIAN ATAS: BRANDING (SOFT BACKGROUND) --- */
        .side-branding {
            background: var(--bg-light);
            display: flex;
            flex-direction: column;
            justify-content: center;
            align-items: center;
            padding: 35px 20px 20px;
            text-align: center;
            border-bottom: 1px solid #e2e8f0;
        }

        .side-branding img {
            width: 75px;
            height: auto;
            margin-bottom: 12px;
            filter: drop-shadow(0 4px 6px rgba(0,0,0,0.05));
        }

        .side-branding h1 {
            color: var(--dark-green);
            margin: 0;
            font-size: 22px;
            font-weight: 800;
            letter-spacing: 0.5px;
        }

        .side-branding .tagline {
            color: var(--text-muted);
            font-size: 13px;
            margin-top: 6px;
            line-height: 1.5;
        }

        /* --- BAGIAN BAWAH: FORM (WHITE CLEAN) --- */
        .side-form {
            background-color: #ffffff;
            color: var(--text-dark);
            padding: 30px 35px;
            display: flex;
            flex-direction: column;
        }

        .side-form h2 {
            margin: 0 0 5px 0;
            font-size: 24px;
            text-align: center;
            color: var(--dark-green);
            font-weight: 700;
        }

        .side-form p {
            font-size: 13px;
            color: var(--text-muted);
            margin-bottom: 25px;
            text-align: center;
        }

        .form-group {
            margin-bottom: 18px;
        }

        .form-group label {
            display: block;
            font-size: 11px;
            margin-bottom: 6px;
            text-transform: uppercase;
            letter-spacing: 1px;
            font-weight: 700;
            color: var(--text-dark);
        }

        .input-wrapper {
            position: relative;
        }

        /* Icon disesuaikan untuk background terang */
        .input-wrapper i {
            position: absolute;
            left: 15px;
            top: 50%;
            transform: translateY(-50%);
            color: #a0aec0;
            transition: 0.3s;
        }

        /* Input diubah dari transparan menjadi light gray dengan border solid */
        .input-wrapper input {
            width: 100%;
            padding: 13px 15px 13px 45px;
            background: var(--bg-light);
            border: 1px solid #e2e8f0;
            border-radius: 10px;
            color: var(--text-dark);
            box-sizing: border-box;
            outline: none;
            transition: 0.3s;
            font-size: 14px;
        }

        /* Saat fokus, border berubah menjadi hijau tua */
        .input-wrapper input:focus {
            background: white;
            border-color: var(--dark-green);
            box-shadow: 0 0 0 4px rgba(25, 94, 11, 0.1);
        }

        .input-wrapper input:focus + i {
            color: var(--dark-green);
        }

        /* Tombol pendaftaran menggunakan warna Hijau Tua agar lebih kontras */
        .btn-register {
            width: 100%;
            padding: 15px;
            background: var(--dark-green);
            color: white;
            border: none;
            border-radius: 10px;
            font-weight: bold;
            font-size: 15px;
            cursor: pointer;
            transition: 0.3s;
            margin-top: 10px;
            text-transform: uppercase;
            letter-spacing: 1px;
            box-shadow: 0 4px 12px rgba(25, 94, 11, 0.2);
        }

        .btn-register:hover {
            background: var(--accent-green);
            box-shadow: 0 6px 15px rgba(72, 184, 101, 0.3);
            transform: translateY(-2px);
        }

        .login-link {
            margin-top: 25px;
            font-size: 13px;
            text-align: center;
            color: var(--text-muted);
        }

        .login-link a {
            color: var(--dark-green);
            text-decoration: none;
            font-weight: bold;
            transition: 0.2s;
        }

        .login-link a:hover {
            text-decoration: underline;
            color: var(--accent-green);
        }

        /* Desktop View */
        @media (min-width: 769px) {
            .register-card {
                width: 450px;
            }
        }
    </style>
</head>
<body>
    <div id="loaderSistem" style="
    position: fixed;
    top: 0; left: 0;
    width: 100%; height: 100%;
    background: #195e0b; /* Warna hijau gelap khas Tatriz */
    z-index: 99999; /* Dipastikan paling atas menutupi semua menu */
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    transition: opacity 0.3s ease, visibility 0.3s ease;
">
    <div class="spinner-tatriz"></div>
    <p style="color: white; margin-top: 18px; font-weight: bold; font-size: 14px; letter-spacing: 1px; font-family: sans-serif; text-align: center;">
        MEMUAT SISTEM TATRIZ...
    </p>
</div>

<style>
    .spinner-tatriz {
        width: 50px; height: 50px;
        border: 5px solid rgba(255,255,255,0.2);
        border-top: 5px solid #59cf77; /* Warna hijau muda aksen */
        border-radius: 50%;
        animation: putarLoaderTatriz 1s linear infinite;
    }
    @keyframes putarLoaderTatriz {
        0% { transform: rotate(0deg); }
        100% { transform: rotate(360deg); }
    }
    /* Kelas untuk menghilangkan loader dengan halus */
    .loader-hilang {
        opacity: 0 !important;
        visibility: hidden !important;
    }
</style>

    <div class="register-card">
        <div class="side-branding">
            <img src="/img/Tatriz SystemB.png" alt="Logo Tatriz SystemB">
            <h1>Tatriz SystemB</h1>
            <p class="tagline">Manajemen Bordir Cerdas & Otomatis</p>
        </div>

        <div class="side-form">
            <h2>Registrasi Akun</h2>
            <p>Lengkapi data untuk unit usaha baru.</p>

            <form action="/register-tenant" method="POST">
                <div class="form-group">
                    <label>Nama Perusahaan</label>
                    <div class="input-wrapper">
                        <i class="fas fa-building"></i>
                        <input type="text" name="nama_toko" placeholder="Contoh: Tatriz Solo" required>
                    </div>
                </div>

                <div class="form-group">
                    <label>Username Admin</label>
                    <div class="input-wrapper">
                        <i class="fas fa-user-shield"></i>
                        <input type="text" name="username" placeholder="Username login" required>
                    </div>
                </div>

                <div class="form-group">
                    <label>Password</label>
                    <div class="input-wrapper">
                        <i class="fas fa-key"></i>
                        <input type="password" name="password" placeholder="Minimal 6 karakter" required>
                    </div>
                </div>

                <div class="form-group">
                    <label>Kode Aktivasi</label>
                    <div class="input-wrapper">
                        <i class="fas fa-shield-alt"></i>
                        <input type="text" name="activation_code" placeholder="Minta kode ke Admin" required>
                    </div>
                    <p style="text-align: left; font-size: 11px; margin-top: 6px; color: #e67e22; font-weight: 600; margin-bottom: 0;">
                        *Kode ini diperlukan untuk memvalidasi pendaftaran baru.
                    </p>
                </div>

                <button type="submit" class="btn-register">Daftar Sekarang</button>
            </form>

            <div class="login-link">
                Sudah punya akun? <a href="/">Masuk</a>
            </div>
        </div>
    </div>
<script>
        document.addEventListener('DOMContentLoaded', function() {
            const loader = document.getElementById('loaderSistem');
            if (loader) {
                setTimeout(function() {
                    loader.classList.add('loader-hilang');
                }, 200);
            }
        });
        setTimeout(function() {
            const loader = document.getElementById('loaderSistem');
            if (loader && !loader.classList.contains('loader-hilang')) {
                loader.classList.add('loader-hilang');
            }
        }, 4000);
    </script>
</body>
</html>