<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Manajemen Pesanan V2 - Tatriz</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    
    <style>
        body { background: #f4f7f6; font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; }
        .table-primary { background-color: #195e0b !important; } /* Warna Hijau Khas Tatriz */
        .clickable-row { cursor: pointer; transition: 0.2s; }
        .clickable-row:hover { background-color: #f1fdf4 !important; }
        .detail-row { display: none; background-color: #f8f9fa; }
        .badge-variasi { font-size: 10px; background: #fff3e0; color: #e67e22; border: 1px solid #ffe0b2; }
        .action-dropdown { position: relative; display: inline-block; }
        .dropdown-content { 
            display: none; position: absolute; right: 0; background-color: #fff; 
            min-width: 180px; box-shadow: 0 8px 16px rgba(0,0,0,0.1); 
            z-index: 1000; border-radius: 8px; border: 1px solid #ddd; 
        }
        .dropdown-content a, .dropdown-content button { 
            color: #333; padding: 10px 15px; text-decoration: none; 
            display: block; font-size: 13px; text-align: left; width: 100%; border: none; background: none; 
        }
        .dropdown-content a:hover, .dropdown-content button:hover { background-color: #f8f9fa; color: #195e0b; }
        .show { display: block; }
        .blink-warn { animation: blinker 1.5s linear infinite; color: #dc3545; font-weight: bold; }
        @keyframes blinker { 50% { opacity: 0; } }
        .btn-xs { padding: 1px 5px; font-size: 10px; border-radius: 3px; }
    </style>
</head>
<body>

<div class="container-fluid py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <a href="/dashboard" class="text-decoration-none text-muted fw-bold">
            <i class="bi bi-arrow-left"></i> Dashboard
        </a>
        <div class="btn-group shadow-sm">
            <a href="/po-baru-v2" class="btn btn-success fw-bold px-4">
                <i class="bi bi-plus-lg"></i> INPUT PO BARU (V2)
            </a>
            <a href="/po-data" class="btn btn-outline-secondary fw-bold">
                <i class="bi bi-arrow-left-right"></i> PINDAH KE V1
            </a>
        </div>
    </div>

    <div class="card shadow-sm border-0 mb-4">
        <div class="card-header bg-white py-3">
            <div class="row g-3 align-items-center">
                <div class="col-md-5">
                    <label class="small fw-bold text-muted">Cari Pesanan (V2)</label>
                    <input type="text" id="liveSearch" class="form-control" placeholder="Nama PO atau Customer..." onkeyup="jalankanFilter()">
                </div>
                <div class="col-md-3">
                    <label class="small fw-bold text-muted">Status</label>
                    <select id="filterStatus" class="form-select" onchange="jalankanFilter()">
                        <option value="ALL">-- Semua Status --</option>
                        <option value="Design">Design</option>
                        <option value="Produksi">Produksi</option>
                        <option value="CMT">CMT (Luar)</option>
                        <option value="QC">QC</option>
                        <option value="Lunas">Lunas</option>
                    </select>
                </div>
                <div class="col-md-4 pt-4 text-end">
                    <span class="badge bg-dark">MODE V2: CMT & OP SINKRON</span>
                </div>
            </div>
        </div>

        <div class="table-responsive">
            <table class="table table-hover table-bordered align-middle mb-0" style="font-size: 13px;">
                <thead class="table-primary text-white text-uppercase text-center">
                    <tr>
                        <th style="width: 100px;">Tanggal</th>
                        <th>Pesanan / Customer</th>
                        <th style="width: 80px;">Qty</th>
                        <th class="text-end">Total Tagihan</th>
                        <th>Status</th>
                        <th style="width: 120px;">Aksi</th>
                    </tr>
                </thead>
                <tbody id="bodyPO">
                    <% orders.forEach(function(po) { %>
                        <tr class="clickable-row" onclick="toggleDetail('<%= po.id %>')">
                            <td class="text-center text-muted"><%= po.tanggal.split('-').reverse().join('/') %></td>
                            <td>
                                <strong class="text-dark"><%= po.nama_po %></strong><br>
                                <small class="text-secondary"><i class="bi bi-person"></i> <%= po.customer %></small>
                                <% if (po.variasi_jumlah > 1) { %>
                                    <span class="badge badge-variasi">+<%= po.variasi_jumlah %> Item</span>
                                <% } %>
                            </td>
                            <td class="text-center fw-bold"><%= po.qty_tampil || 0 %></td>
                            <td class="text-end fw-bold text-success">
                                Rp <%= (po.total_harga_customer || 0).toLocaleString('id-ID') %>
                            </td>
                            <td class="text-center" onclick="event.stopPropagation()">
                                <span class="badge bg-secondary"><%= po.status %></span>
                            </td>
                            <td class="text-center" onclick="event.stopPropagation()">
                                <div class="action-dropdown">
                                    <button class="btn btn-sm btn-outline-dark py-0" onclick="toggleMenu(event, '<%= po.id %>')">
                                        Opsi <i class="bi bi-chevron-down"></i>
                                    </button>
                                    <div id="menu-<%= po.id %>" class="dropdown-content shadow rounded">
                                        <button onclick="toggleDetail('<%= po.id %>')"><i class="bi bi-eye"></i> Detail Lengkap</button>
                                        <a href="/edit-po/<%= po.id %>"><i class="bi bi-pencil-square"></i> Edit PO</a>
                                        <a href="/cetak-nota-rinci/<%= po.id %>" target="_blank"><i class="bi bi-printer"></i> Cetak Nota Rinci</a>
                                    </div>
                                </div>
                            </td>
                        </tr>

                        <tr id="detail-<%= po.id %>" class="detail-row">
                            <td colspan="6" class="p-0">
                                <div class="bg-white p-3 border-start border-5 border-success m-2 shadow-sm rounded">
                                    <div class="d-flex justify-content-between align-items-center mb-3">
                                        <h6 class="fw-bold text-success mb-0"><i class="bi bi-graph-up-arrow me-2"></i>Informasi Progres & Finansial</h6>
                                        <button class="btn btn-xs btn-success fw-bold" onclick="bukaPanelQC('<%= po.id %>', '<%= po.nama_po %>')">UPDATE HASIL QC</button>
                                    </div>
                                    
                                    <table class="table table-sm table-bordered mb-0 align-middle" style="font-size: 11px;">
                                        <thead class="table-dark text-center">
                                            <tr>
                                                <th rowspan="2">Item / Desain</th>
                                                <th colspan="3">Progres (Pcs)</th>
                                                <th colspan="<%= (user.tenantId === 1 || user.tenantId === 100) ? '3' : '1' %>" class="bg-success">Finansial V2 (Rp)</th>
                                            </tr>
                                            <tr>
                                                <th>Target</th>
                                                <th>Setor Op</th>
                                                <th>Lulus QC</th>
                                                <% if (user.tenantId === 1 || user.tenantId === 100) { %>
                                                    <th>Hrg CMT</th>
                                                    <th>Hrg Op</th>
                                                <% } %>
                                                <th>Hrg Cust</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            <% details.filter(d => d.po_id === po.id).forEach(function(sub) { %>
                                                <tr class="text-center">
                                                    <td class="text-start ps-2">
                                                        <strong><%= sub.nama_desain %></strong><br>
                                                        <small class="text-muted"><%= sub.jenis_bordir %></small>
                                                    </td>
                                                    <td><%= sub.jumlah %></td>
                                                    <td><%= sub.total_produksi || 0 %></td>
                                                    <td class="bg-light fw-bold text-success"><%= sub.total_qc || 0 %></td>
                                                    
                                                    <% if (user.tenantId === 1 || user.tenantId === 100) { %>
                                                        <td class="text-secondary"><%= (sub.harga_cmt || 0).toLocaleString('id-ID') %></td>
                                                        <td class="text-secondary fw-italic"><%= (sub.harga_operator || 0).toLocaleString('id-ID') %></td>
                                                    <% } %>
                                                    <td class="fw-bold"><%= (sub.harga_customer || 0).toLocaleString('id-ID') %></td>
                                                </tr>
                                            <% }); %>
                                        </tbody>
                                    </table>
                                </div>
                            </td>
                        </tr>
                    <% }); %>
                </tbody>
            </table>
        </div>
    </div>
</div>

<div class="modal fade" id="modalQC" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0">
            <div class="modal-header bg-success text-white py-2">
                <h6 class="modal-title fw-bold">Update Hasil Lulus QC</h6>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body" id="container_input_qc"></div>
            <div class="modal-footer p-2">
                <button type="button" onclick="simpanQCBulk()" class="btn btn-success w-100 fw-bold">SIMPAN PERUBAHAN</button>
            </div>
        </div>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
<script>
    function toggleDetail(id) {
        const row = document.getElementById('detail-' + id);
        if(row) row.style.display = (row.style.display === 'table-row') ? 'none' : 'table-row';
    }

    function toggleMenu(event, id) {
        event.stopPropagation();
        document.querySelectorAll(".dropdown-content").forEach(d => {
            if (d.id !== 'menu-' + id) d.classList.remove('show');
        });
        document.getElementById('menu-' + id).classList.toggle('show');
    }

    window.onclick = function() {
        document.querySelectorAll(".dropdown-content").forEach(d => d.classList.remove('show'));
    }

    function jalankanFilter() {
        let inputNama = document.getElementById("liveSearch").value.toLowerCase();
        let inputStatus = document.getElementById("filterStatus").value;
        let rows = document.querySelectorAll("#bodyPO tr.clickable-row");
        
        rows.forEach(row => {
            let text = row.innerText.toLowerCase();
            let status = row.querySelector(".badge").innerText;
            let match = text.includes(inputNama) && (inputStatus === "ALL" || status === inputStatus);
            row.style.display = match ? "" : "none";
        });
    }

    function bukaPanelQC(poId, namaPo) {
        fetch(`/api/po-details/${poId}`).then(res => res.json()).then(data => {
            let html = `<p class="small">PO: <strong>${namaPo}</strong></p>`;
            data.forEach(d => {
                html += `<div class="mb-2 border-bottom pb-2">
                    <label class="small fw-bold d-block mb-1">${d.nama_desain}</label>
                    <div class="input-group input-group-sm">
                        <span class="input-group-text">Lulus:</span>
                        <input type="number" class="form-control fw-bold text-center input-qc-val" data-id="${d.id}" value="${d.total_qc || 0}">
                        <span class="input-group-text">Pcs</span>
                    </div>
                </div>`;
            });
            document.getElementById('container_input_qc').innerHTML = html;
            new bootstrap.Modal(document.getElementById('modalQC')).show();
        });
    }

    async function simpanQCBulk() {
        const inputs = document.querySelectorAll('.input-qc-val');
        const dataKirim = Array.from(inputs).map(i => ({ detail_id: i.dataset.id, jumlah: i.value }));
        const response = await fetch('/update-qc-bulk', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ data: dataKirim })
        });
        if (response.ok) window.location.reload();
        else alert("Gagal menyimpan.");
    }
</script>
</body>
</html>