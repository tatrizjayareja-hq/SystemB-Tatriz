<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
<script>
    // --- FUNGSI CMT ---
    const rawDetails = JSON.parse(document.getElementById('data-details').textContent);

    function cekStatusCMT(event, formElement, poId, namaPo) {
        const statusTerpilih = formElement.querySelector('select[name="status_baru"]').value;
        if (statusTerpilih === 'CMT') {
            event.preventDefault(); 
            bukaModalCMT(poId, namaPo);
        }
    }

    // 🔴 REVISI TOTAL: FUNGSI MEMBUAT FORM DISTRIBUSI LOGISTIK SECARA DINAMIS
async function bukaModalCMT(poId, namaPo) {
    document.getElementById('cmt_nama_po').innerText = namaPo;
    document.getElementById('cmt_po_id').value = poId;
    
    const container = document.getElementById('container_rincian_cmt');
    // Beri efek loading sementara data ditarik dari database PostgreSQL
    container.innerHTML = `
        <div class="text-center py-4">
            <div class="spinner-border text-primary" role="status"></div>
            <p class="small text-muted mt-2 mb-0">Mengecek sisa logistik di gudang...</p>
        </div>
    `;
    
    // Tampilkan modal terlebih dahulu
    const modalCmt = new bootstrap.Modal(document.getElementById('modalDistribusiCMT'));
    modalCmt.show();

    try {
        // Ambil data sisa real-time dari API backend tahap 2 kemarin
        const response = await fetch(`/api/po-cmt-status/${poId}`);
        const dataPO = await response.json();
        
        let html = '';

        dataPO.forEach((item, index) => {
            html += `
            <div class="card mb-3 border-0 shadow-sm card-item-cmt">
                <div class="card-header bg-white border-bottom-0 py-2 d-flex justify-content-between align-items-center">
                    <div>
                        <strong class="text-dark" style="font-size: 14px;">${item.nama_desain}</strong>
                        <span class="badge bg-secondary-subtle text-dark border ms-1" style="font-size: 10px;">${item.jenis_bordir}</span>
                    </div>
                    <div class="text-end">
                        <span class="small text-muted">Target: <b>${item.total_order}</b> | Terkirim: <b class="text-success">${item.total_terkirim}</b></span>
                    </div>
                </div>
                <div class="card-body p-3 bg-white border-top border-light">
                    <div class="row g-2 align-items-center">
                        <div class="col-12 col-md-4">
                            <div class="p-2 bg-light rounded border text-center text-md-start">
                                <small class="text-muted d-block" style="font-size: 10px;">SISA KAIN DI GUDANG:</small>
                                <strong class="text-danger fs-5 id-sisa-maks" data-maks="${item.sisa_gudang}">${item.sisa_gudang} <span style="font-size: 12px;">Pcs</span></strong>
                            </div>
                        </div>
                        <div class="col-12 col-md-8">
                            <div class="row g-2">
                                <div class="col-7">
                                    <label class="fw-bold text-muted" style="font-size: 10px; text-transform:uppercase;">Kirim Ke Vendor:</label>
                                    <input type="text" name="nama_vendors" class="form-control form-control-sm border-secondary input-nama-vendor" placeholder="Contoh: Pak Eko / Bordir Luar" style="padding: 8px;" />
                                    <input type="hidden" name="po_detail_ids" value="${item.po_detail_id}" />
                                    <input type="hidden" name="harga_cmts" value="${item.harga_cmt}" />
                                </div>
                                <div class="col-5">
                                    <label class="fw-bold text-muted" style="font-size: 10px; text-transform:uppercase;">Qty Kirim (Pcs):</label>
                                    <input type="number" name="qty_kirims" class="form-control form-control-sm border-secondary fw-bold text-center input-qty-kirim" 
                                           value="${item.sisa_gudang}" min="0" max="${item.sisa_gudang}" oninput="validasiKetikMaksimal(this)" style="padding: 8px;" />
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>`;
        });

        container.innerHTML = html;
    } catch (err) {
        console.error(err);
        container.innerHTML = `<div class="alert alert-danger small">Gagal memuat status logistik: ${err.message}</div>`;
    }
}

// Fungsi pengaman agar user tidak bisa mengetik angka melebihi sisa kain di gudang melalui HP
function validasiKetikMaksimal(input) {
    const maks = parseInt(input.max) || 0;
    const nilai = parseInt(input.value) || 0;
    if (nilai > maks) {
        Swal.fire({ title: 'Kelebihan Qty!', text: `Sisa kain di gudang hanya ${maks} Pcs.`, icon: 'warning', confirmButtonColor: '#0d6efd' });
        input.value = maks;
    }
}

// Fungsi validasi akhir sebelum form dikirim terbang ke backend
function validasiSebelumKirim() {
    const rows = document.querySelectorAll('.card-item-cmt');
    let adaYangDikirim = false;
    let valid = true;

    rows.forEach(row => {
        const vendor = row.querySelector('.input-nama-vendor').value.trim();
        const qty = parseInt(row.querySelector('.input-qty-kirim').value) || 0;
        const maks = parseInt(row.querySelector('.id-sisa-maks').dataset.maks) || 0;

        if (vendor !== "" && qty > 0) {
            adaYangDikirim = true;
            if (qty > maks) {
                valid = false;
            }
        }
    });

    if (!valid) {
        Swal.fire('Kesalahan Input', 'Ada jumlah pengiriman yang melebihi stok gudang!', 'error');
        return false;
    }

    if (!adaYangDikirim) {
        Swal.fire('Form Kosong', 'Harap isi minimal 1 nama vendor dan Qty Kirim untuk memproses.', 'info');
        return false;
    }

    return true;
}

    // --- FUNGSI BAWAAN PO DATA ---
    function ubahStatusMobile(poId, currentStatus) {
        Swal.fire({
            title: 'Update Status PO',
            input: 'select',
            inputOptions: { 'Design': 'Design', 'Antri': 'Antri', 'Produksi': 'Produksi', 'CMT': 'CMT', 'QC': 'QC', 'Clear': 'Clear', 'DP/Cicil': 'DP/Cicil', 'Lunas': 'Lunas' },
            inputValue: currentStatus,
            showCancelButton: true,
            confirmButtonText: 'Simpan Perubahan',
            confirmButtonColor: '#0d6efd',
        }).then((result) => {
            if (result.isConfirmed) {
                const form = document.createElement('form');
                form.method = 'POST';
                form.action = `/update-status/${poId}`;
                const input = document.createElement('input');
                input.type = 'hidden';
                input.name = 'status_baru';
                input.value = result.value;
                form.appendChild(input);
                document.body.appendChild(form);
                form.submit();
            }
        });
    }

    function toggleDetailMobile(id) {
        const el = document.getElementById('detail-mob-' + id);
        if(el) el.style.display = (el.style.display === 'block') ? 'none' : 'block';
    }
    
    function toggleDetailDesktop(id) {
        const el = document.getElementById('detail-desk-' + id);
        if(el) el.style.display = (el.style.display === 'table-row') ? 'none' : 'table-row';
    }

    function toggleMenu(event, id) {
        event.stopPropagation();
        const allMenus = document.querySelectorAll('.dropdown-content');
        allMenus.forEach(menu => { if (menu.id !== 'menu-' + id) menu.classList.remove('show'); });
        document.getElementById('menu-' + id).classList.toggle('show');
    }

    window.onclick = function(event) {
        if (!event.target.closest('.action-dropdown')) {
            document.querySelectorAll(".dropdown-content").forEach(d => d.classList.remove('show'));
        }
    }

    function bukaModalEdit(id) {
        document.getElementById('loadingEdit').style.display = 'flex';
        document.getElementById('iframeEditPO').src = '/edit-po/' + id;
        new bootstrap.Modal(document.getElementById('modalEditPO')).show();
    }

    function jalankanFilter() {
        let inputNama = document.getElementById("liveSearch").value.toLowerCase();
        let inputStatus = document.getElementById("filterStatus").value;
        let hideLunas = document.getElementById("checkLunas").checked;

        localStorage.setItem('filterNama', inputNama);
        localStorage.setItem('filterStatus', inputStatus);
        localStorage.setItem('hideLunas', hideLunas);
        document.getElementById('checkAllVisible').checked = false;

        let items = document.querySelectorAll(".filter-item");
        items.forEach(item => {
            let nama = item.getAttribute('data-nama');
            let status = item.getAttribute('data-status');
            let match = nama.includes(inputNama) && (inputStatus === "ALL" || status === inputStatus);
            
            if (match && !(hideLunas && status === "Lunas")) {
                item.style.display = ""; 
            } else {
                item.style.display = "none"; 
                let cb = item.querySelector('.po-checkbox');
                if (cb) cb.checked = false;
            }
        });
        updateCounter();
    }

    function updateCounter() {
        const chk = document.querySelectorAll('.po-checkbox:checked');
        const bar = document.getElementById('bulkActionArea');
        if (chk.length > 0) {
            bar.style.display = 'flex';
            document.getElementById('countSelected').innerText = chk.length + " PO Terpilih";
        } else {
            bar.style.display = 'none';
        }
    }

    function prosesNotaGabungan(mode = 'rinci') {
        const checked = document.querySelectorAll('.po-checkbox:checked');
        let ids = Array.from(checked).map(cb => cb.value);
        let customers = new Set(Array.from(checked).map(cb => cb.getAttribute('data-customer')));
        if (customers.size > 1) return alert("❌ Nota Gabungan hanya untuk 1 Customer yang sama.");
        window.open(`/cetak-nota-gabungan?ids=${ids.join(',')}&mode=${mode}`, '_blank');
    }

    function sinkronLunas(cb) {
        if (cb.checked && document.getElementById('filterStatus').value === 'Lunas') {
            document.getElementById('filterStatus').value = 'ALL';
        }
        jalankanFilter();
    }

    function bukaPanelQC(poId, namaPo) {
        document.getElementById('qc_nama_po').innerText = namaPo;
        const container = document.getElementById('container_input_qc');
        container.innerHTML = '<div class="text-center py-3"><div class="spinner-border spinner-border-sm text-success"></div></div>';
        fetch(`/api/po-details/${poId}`).then(res => res.json()).then(data => {
            let html = '';
            data.forEach(d => {
                html += `<div class="mb-3 border-bottom pb-2">
                    <label class="small fw-bold d-block mb-1 text-uppercase" style="font-size:10px">${d.nama_desain} (${d.jenis_bordir})</label>
                    <div class="input-group input-group-sm">
                        <span class="input-group-text bg-light small">Lulus:</span>
                        <input type="number" class="form-control fw-bold text-center input-qc-val" data-id="${d.id}" value="${d.total_qc || 0}" min="0">
                        <span class="input-group-text bg-light small">Pcs</span>
                    </div>
                </div>`;
            });
            container.innerHTML = html;
            new bootstrap.Modal(document.getElementById('modalQC')).show();
        });
    }

    async function simpanQCBulk() {
        const inputs = document.querySelectorAll('.input-qc-val');
        const dataKirim = Array.from(inputs).map(i => ({ detail_id: i.dataset.id, jumlah: i.value }));
        const response = await fetch('/update-qc-bulk', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ data: dataKirim })
        });
        if (response.ok) window.location.reload();
        else alert("Gagal menyimpan data.");
    }

    function ajakUpgrade(fitur) {
        Swal.fire({
            title: 'Fitur PRO!',
            text: 'Fitur ' + fitur + ' hanya tersedia untuk pengguna Akun PRO.',
            icon: 'warning',
            showCancelButton: true,
            confirmButtonColor: '#2ecc71',
            confirmButtonText: 'Upgrade PRO Sekarang',
            cancelButtonText: 'Nanti Dulu'
        }).then((result) => {
            if (result.isConfirmed) {
                window.open('https://wa.me/+6281315290003?text=Halo%20Admin%20Tatriz,%20saya%20tertarik%20upgrade%20PRO%20untuk%20' + fitur, '_blank');
            }
        });
    }

    function konfirmasiRepeat(id, nama) {
        Swal.fire({
            title: 'Repeat Order?',
            text: `Buat PO baru berdasarkan data "${nama}"? Semua detail desain dan harga akan disalin.`,
            icon: 'question',
            showCancelButton: true,
            confirmButtonColor: '#198754',
            confirmButtonText: 'Ya, Duplikat!',
            cancelButtonText: 'Batal'
        }).then((result) => {
            if (result.isConfirmed) window.location.href = `/admin/repeat-po/${id}`;
        });
    }

    function pilihSemuaTampil(source) {
        const rows = document.querySelectorAll("#bodyPO tr.clickable-row");
        rows.forEach(row => {
            if (row.style.display !== "none") {
                const checkbox = row.querySelector('.po-checkbox');
                if (checkbox) checkbox.checked = source.checked;
            }
        });
        updateCounter();
    }

    window.onload = function() {
        const sn = localStorage.getItem('filterNama');
        const ss = localStorage.getItem('filterStatus');
        const shl = localStorage.getItem('hideLunas');
        if (sn !== null) document.getElementById('liveSearch').value = sn;
        if (ss !== null) document.getElementById('filterStatus').value = ss;
        if (shl !== null) document.getElementById('checkLunas').checked = (shl === 'true');
        jalankanFilter();
    };
</script>
<script>
        document.addEventListener('DOMContentLoaded', function() {
            const loader = document.getElementById('loaderSistem');
            if (loader) {
                setTimeout(function() {
                    loader.classList.add('loader-hilang');
                }, 200);
            }
        });
        setTimeout(function() {
            const loader = document.getElementById('loaderSistem');
            if (loader && !loader.classList.contains('loader-hilang')) {
                loader.classList.add('loader-hilang');
            }
        }, 4000);
    </script>
